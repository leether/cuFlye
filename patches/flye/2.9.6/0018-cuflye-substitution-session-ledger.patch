+	OverlapWorkerReplayShape makeOverlapWorkerReplayShape(
+		bool forceLocal,
+		int maxOverlaps,
+		bool keepAlignment,
+		bool onlyMaxExt,
+		bool nuclAlignment,
+		bool partitionBadMappings)
+	{
+		OverlapWorkerReplayShape shape;
+		shape.forceLocal = forceLocal;
+		shape.maxOverlaps = maxOverlaps;
+		shape.keepAlignment = keepAlignment;
+		shape.onlyMaxExt = onlyMaxExt;
+		shape.nuclAlignment = nuclAlignment;
+		shape.partitionBadMappings = partitionBadMappings;
+
+		std::vector<std::string> unsupported;
+		if (nuclAlignment)
+		{
+			unsupported.push_back("nucl_alignment=true requires base-alignment replay");
+		}
+		if (partitionBadMappings)
+		{
+			unsupported.push_back("partition_bad_mappings=true requires trim replay");
+		}
+		if (keepAlignment)
+		{
+			unsupported.push_back("keep_alignment=true is outside M4c prototype scope");
+		}
+		if (!onlyMaxExt)
+		{
+			unsupported.push_back("only_max_ext=false is outside M4c prototype scope");
+		}
+		if (maxOverlaps != 0)
+		{
+			unsupported.push_back("max_overlaps!=0 is outside M4c prototype scope");
+		}
+		shape.supported = unsupported.empty();
+		shape.unsupportedReason = joinSemicolon(unsupported);
+		return shape;
 	}
 
