+	std::string joinSemicolon(const std::vector<std::string>& values)
+	{
+		std::ostringstream joined;
+		for (size_t i = 0; i < values.size(); ++i)
+		{
+			if (i) joined << "; ";
+			joined << values[i];
+		}
+		return joined.str();
+	}
