+	ReadToGraphRawOverlapRehydrationResult
+	evaluateReadToGraphRawOverlapRehydration(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const std::vector<ReadToGraphRawOverlapRowKey>& workerKeys)
