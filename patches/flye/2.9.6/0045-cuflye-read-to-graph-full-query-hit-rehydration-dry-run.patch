+			result, "audit_metadata_available",
+			!dryRun.rawOverlapRehydrationJson.empty(),
+			"raw-overlap rehydration audit JSON path must be available");
+		addReadToGraphRawOverlapRehydrationCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphRawOverlapRehydrationChecksPassed(result))
+		{
+			result.error = "raw-overlap rehydration preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto records = readToGraphRawOverlapRecords(result.workerTsv);
+			result.parsedRecords = records.size();
+			if (result.proofFault == "drop-first-rehydrated-record" &&
+				!records.empty())
+			{
+				records.erase(records.begin());
+				result.proofFaultApplied = true;
+			}
+			result.rehydratedRecords = records.size();
