+			result.mode == "raw-overlap-vector-dry-run-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_REHYDRATION_MODE="
+			"raw-overlap-vector-dry-run-v0");
+		addReadToGraphRawOverlapRehydrationCheck(
+			result, "worker_row_key_parity_passed",
+			dryRun.rowKeyMatched && dryRun.workerOutputConsumptionEligible,
+			"M6l/M6n full-query-hit worker row-key diff must pass first");
+		addReadToGraphRawOverlapRehydrationCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
