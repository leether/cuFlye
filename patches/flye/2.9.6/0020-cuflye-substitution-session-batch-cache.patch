+	bool vectorContainsQueryId(const std::vector<int64_t>& ids, int64_t queryId)
+	{
+		return std::find(ids.begin(), ids.end(), queryId) != ids.end();
+	}
+
+	void collectSessionBatchRequest(
+		const std::vector<std::string>& capturedFixtures,
+		const std::vector<int64_t>& capturedQueryIds,
+		std::vector<std::string>& requestFixtures,
+		std::vector<int64_t>& requestQueryIds)
+	{
+		requestFixtures.clear();
+		requestQueryIds.clear();
+		std::set<int64_t> seen;
+		const auto& selectedIds = overlapReplayQueryIds();
+		for (size_t idx = 0; idx < capturedFixtures.size() &&
+							 idx < capturedQueryIds.size(); ++idx)
+		{
+			int64_t queryId = capturedQueryIds[idx];
+			if (!vectorContainsQueryId(selectedIds, queryId)) continue;
+			if (!seen.insert(queryId).second) continue;
+			requestFixtures.push_back(capturedFixtures[idx]);
+			requestQueryIds.push_back(queryId);
+			if (requestFixtures.size() == overlapReplayMaxFixtures()) return;
+		}
+	}
+
