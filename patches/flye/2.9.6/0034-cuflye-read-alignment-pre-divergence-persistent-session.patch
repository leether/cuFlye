+	std::string readAlignmentWorkerLifecycleMode()
+	{
+		static std::string mode = []()
+		{
+			const char* raw =
+				std::getenv("CUFLYE_READ_ALIGNMENT_WORKER_LIFECYCLE_MODE");
+			if (!raw || !raw[0]) return std::string();
+			std::string selected(raw);
+			if (selected != "session-file-v0")
+			{
+				throw std::runtime_error(
+					"Unsupported "
