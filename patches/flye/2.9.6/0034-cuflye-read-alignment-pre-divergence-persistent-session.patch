+	{
+		if (std::rename(from.c_str(), to.c_str()) != 0)
+		{
+			throw std::runtime_error("cuFlye read alignment worker seam cannot rename " +
+									 from + " to " + to + ": " +
+									 std::strerror(errno));
+		}
+	}
+
+	void waitForReadAlignmentReadableFile(const std::string& path,
+										  const std::string& label,
+										  unsigned long timeoutMs,
+										  unsigned long pollMs)
+	{
+		auto waitStart = std::chrono::steady_clock::now();
+		while (!readableFile(path))
+		{
+			if (readAlignmentElapsedMs(waitStart,
+									   std::chrono::steady_clock::now()) >
+				static_cast<double>(timeoutMs))
+			{
+				throw std::runtime_error(
+					"cuFlye read alignment worker seam timed out waiting for " +
+					label + ": " + path);
+			}
+			std::this_thread::sleep_for(std::chrono::milliseconds(pollMs));
+		}
+	}
