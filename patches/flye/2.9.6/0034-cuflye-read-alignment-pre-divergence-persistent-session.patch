+	unsigned long parsePositiveReadAlignmentWorkerEnv(const char* name,
+													  unsigned long fallback)
+	{
+		const char* raw = std::getenv(name);
+		if (!raw || !raw[0]) return fallback;
+		std::string text(raw);
+		size_t parsedChars = 0;
+		if (!std::isdigit(static_cast<unsigned char>(text[0])))
+		{
+			throw std::runtime_error(std::string("Unsupported ") + name +
+									 ": expected positive integer, got " + text);
+		}
+		unsigned long parsed = std::stoul(text, &parsedChars);
+		if (parsedChars != text.size() || parsed == 0)
+		{
+			throw std::runtime_error(std::string("Unsupported ") + name +
+									 ": expected positive integer, got " + text);
+		}
+		return parsed;
+	}
+
+	unsigned long readAlignmentWorkerFileSessionPollMs()
+	{
+		static unsigned long pollMs = parsePositiveReadAlignmentWorkerEnv(
+			"CUFLYE_READ_ALIGNMENT_WORKER_SESSION_POLL_MS", 2);
+		return pollMs;
+	}
+
+	unsigned long readAlignmentWorkerFileSessionTimeoutMs()
+	{
+		static unsigned long timeoutMs = parsePositiveReadAlignmentWorkerEnv(
+			"CUFLYE_READ_ALIGNMENT_WORKER_SESSION_TIMEOUT_MS", 600000);
+		return timeoutMs;
+	}
