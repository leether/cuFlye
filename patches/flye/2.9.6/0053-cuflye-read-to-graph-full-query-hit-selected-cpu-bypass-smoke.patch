+
+	bool allReadToGraphFullQueryHitSelectedCpuBypassSmokeChecksPassed(
+		const ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult& smoke)
+	{
+		for (const auto& check : smoke.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !smoke.checks.empty();
+	}
+
+	void addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+		ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult& smoke,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		smoke.checks.push_back(check);
+	}
+
+	ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult
+	evaluateReadToGraphFullQueryHitSelectedCpuBypassSmoke(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitSelectedBypassDryRunResult& selectedBypass,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult result;
+		result.mode = readToGraphFullQueryHitSelectedCpuBypassSmokeMode();
+		result.proofFault =
+			readToGraphFullQueryHitSelectedCpuBypassSmokeProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.selectedBypassDryRunStatus = selectedBypass.status;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitSelectedCpuBypassSmokeEnabled())
+		{
+			return result;
+		}
+
+		markReadToGraphFullQueryHitSelectedCpuBypassSmokeFailed(result);
+		addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+			result, "explicit_selected_cpu_bypass_smoke_mode",
+			result.mode == "selected-cpu-bypass-smoke-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SELECTED_CPU_BYPASS_SMOKE_MODE="
+			"selected-cpu-bypass-smoke-v0");
+		addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+			result, "selected_bypass_dry_run_passed",
+			selectedBypass.status == "passed" && selectedBypass.eligible &&
+				!selectedBypass.failedClosed,
+			"M6x selected bypass dry-run must pass before selected CPU-bypass smoke");
+		addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+			result, "selected_bypass_dry_run_row_keys_matched",
+			selectedBypass.selectedBypassRowKeyMatched &&
+				selectedBypass.selectedBypassOrderedRowKeyMatched,
+			"M6x selected bypass dry-run must match selected CPU handoff rows");
+		addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapSelectedCpuBypassSmokeJson.empty(),
+			"selected CPU-bypass smoke audit JSON path must be available");
+		addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitSelectedCpuBypassSmokeChecksPassed(
+				result))
+		{
+			result.error = "selected CPU-bypass smoke preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto allCpuRecords =
+				readToGraphOracleRawOverlapRecords(dryRun.queryIds);
+			auto selectedCpuRecords =
+				readToGraphSelectedCpuHandoffRecords(dryRun.queryIds);
+			result.totalCpuRawOverlapRows = allCpuRecords.size();
+			result.selectedCpuHandoffRows = selectedCpuRecords.size();
+			auto allCpuKeys =
+				readToGraphRawOverlapRecordRowKeys(allCpuRecords);
+			auto selectedCpuKeys =
+				readToGraphRawOverlapRecordRowKeys(selectedCpuRecords);
+			std::set<ReadToGraphRawOverlapRowKey> selectedCpuKeySet;
+			for (size_t index = 0; index < selectedCpuRecords.size(); ++index)
+			{
+				const auto key =
+					readToGraphRawOverlapRecordToRowKey(selectedCpuRecords[index]);
+				selectedCpuKeySet.insert(key);
+				result.skippedCpuSelectedRowsLedger.push_back(
+					readToGraphFullQueryHitSelectedBypassPlanRow(
+						index, selectedCpuRecords[index],
+						"selected-cpu-handoff-skipped",
+						"cuda-selected-bypass-supplier"));
+			}
+			result.skippedCpuSelectedRows =
+				result.skippedCpuSelectedRowsLedger.size();
+
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				suppliedObjects =
+					buildReadToGraphFullQueryHitLiveObjectVector(
+						result.workerTsv, graph, result.missingGraphEdgeRows);
+			std::vector<ReadToGraphRawOverlapRecord> suppliedRecords;
+			std::set<ReadToGraphRawOverlapRowKey> suppliedKeys;
+			for (size_t index = 0; index < suppliedObjects.size(); ++index)
+			{
+				const auto& object = suppliedObjects[index];
+				const auto key =
+					readToGraphRawOverlapRecordToRowKey(object.record);
+				suppliedKeys.insert(key);
+				suppliedRecords.push_back(object.record);
+				result.cudaSuppliedRows.push_back(
+					readToGraphFullQueryHitSelectedBypassPlanRow(
+						index, object.record,
+						"cuda-supplied-selected-bypass",
+						"m6x-selected-bypass-row"));
+			}
+			result.cudaSuppliedSelectedRows = result.cudaSuppliedRows.size();
+			auto suppliedRecordKeys =
+				readToGraphRawOverlapRecordRowKeys(suppliedRecords);
+			result.cudaSuppliedRowKeyDiff =
+				compareReadToGraphRawOverlapRowKeys(
+					selectedCpuKeys, suppliedRecordKeys);
+			result.cudaSuppliedRowKeyMatched =
+				result.cudaSuppliedRowKeyDiff.matched;
+			result.cudaSuppliedOrderedRowKeyMatched =
+				result.cudaSuppliedRowKeyDiff.orderedMatched;
+			result.missingCudaSuppliedRows =
+				result.cudaSuppliedRowKeyDiff.missingRows;
+			result.unexpectedCudaSuppliedRows =
+				result.cudaSuppliedRowKeyDiff.extraRows;
+			result.cpuOwnedRows = selectedBypass.cpuOwnedRows;
+			result.cpuOwnedResidualRows = result.cpuOwnedRows.size();
+
+			bool leakFirstSkippedCpuRow =
+				result.proofFault == "leak-first-skipped-cpu-row" &&
+				!selectedCpuRecords.empty();
+			ReadToGraphRawOverlapRowKey leakedKey;
+			if (leakFirstSkippedCpuRow)
+			{
+				leakedKey = readToGraphRawOverlapRecordToRowKey(
+					selectedCpuRecords.front());
+				result.proofFaultApplied = true;
+			}
+
+			std::vector<ReadToGraphRawOverlapRecord> finalMergedRecords;
+			for (const auto& record : allCpuRecords)
+			{
+				const auto key = readToGraphRawOverlapRecordToRowKey(record);
+				finalMergedRecords.push_back(record);
+				if (suppliedKeys.count(key) != 0 &&
+					!(leakFirstSkippedCpuRow && key == leakedKey))
+				{
+					++result.finalCudaSuppliedRows;
+					result.finalMergedLedger.push_back(
+						readToGraphFullQueryHitSelectedBypassPlanRow(
+							result.finalMergedLedger.size(), record,
+							"cuda-supplied-selected-bypass",
+							"selected-cpu-handoff-skipped"));
+				}
+				else if (selectedCpuKeySet.count(key) != 0)
+				{
+					if (leakFirstSkippedCpuRow && key == leakedKey)
+					{
+						++result.leakedSelectedCpuRows;
+						result.finalMergedLedger.push_back(
+							readToGraphFullQueryHitSelectedBypassPlanRow(
+								result.finalMergedLedger.size(), record,
+								"cpu-owned-selected-leak",
+								"proof-fault-leaked-skipped-selected-row"));
+					}
+					else
+					{
+						++result.missingCudaSuppliedRows;
+						result.finalMergedLedger.push_back(
+							readToGraphFullQueryHitSelectedBypassPlanRow(
+								result.finalMergedLedger.size(), record,
+								"selected-cpu-skip-without-cuda-supply",
+								"selected-row-not-present-in-cuda-supply"));
+					}
+				}
+				else
+				{
+					std::string reason = "not-selected-for-bypass";
+					if (record.edgeId == 0)
+					{
+						reason = "unsupported-unresolved-edge-id";
+					}
+					result.finalMergedLedger.push_back(
+						readToGraphFullQueryHitSelectedBypassPlanRow(
+							result.finalMergedLedger.size(), record,
+							"cpu-owned", reason));
+				}
+			}
+			result.finalMergedLedgerRows = result.finalMergedLedger.size();
+			auto finalMergedKeys =
+				readToGraphRawOverlapRecordRowKeys(finalMergedRecords);
+			result.finalMergedRowKeyDiff =
+				compareReadToGraphRawOverlapRowKeys(
+					allCpuKeys, finalMergedKeys);
+			result.finalMergedRowKeyMatched =
+				result.finalMergedRowKeyDiff.matched;
+			result.finalMergedOrderedRowKeyMatched =
+				result.finalMergedRowKeyDiff.orderedMatched;
+
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "selected_cpu_handoff_rows_present",
+				result.selectedCpuHandoffRows > 0,
+				"selected CPU handoff rows must be nonzero");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "skipped_cpu_rows_match_selected_handoff",
+				result.skippedCpuSelectedRows == result.selectedCpuHandoffRows,
+				"skipped CPU-selected rows must match selected CPU handoff rows");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "cuda_supplied_selected_rows_present",
+				result.cudaSuppliedSelectedRows > 0,
+				"CUDA-supplied selected bypass rows must be nonzero");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "cuda_supplied_count_matches_skipped_cpu_rows",
+				result.cudaSuppliedSelectedRows == result.skippedCpuSelectedRows,
+				"CUDA-supplied rows must match skipped CPU-selected rows");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "cuda_supplied_row_keys_match_selected_cpu_rows",
+				result.cudaSuppliedRowKeyMatched,
+				"CUDA-supplied selected row keys must match skipped CPU-selected rows");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "cuda_supplied_row_order_matches_selected_cpu_rows",
+				result.cudaSuppliedOrderedRowKeyMatched,
+				"CUDA-supplied selected row order must match skipped CPU-selected rows");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "cpu_owned_residual_rows_preserved",
+				result.cpuOwnedResidualRows == selectedBypass.cpuOwnedResidualRows &&
+					result.cpuOwnedResidualRows == result.cpuOwnedRows.size(),
+				"CPU-owned residual rows must be preserved from M6x");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "final_merged_ledger_accounts_for_input",
+				result.finalMergedLedgerRows == result.totalCpuRawOverlapRows &&
+					result.finalMergedLedgerRows ==
+						result.finalMergedLedger.size(),
+				"final merged smoke ledger must account for all CPU raw-overlap rows");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "final_merged_row_keys_match_cpu_oracle",
+				result.finalMergedRowKeyMatched,
+				"final merged smoke ledger row keys must match CPU oracle");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "final_merged_row_order_matches_cpu_oracle",
+				result.finalMergedOrderedRowKeyMatched,
+				"final merged smoke ledger row order must match CPU oracle");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "final_cuda_supplied_rows_match_supplier",
+				result.finalCudaSuppliedRows == result.cudaSuppliedSelectedRows,
+				"final merged ledger must consume every CUDA-supplied selected row");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "leaked_selected_cpu_rows_zero",
+				result.leakedSelectedCpuRows == 0,
+				"skipped selected CPU rows must not leak back into CPU-owned path");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "missing_cuda_supplied_rows_zero",
+				result.missingCudaSuppliedRows == 0,
+				"every skipped selected CPU row must have a CUDA supplier");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "unexpected_cuda_supplied_rows_zero",
+				result.unexpectedCudaSuppliedRows == 0,
+				"CUDA supplier must not add unexpected selected rows");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "bypass_objects_have_live_graph_edges",
+				result.missingGraphEdgeRows == 0,
+				"every CUDA-supplied selected object must have a live GraphEdge");
+			addReadToGraphFullQueryHitSelectedCpuBypassSmokeCheck(
+				result, "graph_not_mutated_after_selected_cpu_bypass_smoke",
+				!result.graphMutationConsumedWorkerOutput,
+				"selected CPU-bypass smoke must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitSelectedCpuBypassSmokeChecksPassed(
+					result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"selected-cpu-bypass-smoke-written-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"selected CPU-bypass smoke differs from M6x selected bypass dry-run";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitSelectedCpuBypassSmokeFailed(result);
+		}
+		return result;
+	}
+
+	void captureReadToGraphFullQueryHitSelectedCpuBypassSmokeResult(
+		ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult& smoke)
+	{
+		dryRun.rawOverlapSelectedCpuBypassSmokeMode = smoke.mode;
+		dryRun.rawOverlapSelectedCpuBypassSmokeProofFault =
+			smoke.proofFault;
