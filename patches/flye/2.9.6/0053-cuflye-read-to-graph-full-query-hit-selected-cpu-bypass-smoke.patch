+	void markReadToGraphFullQueryHitSelectedCpuBypassSmokeFailed(
+		ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult& smoke)
+	{
+		smoke.status = "failed";
+		smoke.state = "failed-closed";
+		smoke.decision = "failed-closed-before-graph-mutation";
+		smoke.eligible = false;
