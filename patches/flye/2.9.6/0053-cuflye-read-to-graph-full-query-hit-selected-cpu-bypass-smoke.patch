+			 << indent << "\"missing_rows\": " << diff.missingRows << ",\n"
+			 << indent << "\"extra_rows\": " << diff.extraRows << ",\n"
+			 << indent << "\"missing_examples\": [";
+		for (size_t index = 0; index < diff.missingExamples.size(); ++index)
+		{
+			if (index) json << ", ";
+			json << "\"" << readAlignmentJsonEscape(
+				diff.missingExamples[index]) << "\"";
+		}
+		json << "],\n"
+			 << indent << "\"extra_examples\": [";
+		for (size_t index = 0; index < diff.extraExamples.size(); ++index)
