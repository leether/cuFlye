+	unsigned long parsePositiveOverlapWorkerEnv(const char* name,
+												unsigned long fallback)
+	{
+		const char* raw = std::getenv(name);
+		if (!raw || !raw[0]) return fallback;
+		std::string text(raw);
+		size_t parsedChars = 0;
+		if (!std::isdigit(static_cast<unsigned char>(text[0])))
+		{
+			throw std::runtime_error(std::string("Unsupported ") + name +
+									 ": expected positive integer, got " + text);
+		}
+		unsigned long parsed = std::stoul(text, &parsedChars);
+		if (parsedChars != text.size() || parsed == 0)
+		{
+			throw std::runtime_error(std::string("Unsupported ") + name +
+									 ": expected positive integer, got " + text);
+		}
+		return parsed;
+	}
+
+	unsigned long overlapWorkerFileSessionPollMs()
+	{
+		static unsigned long pollMs = parsePositiveOverlapWorkerEnv(
+			"CUFLYE_OVERLAP_WORKER_SESSION_POLL_MS", 2);
+		return pollMs;
+	}
+
+	unsigned long overlapWorkerFileSessionTimeoutMs()
+	{
+		static unsigned long timeoutMs = parsePositiveOverlapWorkerEnv(
+			"CUFLYE_OVERLAP_WORKER_SESSION_TIMEOUT_MS", 600000);
+		return timeoutMs;
+	}
