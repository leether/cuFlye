+	void renamePath(const std::string& from, const std::string& to)
+	{
+		ensureParentDirectory(to);
+		if (std::rename(from.c_str(), to.c_str()) != 0)
+		{
+			throw std::runtime_error("cuFlye overlap worker seam cannot rename " +
+									 from + " to " + to + ": " +
+									 std::strerror(errno));
+		}
+	}
+
+	void waitForReadableFile(const std::string& path,
+							 const std::string& label,
+							 unsigned long timeoutMs,
+							 unsigned long pollMs)
+	{
+		auto waitStart = overlapWorkerTimingNow();
+		while (!fileExists(path))
+		{
+			if (overlapWorkerElapsedMs(waitStart) >
+				static_cast<double>(timeoutMs))
+			{
+				throw std::runtime_error(
+					"cuFlye overlap worker seam timed out waiting for " + label +
+					": " + path);
+			}
+			std::this_thread::sleep_for(std::chrono::milliseconds(pollMs));
+		}
+		ensureReadableFile(path, label);
+	}
