+	std::string joinReplayPath(const std::string& root, const std::string& leaf)
+	{
+		if (root.empty()) return leaf;
+		if (root.back() == '/') return root + leaf;
+		return root + "/" + leaf;
+	}
+
+	void writeAlignmentRows(const std::string& path,
+							const std::vector<GraphAlignment>& chains)
+	{
+		std::ofstream fout(path);
+		if (!fout)
+		{
+			throw std::runtime_error("Can't open read alignment replay oracle path");
+		}
+		fout << std::setprecision(9);
+		for (size_t chainId = 0; chainId < chains.size(); ++chainId)
+		{
+			const auto& chain = chains[chainId];
+			for (size_t segmentId = 0; segmentId < chain.size(); ++segmentId)
+			{
+				const auto& aln = chain[segmentId];
+				const auto& ovlp = aln.overlap;
+				fout << chainId << "\t"
+					 << segmentId << "\t"
+					 << ovlp.curId.signedId() << "\t"
+					 << ovlp.curBegin << "\t"
+					 << ovlp.curEnd << "\t"
+					 << ovlp.curLen << "\t"
+					 << aln.edge->edgeId.signedId() << "\t"
+					 << ovlp.extId.signedId() << "\t"
+					 << ovlp.extBegin << "\t"
+					 << ovlp.extEnd << "\t"
+					 << ovlp.extLen << "\t"
+					 << ovlp.score << "\t"
+					 << ovlp.seqDivergence << "\n";
+			}
+		}
+	}
