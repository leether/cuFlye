+
+	int64_t parseReplayQueryId()
+	{
+		const char* raw = std::getenv("CUFLYE_READ_ALIGNMENT_REPLAY_QUERY_ID");
+		if (!raw || !raw[0])
+		{
+			throw std::runtime_error(
+				"CUFLYE_READ_ALIGNMENT_REPLAY_QUERY_ID is required when "
+				"CUFLYE_READ_ALIGNMENT_REPLAY_DUMP_DIR is set");
+		}
+		size_t parsedChars = 0;
+		int64_t queryId = std::stoll(raw, &parsedChars);
+		if (parsedChars != std::string(raw).size() || queryId <= 0)
+		{
+			throw std::runtime_error(
+				"CUFLYE_READ_ALIGNMENT_REPLAY_QUERY_ID must be a positive integer");
+		}
+		return queryId;
+	}
+
+	int64_t readAlignmentReplayQueryId()
+	{
+		static int64_t queryId = parseReplayQueryId();
+		return queryId;
+	}
