+		std::ofstream overlapOut(joinReplayPath(dumpDir, "edge-overlaps.tsv"));
+		std::ofstream divergenceOut(joinReplayPath(dumpDir, "chain-divergence.tsv"));
+		if (!readOut || !edgeSeqOut || !overlapOut || !divergenceOut)
+		{
+			throw std::runtime_error(
+				"Can't open CUFLYE_READ_ALIGNMENT_REPLAY_DUMP_DIR output files");
+		}
+
+		readOut << seqId.signedId() << "\t" << readSeqs.getSeq(seqId).str() << "\n";
+
+		std::unordered_set<int64_t> writtenEdgeSeqs;
+		overlapOut << std::setprecision(9);
+		for (size_t index = 0; index < alignments.size(); ++index)
+		{
+			const auto& aln = alignments[index];
+			const auto& ovlp = aln.overlap;
+			overlapOut << index << "\t"
+					   << ovlp.curId.signedId() << "\t"
+					   << ovlp.curBegin << "\t"
+					   << ovlp.curEnd << "\t"
+					   << ovlp.curLen << "\t"
+					   << aln.edge->edgeId.signedId() << "\t"
+					   << aln.edge->nodeLeft->nodeId << "\t"
+					   << aln.edge->nodeRight->nodeId << "\t"
+					   << ovlp.extId.signedId() << "\t"
+					   << ovlp.extBegin << "\t"
+					   << ovlp.extEnd << "\t"
+					   << ovlp.extLen << "\t"
+					   << ovlp.score << "\t"
+					   << ovlp.seqDivergence << "\n";
+			if (writtenEdgeSeqs.insert(ovlp.extId.signedId()).second)
+			{
+				edgeSeqOut << ovlp.extId.signedId() << "\t"
+						   << edgeSeqs.getSeq(ovlp.extId).str() << "\n";
+			}
+		}
+
+		for (size_t chainId = 0; chainId < readChains.size(); ++chainId)
+		{
+			bool accepted =
+				chainDivergences[chainId] <
+				static_cast<float>(Config::get("read_align_ovlp_divergence"));
+			divergenceOut << chainId << "\t"
+						  << std::setprecision(9) << chainDivergences[chainId] << "\t"
+						  << (accepted ? 1 : 0) << "\n";
+		}
+
+		writeAlignmentRows(joinReplayPath(dumpDir, "oracle.read-alignment.tsv"),
+						   goodChains);
+
+		std::ofstream manifestOut(joinReplayPath(dumpDir, "manifest.json"));
+		if (!manifestOut)
+		{
+			throw std::runtime_error("Can't open read alignment replay manifest");
+		}
+		manifestOut << "{\n"
+					<< "  \"schema\": \"cuflye-read-alignment-replay-fixture-v0\",\n"
+					<< "  \"query_id\": " << seqId.signedId() << ",\n"
+					<< "  \"alignment_input_records\": " << alignments.size() << ",\n"
+					<< "  \"candidate_chains\": " << readChains.size() << ",\n"
+					<< "  \"oracle_chains\": " << goodChains.size() << ",\n"
+					<< "  \"maximum_jump\": " << static_cast<int>(Config::get("maximum_jump")) << ",\n"
+					<< "  \"max_read_overlap\": 50,\n"
+					<< "  \"minimum_overlap\": " << Parameters::get().minimumOverlap << ",\n"
+					<< "  \"max_separation\": " << static_cast<int>(Config::get("max_separation")) << ",\n"
+					<< "  \"read_align_ovlp_divergence\": "
+					<< std::setprecision(9)
+					<< static_cast<float>(Config::get("read_align_ovlp_divergence")) << ",\n"
+					<< "  \"reads_base_alignment\": "
+					<< ((bool)Config::get("reads_base_alignment") ? "true" : "false") << "\n"
+					<< "}\n";
+	}
