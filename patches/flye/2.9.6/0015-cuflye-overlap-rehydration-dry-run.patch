+		}
+		return static_cast<int32_t>(value);
+	}
+
+	FastaRecord::Id checkedFastaIdFromSigned(int64_t signedId,
+											 const std::string& name,
+											 const std::string& path)
+	{
+		if (signedId < -static_cast<int64_t>(std::numeric_limits<int32_t>::max()) ||
+			signedId > static_cast<int64_t>(std::numeric_limits<int32_t>::max()) ||
+			signedId == 0)
+		{
+			throw std::runtime_error(path + ": " + name +
+									 " is outside Flye signed-id range");
+		}
+		return fastaIdFromSigned(signedId);
+	}
