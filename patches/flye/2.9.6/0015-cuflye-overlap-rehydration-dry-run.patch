+	int32_t checkedOverlapInt32(int64_t value,
+								const std::string& name,
+								const std::string& path)
+	{
+		if (value < std::numeric_limits<int32_t>::min() ||
+			value > std::numeric_limits<int32_t>::max())
+		{
+			throw std::runtime_error(path + ": " + name +
