+	void markRehydrationFailed(OverlapWorkerRehydrationResult& rehydration)
+	{
+		rehydration.status = "failed";
+		rehydration.state = "failed-closed";
+		rehydration.decision = "failed-closed-before-graph-mutation";
+		rehydration.eligible = false;
+		rehydration.consumed = false;
