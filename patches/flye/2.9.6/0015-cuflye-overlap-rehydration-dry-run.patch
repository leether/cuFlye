+	OverlapTypedRecord overlapDumpRecordToTypedRecord(
+		const OverlapDumpRecord& record,
+		const std::string& path)
+	{
+		OverlapTypedRecord typed;
+		typed.curId = checkedFastaIdFromSigned(record.curId, "cur_id", path);
+		typed.curBegin = checkedOverlapInt32(record.curBegin, "cur_begin", path);
+		typed.curEnd = checkedOverlapInt32(record.curEnd, "cur_end", path);
+		typed.curLen = checkedOverlapInt32(record.curLen, "cur_len", path);
+		typed.extId = checkedFastaIdFromSigned(record.extId, "ext_id", path);
+		typed.extBegin = checkedOverlapInt32(record.extBegin, "ext_begin", path);
+		typed.extEnd = checkedOverlapInt32(record.extEnd, "ext_end", path);
+		typed.extLen = checkedOverlapInt32(record.extLen, "ext_len", path);
+		typed.score = checkedOverlapInt32(record.score, "score", path);
+		typed.seqDivergence = record.seqDivergence;
+		return typed;
+	}
+
+	OverlapDumpRecord overlapTypedRecordToDumpRecord(
+		const OverlapTypedRecord& typed)
+	{
+		OverlapDumpRecord record;
+		record.curId = typed.curId.signedId();
+		record.curBegin = typed.curBegin;
+		record.curEnd = typed.curEnd;
+		record.curLen = typed.curLen;
+		record.extId = typed.extId.signedId();
+		record.extBegin = typed.extBegin;
+		record.extEnd = typed.extEnd;
+		record.extLen = typed.extLen;
+		record.score = typed.score;
+		record.seqDivergence = typed.seqDivergence;
+		return record;
+	}
+
+	std::vector<OverlapTypedRecord> rehydrateTypedOverlapRecords(
+		const std::vector<OverlapDumpRecord>& records,
+		const std::string& path)
+	{
+		std::vector<OverlapTypedRecord> typedRecords;
+		typedRecords.reserve(records.size());
+		for (const auto& record : records)
+		{
+			typedRecords.push_back(overlapDumpRecordToTypedRecord(record, path));
+		}
+		return typedRecords;
+	}
+
+	std::vector<OverlapDumpRecord> canonicalOverlapRecordsFromTyped(
+		const std::vector<OverlapTypedRecord>& typedRecords)
+	{
+		std::vector<OverlapDumpRecord> records;
+		records.reserve(typedRecords.size());
+		for (const auto& record : typedRecords)
+		{
+			records.push_back(overlapTypedRecordToDumpRecord(record));
+		}
+		std::sort(records.begin(), records.end());
+		return records;
+	}
