+	OverlapWorkerRehydrationResult compareOverlapWorkerRehydrationOutputs(
+		const std::vector<std::string>& fixtures,
+		const std::string& batchOutputDir,
+		const OverlapWorkerValidationResult& validation,
+		const OverlapWorkerShadowResult& shadow,
+		const OverlapWorkerGraphGuardResult& graphGuard,
+		const std::string& rehydrationJson)
+	{
+		OverlapWorkerRehydrationResult result;
+		result.mode = overlapWorkerRehydrationMode();
+		result.proofFault = overlapWorkerRehydrationProofFault();
+		if (!overlapWorkerRehydrationEnabled()) return result;
+
+		markRehydrationFailed(result);
+		addRehydrationCheck(result, "explicit_rehydration_mode",
+							result.mode == "typed-overlap-v0",
+							"CUFLYE_OVERLAP_REHYDRATION_MODE=typed-overlap-v0");
+		addRehydrationCheck(result, "graph_guard_passed",
+							graphGuard.status == "passed" && graphGuard.eligible,
+							"M4o graph-consumption guard must be eligible");
+		addRehydrationCheck(result, "validation_passed",
+							validation.status == "passed" &&
+								validation.consumptionEligible,
+							"worker output validation must pass");
+		addRehydrationCheck(result, "shadow_passed",
+							shadow.status == "passed" &&
+								shadow.shadowConsumptionEligible,
+							"in-memory shadow comparison must pass");
+		addRehydrationCheck(result, "fixture_count_matches_request",
+							fixtures.size() == overlapReplayMaxFixtures(),
+							"captured fixture count must match request");
+		addRehydrationCheck(result, "audit_metadata_available",
+							!rehydrationJson.empty(),
+							"rehydration audit JSON path must be available");
+
+		if (!allRehydrationChecksPassed(result)) return result;
+
+		result.status = "passed";
+		result.state = "not-consumed";
+		result.decision = "typed-vector-match-not-consumed";
+		result.eligible = true;
+		result.notConsumed = true;
+		result.failedClosed = false;
+
+		auto& cpuRecordsByFixture = overlapReplayCapturedCpuRecords();
+		for (const auto& fixtureDir : fixtures)
+		{
+			OverlapWorkerFixtureRehydration fixture;
+			fixture.fixtureDir = fixtureDir;
+			fixture.fixtureName = pathBasename(fixtureDir);
+			fixture.workerPath = joinPath(joinPath(batchOutputDir, fixture.fixtureName),
+										  "overlaps.tsv");
+			try
+			{
+				auto cpuIt = cpuRecordsByFixture.find(fixtureDir);
+				if (cpuIt == cpuRecordsByFixture.end())
+				{
+					throw std::runtime_error(
+						"missing captured CPU overlap records for fixture");
+				}
+				fixture.cpuRecords = cpuIt->second.size();
+				auto workerRecords = readCanonicalOverlapDump(fixture.workerPath);
+				fixture.workerRecords = workerRecords.size();
+				if (result.proofFault == "drop-first-worker-record" &&
+					!workerRecords.empty())
+				{
+					workerRecords.erase(workerRecords.begin());
+					fixture.proofFaultApplied = true;
+				}
+				auto typedRecords = rehydrateTypedOverlapRecords(workerRecords,
+																fixture.workerPath);
+				fixture.rehydratedRecords = typedRecords.size();
+				auto rehydratedRecords = canonicalOverlapRecordsFromTyped(typedRecords);
+				if (cpuIt->second == rehydratedRecords)
+				{
+					fixture.status = "passed";
+					fixture.typedVectorStatus = "match";
+				}
+				else
+				{
+					fixture.status = "failed";
+					fixture.typedVectorStatus = "mismatch";
+					fixture.error =
+						"rehydrated typed overlap vector differs from captured CPU records";
+					markRehydrationFailed(result);
+				}
+			}
+			catch (const std::exception& exc)
+			{
+				fixture.status = "failed";
+				fixture.error = exc.what();
+				markRehydrationFailed(result);
+			}
+			result.fixtures.push_back(fixture);
+		}
+
+		if (result.fixtures.empty()) markRehydrationFailed(result);
+		return result;
+	}
