+	void addReadAlignmentVectorSubstitutionCheck(
+		ReadAlignmentVectorSubstitutionResult& substitution,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadAlignmentVectorSubstitutionCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		substitution.checks.push_back(check);
+	}
+
+	bool allReadAlignmentVectorSubstitutionChecksPassed(
+		const ReadAlignmentVectorSubstitutionResult& substitution)
+	{
+		for (const auto& check : substitution.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !substitution.checks.empty();
+	}
+
+	void markReadAlignmentVectorSubstitutionFailed(
+		ReadAlignmentVectorSubstitutionResult& substitution)
+	{
+		substitution.status = "failed";
+		substitution.state = "failed-closed";
+		substitution.decision = "failed-closed-before-graph-mutation";
+		substitution.eligible = false;
+		substitution.accepted = false;
+		substitution.consumed = false;
+		substitution.notConsumed = false;
+		substitution.failedClosed = true;
+		substitution.graphFacingReturnedWorkerOutput = false;
+		substitution.graphMutationConsumedWorkerOutput = false;
+	}
+
+	void markReadAlignmentVectorSubstitutionConsumed(
+		ReadAlignmentVectorSubstitutionResult& substitution)
+	{
+		substitution.status = "passed";
+		substitution.state = "consumed";
+		substitution.decision =
+			"verified-graph-alignment-object-vector-substituted";
+		substitution.eligible = true;
+		substitution.accepted = true;
+		substitution.consumed = true;
+		substitution.notConsumed = false;
+		substitution.failedClosed = false;
+		substitution.graphFacingReturnedWorkerOutput = true;
+		substitution.graphMutationConsumedWorkerOutput = true;
+	}
+
+	ReadAlignmentVectorSubstitutionResult
+	evaluateReadAlignmentVectorSubstitution(
+		const std::vector<int64_t>& queryIds,
+		const std::string& batchOutputDir,
+		const ReadAlignmentObjectRehydrationResult& objectRehydration,
+		const std::string& substitutionJson,
+		RepeatGraph& graph,
+		std::vector<GraphAlignment>& alignments)
+	{
+		ReadAlignmentVectorSubstitutionResult result;
+		result.mode = readAlignmentVectorSubstitutionMode();
+		result.proofFault = readAlignmentVectorSubstitutionProofFault();
+		if (!readAlignmentVectorSubstitutionEnabled()) return result;
+
+		result.attempted = true;
+		markReadAlignmentVectorSubstitutionFailed(result);
+		addReadAlignmentVectorSubstitutionCheck(
+			result, "explicit_vector_substitution_mode",
+			result.mode == "verified-graph-alignment-v0",
+			"CUFLYE_READ_ALIGNMENT_VECTOR_SUBSTITUTION_MODE="
+			"verified-graph-alignment-v0");
+		addReadAlignmentVectorSubstitutionCheck(
+			result, "object_rehydration_passed",
+			objectRehydration.status == "passed" && objectRehydration.eligible,
+			"M5l GraphAlignment object-vector rehydration must pass");
+		addReadAlignmentVectorSubstitutionCheck(
+			result, "fixture_count_nonzero", !queryIds.empty(),
+			"at least one replay fixture must be selected");
+		addReadAlignmentVectorSubstitutionCheck(
+			result, "audit_metadata_available", !substitutionJson.empty(),
+			"vector substitution audit JSON path must be available");
+
+		if (!allReadAlignmentVectorSubstitutionChecksPassed(result))
+		{
+			return result;
+		}
+
+		result.status = "passed";
+		result.state = "pending-substitution";
+		result.decision = "verified-object-vector-match-pending-substitution";
+		result.eligible = true;
+		result.notConsumed = true;
+		result.failedClosed = false;
+		result.accepted = false;
+		result.consumed = false;
+		result.graphFacingReturnedWorkerOutput = false;
+		result.graphMutationConsumedWorkerOutput = false;
+
+		std::vector<ReadAlignmentQueryReplacement> replacements;
+		for (int64_t queryId : queryIds)
+		{
+			ReadAlignmentFixtureVectorSubstitution fixture;
+			fixture.queryId = queryId;
+			fixture.workerTsv = joinReplayPath(
+				joinReplayPath(batchOutputDir, replayQueryDirName(queryId)),
+				"read-alignment.tsv");
+			try
+			{
+				auto workerRecords = readAlignmentDumpRecords(fixture.workerTsv);
+				auto typedRecords =
+					rehydrateTypedReadAlignmentRecords(workerRecords, graph,
+													   fixture.workerTsv);
+				auto objectVector =
+					rehydrateGraphAlignmentObjectVector(typedRecords,
+														fixture.workerTsv);
+				if (result.proofFault == "drop-first-substitution-chain" &&
+					!objectVector.empty())
+				{
+					objectVector.erase(objectVector.begin());
+					fixture.proofFaultApplied = true;
+				}
+				fixture.objectChains = objectVector.size();
+				auto objectRecords =
+					canonicalReadAlignmentRecordsFromGraphAlignments(objectVector);
+				fixture.objectRecords = objectRecords.size();
+
+				auto cpuSlice = readAlignmentCpuSliceForQuery(alignments, queryId);
+				fixture.cpuChains = cpuSlice.size();
+				auto cpuRecords =
+					canonicalReadAlignmentRecordsFromGraphAlignments(cpuSlice);
+				fixture.cpuRecords = cpuRecords.size();
+				result.totalCpuRecords += fixture.cpuRecords;
+				result.totalObjectRecords += fixture.objectRecords;
+
+				if (cpuRecords != objectRecords)
+				{
+					fixture.status = "failed";
+					fixture.objectVectorStatus = "mismatch";
+					fixture.error =
+						"verified substitution object vector differs from CPU "
+						"_readAlignments slice";
+					markReadAlignmentVectorSubstitutionFailed(result);
+				}
+				else
+				{
+					fixture.status = "passed";
+					fixture.objectVectorStatus = "match";
+					ReadAlignmentQueryReplacement replacement;
+					replacement.queryId = queryId;
+					replacement.chains = objectVector;
+					replacements.push_back(replacement);
+				}
+			}
+			catch (const std::exception& exc)
+			{
+				fixture.status = "failed";
+				fixture.error = exc.what();
+				markReadAlignmentVectorSubstitutionFailed(result);
+			}
+			result.fixtures.push_back(fixture);
+		}
+
+		if (result.failedClosed || result.fixtures.empty()) return result;
+
+		std::vector<GraphAlignment> substitutedAlignments(alignments);
+		std::vector<size_t> replacementOffsets(replacements.size(), 0);
+		for (auto& chain : substitutedAlignments)
+		{
+			if (chain.empty()) continue;
+			int64_t queryId = chain.front().overlap.curId.signedId();
+			for (size_t index = 0; index < replacements.size(); ++index)
+			{
+				if (replacements[index].queryId != queryId) continue;
+				size_t& offset = replacementOffsets[index];
+				if (offset >= replacements[index].chains.size())
+				{
+					markReadAlignmentVectorSubstitutionFailed(result);
+					return result;
+				}
+				chain = replacements[index].chains[offset];
+				++offset;
+				++result.totalSubstitutedChains;
+				break;
+			}
+		}
+		for (size_t index = 0; index < replacements.size(); ++index)
+		{
+			if (replacementOffsets[index] != replacements[index].chains.size())
+			{
+				markReadAlignmentVectorSubstitutionFailed(result);
+				return result;
+			}
+		}
+		for (auto& fixture : result.fixtures)
+		{
+			for (const auto& replacement : replacements)
+			{
+				if (replacement.queryId == fixture.queryId)
+				{
+					fixture.substitutedChains = replacement.chains.size();
+				}
+			}
+		}
+
+		alignments.swap(substitutedAlignments);
+		markReadAlignmentVectorSubstitutionConsumed(result);
+		return result;
+	}
