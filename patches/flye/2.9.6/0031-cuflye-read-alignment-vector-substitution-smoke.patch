+	std::string readAlignmentVectorSubstitutionMode()
+	{
+		static std::string mode = []()
+		{
+			const char* raw =
+				std::getenv("CUFLYE_READ_ALIGNMENT_VECTOR_SUBSTITUTION_MODE");
+			if (!raw || !raw[0]) return std::string();
+			std::string selected(raw);
+			if (selected != "verified-graph-alignment-v0")
+			{
+				throw std::runtime_error(
+					"Unsupported CUFLYE_READ_ALIGNMENT_VECTOR_SUBSTITUTION_MODE: " +
+					selected);
+			}
+			return selected;
+		}();
+		return mode;
+	}
