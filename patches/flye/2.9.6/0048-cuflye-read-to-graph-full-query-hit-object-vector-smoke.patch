+	void addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+		ReadToGraphFullQueryHitObjectVectorSmokeResult& smoke,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitObjectVectorSmokeCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		smoke.checks.push_back(check);
+	}
+
+	bool allReadToGraphFullQueryHitObjectVectorSmokeChecksPassed(
+		const ReadToGraphFullQueryHitObjectVectorSmokeResult& smoke)
+	{
+		for (const auto& check : smoke.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !smoke.checks.empty();
+	}
+
+	void markReadToGraphFullQueryHitObjectVectorSmokeFailed(
+		ReadToGraphFullQueryHitObjectVectorSmokeResult& smoke)
+	{
+		smoke.status = "failed";
+		smoke.state = "failed-closed";
+		smoke.decision = "failed-closed-before-graph-mutation";
+		smoke.eligible = false;
+		smoke.consumed = false;
+		smoke.notConsumed = false;
+		smoke.failedClosed = true;
+		smoke.graphMutationConsumedWorkerOutput = false;
+	}
+
+	ReadToGraphFullQueryHitObjectVectorSmokeResult
+	evaluateReadToGraphFullQueryHitObjectVectorSmoke(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitGraphEdgeBindingResult& binding,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitObjectVectorSmokeResult result;
+		result.mode = readToGraphFullQueryHitObjectVectorSmokeMode();
+		result.proofFault =
+			readToGraphFullQueryHitObjectVectorSmokeProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.bindingStatus = binding.status;
+		result.chainInputFilterRows = binding.chainInputFilterRows;
+		result.bindingRows = binding.bindingRows;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitObjectVectorSmokeEnabled()) return result;
+
+		markReadToGraphFullQueryHitObjectVectorSmokeFailed(result);
+		addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+			result, "explicit_object_vector_smoke_mode",
+			result.mode == "object-vector-smoke-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_OBJECT_VECTOR_SMOKE_MODE="
+			"object-vector-smoke-v0");
+		addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+			result, "graph_edge_binding_passed",
+			binding.status == "passed" && binding.eligible &&
+				!binding.failedClosed,
+			"M6s graph-edge binding must pass before object-vector smoke");
+		addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+			result, "binding_rows_present",
+			binding.bindingRows > 0,
+			"object-vector smoke requires nonzero bound rows");
+		addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapObjectVectorSmokeJson.empty(),
+			"object-vector smoke audit JSON path must be available");
+		addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitObjectVectorSmokeChecksPassed(result))
+		{
+			result.error = "object-vector smoke preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto records = readToGraphRawOverlapRecords(result.workerTsv);
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				objects;
+			for (const auto& record : records)
+			{
+				if (!record.passesChainInputFilter) continue;
+				if (record.edgeId == 0)
+				{
+					++result.missingGraphEdgeRows;
+					continue;
+				}
+				FastaRecord::Id edgeId = checkedReadAlignmentFastaIdFromSigned(
+					record.edgeId, "edge_id", result.workerTsv);
+				GraphEdge* edge = graph.getEdge(edgeId);
+				if (!edge)
+				{
+					++result.missingGraphEdgeRows;
+					continue;
+				}
+				ReadToGraphFullQueryHitObjectVectorSmokeObject object;
+				object.record = record;
+				object.edge = edge;
+				objects.push_back(object);
+			}
+			result.objectRows = objects.size();
+
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				accountingObjects = objects;
+			if (result.proofFault == "drop-first-object-accounting-row" &&
+				!accountingObjects.empty())
+			{
+				accountingObjects.erase(accountingObjects.begin());
+				result.proofFaultApplied = true;
+			}
+			result.objectAccountingRows = accountingObjects.size();
+
+			std::map<int64_t, size_t> byQuery;
+			std::map<int64_t, size_t> byEdge;
+			std::map<std::pair<int64_t, int64_t>, size_t> byQueryEdge;
+			for (const auto& object : accountingObjects)
+			{
+				const int64_t queryId = object.record.queryId;
+				const int64_t edgeId = object.record.edgeId;
+				++byQuery[queryId];
+				++byEdge[edgeId];
+				++byQueryEdge[std::make_pair(queryId, edgeId)];
+			}
+			for (const auto& entry : byQuery)
+			{
+				ReadToGraphFullQueryHitObjectVectorSmokeQuerySummary summary;
+				summary.queryId = entry.first;
+				summary.objectRows = entry.second;
+				result.queryAccountedRows += entry.second;
+				result.queries.push_back(summary);
+			}
+			for (const auto& entry : byEdge)
+			{
+				ReadToGraphFullQueryHitObjectVectorSmokeEdgeSummary summary;
+				summary.edgeId = entry.first;
+				summary.objectRows = entry.second;
+				result.edgeAccountedRows += entry.second;
+				result.edges.push_back(summary);
+			}
+			for (const auto& entry : byQueryEdge)
+			{
+				ReadToGraphFullQueryHitObjectVectorSmokeQueryEdgeSummary
+					summary;
+				summary.queryId = entry.first.first;
+				summary.edgeId = entry.first.second;
+				summary.objectRows = entry.second;
+				result.queryEdgeAccountedRows += entry.second;
+				result.queryEdges.push_back(summary);
+			}
+			result.querySummaryRows = result.queries.size();
+			result.edgeSummaryRows = result.edges.size();
+			result.queryEdgeSummaryRows = result.queryEdges.size();
+
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "constructed_objects_match_binding_rows",
+				result.objectRows == binding.bindingRows,
+				"constructed object count must match M6s binding rows");
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "constructed_objects_have_live_graph_edges",
+				result.missingGraphEdgeRows == 0,
+				"every constructed object must have a live GraphEdge");
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "accounting_rows_match_constructed_objects",
+				result.objectAccountingRows == result.objectRows,
+				"accounting must cover every constructed object");
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "query_accounting_covers_objects",
+				result.queryAccountedRows == result.objectRows,
+				"query accounting rows must sum to constructed objects");
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "edge_accounting_covers_objects",
+				result.edgeAccountedRows == result.objectRows,
+				"edge accounting rows must sum to constructed objects");
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "query_edge_accounting_covers_objects",
+				result.queryEdgeAccountedRows == result.objectRows,
+				"query-edge accounting rows must sum to constructed objects");
+			addReadToGraphFullQueryHitObjectVectorSmokeCheck(
+				result, "graph_not_mutated_after_object_vector",
+				!result.graphMutationConsumedWorkerOutput,
+				"object-vector smoke must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitObjectVectorSmokeChecksPassed(result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"object-vector-smoke-audited-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"object-vector smoke accounting differs from bound rows";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitObjectVectorSmokeFailed(result);
+		}
+		return result;
+	}
+
+	void captureReadToGraphFullQueryHitObjectVectorSmokeResult(
+		ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
