+		dryRun.rawOverlapObjectVectorSmokeStatus = smoke.status;
+		dryRun.rawOverlapObjectVectorSmokeState = smoke.state;
+		dryRun.rawOverlapObjectVectorSmokeDecision = smoke.decision;
+		dryRun.rawOverlapObjectVectorSmokeEligible = smoke.eligible;
+		dryRun.rawOverlapObjectVectorSmokeFailedClosed = smoke.failedClosed;
+		dryRun.rawOverlapObjectVectorSmokeRows = smoke.objectRows;
+		dryRun.rawOverlapObjectVectorSmokeAccountingRows =
+			smoke.objectAccountingRows;
+		dryRun.rawOverlapObjectVectorSmokeQuerySummaryRows =
+			smoke.querySummaryRows;
+		dryRun.rawOverlapObjectVectorSmokeEdgeSummaryRows =
