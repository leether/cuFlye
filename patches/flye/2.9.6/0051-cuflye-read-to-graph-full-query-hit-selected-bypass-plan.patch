+	ReadToGraphFullQueryHitSelectedBypassPlanRow
+	readToGraphFullQueryHitSelectedBypassPlanRow(
+		size_t orderIndex,
+		const ReadToGraphRawOverlapRecord& record,
+		const std::string& decision,
+		const std::string& reason)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanRow row;
+		row.orderIndex = orderIndex;
+		row.queryId = record.queryId;
+		row.sourceOrder = record.sourceOrder;
+		row.edgeId = record.edgeId;
+		row.readId = record.overlap.curId.signedId();
+		row.edgeSeqId = record.overlap.extId.signedId();
+		row.decision = decision;
+		row.reason = reason;
+		return row;
+	}
+
+	void addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+		ReadToGraphFullQueryHitSelectedBypassPlanResult& plan,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		plan.checks.push_back(check);
+	}
+
+	bool allReadToGraphFullQueryHitSelectedBypassPlanChecksPassed(
+		const ReadToGraphFullQueryHitSelectedBypassPlanResult& plan)
+	{
+		for (const auto& check : plan.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !plan.checks.empty();
+	}
+
+	void markReadToGraphFullQueryHitSelectedBypassPlanFailed(
+		ReadToGraphFullQueryHitSelectedBypassPlanResult& plan)
+	{
+		plan.status = "failed";
+		plan.state = "failed-closed";
+		plan.decision = "failed-closed-before-graph-mutation";
+		plan.eligible = false;
+		plan.consumed = false;
+		plan.notConsumed = false;
+		plan.failedClosed = true;
+		plan.graphMutationConsumedWorkerOutput = false;
+	}
+
+	ReadToGraphFullQueryHitSelectedBypassPlanResult
+	evaluateReadToGraphFullQueryHitSelectedBypassPlan(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitVerifiedSubstitutionResult& substitution,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanResult result;
+		result.mode = readToGraphFullQueryHitSelectedBypassPlanMode();
+		result.proofFault =
+			readToGraphFullQueryHitSelectedBypassPlanProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.verifiedSubstitutionStatus = substitution.status;
+		result.verifiedSubstitutionLedgerRows =
+			substitution.substitutionLedgerRows;
+		result.selectedCpuHandoffRows = substitution.selectedCpuHandoffRows;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitSelectedBypassPlanEnabled())
+		{
+			return result;
+		}
+
+		markReadToGraphFullQueryHitSelectedBypassPlanFailed(result);
+		addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+			result, "explicit_selected_bypass_plan_mode",
+			result.mode == "selected-bypass-plan-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SELECTED_BYPASS_PLAN_MODE="
+			"selected-bypass-plan-v0");
+		addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+			result, "verified_substitution_passed",
+			substitution.status == "passed" && substitution.eligible &&
+				!substitution.failedClosed,
+			"M6v verified substitution must pass before selected bypass plan");
+		addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+			result, "verified_substitution_row_keys_matched",
+			substitution.rowKeyMatched && substitution.orderedRowKeyMatched,
+			"M6v ledger must match selected CPU handoff row keys and order");
+		addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapSelectedBypassPlanJson.empty(),
+			"selected bypass-plan audit JSON path must be available");
+		addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitSelectedBypassPlanChecksPassed(result))
+		{
+			result.error = "selected bypass-plan preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto allCpuRecords =
+				readToGraphOracleRawOverlapRecords(dryRun.queryIds);
+			auto selectedCpuRecords =
+				readToGraphSelectedCpuHandoffRecords(dryRun.queryIds);
+			result.totalCpuRawOverlapRows = allCpuRecords.size();
+			result.selectedCpuHandoffRows = selectedCpuRecords.size();
+			auto selectedCpuKeys =
+				readToGraphRawOverlapRecordRowKeys(selectedCpuRecords);
+
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				bypassObjects =
+					buildReadToGraphFullQueryHitLiveObjectVector(
+						result.workerTsv, graph, result.missingGraphEdgeRows);
+			if (result.proofFault == "drop-first-bypass-ledger-row" &&
+				!bypassObjects.empty())
+			{
+				bypassObjects.erase(bypassObjects.begin());
+				result.proofFaultApplied = true;
+			}
+			result.selectedBypassEligibleRows = bypassObjects.size();
+			result.selectedBypassLedgerRows = bypassObjects.size();
+
+			std::vector<ReadToGraphRawOverlapRecord> bypassRecords;
+			std::set<ReadToGraphRawOverlapRowKey> bypassKeys;
+			for (size_t index = 0; index < bypassObjects.size(); ++index)
+			{
+				const auto& object = bypassObjects[index];
+				const auto key =
+					readToGraphRawOverlapRecordToRowKey(object.record);
+				bypassKeys.insert(key);
+				bypassRecords.push_back(object.record);
+				++result.bypassQueryAccountedRows;
+				++result.bypassEdgeAccountedRows;
+				++result.bypassQueryEdgeAccountedRows;
+				result.bypassLedger.push_back(
+					readToGraphFullQueryHitSelectedBypassPlanRow(
+						index, object.record, "selected-bypass-eligible",
+						"verified-ledger-row"));
+			}
+			auto bypassRecordKeys =
+				readToGraphRawOverlapRecordRowKeys(bypassRecords);
+			result.bypassRowKeyDiff = compareReadToGraphRawOverlapRowKeys(
+				selectedCpuKeys, bypassRecordKeys);
+			result.bypassRowKeyMatched = result.bypassRowKeyDiff.matched;
+			result.bypassOrderedRowKeyMatched =
+				result.bypassRowKeyDiff.orderedMatched;
+
+			for (const auto& record : allCpuRecords)
+			{
+				const auto key = readToGraphRawOverlapRecordToRowKey(record);
+				if (bypassKeys.count(key) != 0) continue;
+
+				std::string reason = "not-selected-for-bypass";
+				if (record.edgeId == 0)
+				{
+					reason = "unsupported-unresolved-edge-id";
+					++result.cpuOwnedUnsupportedRows;
+				}
+				else if (record.passesChainInputFilter)
+				{
+					reason = "selected-bypass-ledger-missing";
+					++result.cpuOwnedMissingBypassRows;
+				}
+				else
+				{
+					++result.cpuOwnedNonSelectedRows;
+				}
+				result.cpuOwnedRows.push_back(
+					readToGraphFullQueryHitSelectedBypassPlanRow(
+						result.cpuOwnedRows.size(), record, "cpu-owned",
+						reason));
+			}
+			result.cpuOwnedResidualRows = result.cpuOwnedRows.size();
+
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "selected_bypass_rows_present",
+				result.selectedBypassEligibleRows > 0,
+				"selected bypass plan requires nonzero bypass-eligible rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "selected_bypass_count_matches_verified_substitution",
+				result.selectedBypassEligibleRows ==
+					substitution.substitutionLedgerRows,
+				"selected bypass count must match M6v substitution ledger rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "selected_bypass_ledger_matches_verified_substitution",
+				result.selectedBypassLedgerRows ==
+					substitution.substitutionLedgerRows,
+				"selected bypass ledger must match M6v ledger rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "selected_bypass_row_keys_match_cpu_handoff",
+				result.bypassRowKeyMatched,
+				"selected bypass row keys must match selected CPU handoff");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "selected_bypass_order_matches_cpu_handoff",
+				result.bypassOrderedRowKeyMatched,
+				"selected bypass row order must match selected CPU handoff");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "cpu_owned_residual_rows_recorded",
+				result.cpuOwnedResidualRows > 0 &&
+					result.cpuOwnedResidualRows == result.cpuOwnedRows.size(),
+				"CPU-owned residual rows must be explicitly recorded");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "bypass_and_cpu_owned_rows_account_for_input",
+				result.selectedBypassEligibleRows +
+					result.cpuOwnedResidualRows == result.totalCpuRawOverlapRows,
+				"bypass plus CPU-owned rows must account for all CPU raw-overlap rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "bypass_query_accounting_matches_ledger",
+				result.bypassQueryAccountedRows ==
+					result.selectedBypassLedgerRows,
+				"bypass query accounting must match bypass ledger rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "bypass_edge_accounting_matches_ledger",
+				result.bypassEdgeAccountedRows ==
+					result.selectedBypassLedgerRows,
+				"bypass edge accounting must match bypass ledger rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "bypass_query_edge_accounting_matches_ledger",
+				result.bypassQueryEdgeAccountedRows ==
+					result.selectedBypassLedgerRows,
+				"bypass query-edge accounting must match bypass ledger rows");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "bypass_objects_have_live_graph_edges",
+				result.missingGraphEdgeRows == 0,
+				"every selected bypass object must have a live GraphEdge");
+			addReadToGraphFullQueryHitSelectedBypassPlanCheck(
+				result, "graph_not_mutated_after_selected_bypass_plan",
+				!result.graphMutationConsumedWorkerOutput,
+				"selected bypass plan must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitSelectedBypassPlanChecksPassed(
+					result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"selected-bypass-plan-written-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"selected bypass plan differs from verified substitution ledger";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitSelectedBypassPlanFailed(result);
+		}
+		return result;
+	}
+
+	void captureReadToGraphFullQueryHitSelectedBypassPlanResult(
