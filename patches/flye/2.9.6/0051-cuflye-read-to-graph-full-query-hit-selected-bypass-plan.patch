+	void writeReadToGraphFullQueryHitSelectedBypassPlanRowsJson(
+		std::ostringstream& json,
+		const std::vector<ReadToGraphFullQueryHitSelectedBypassPlanRow>& rows)
+	{
+		for (size_t index = 0; index < rows.size(); ++index)
+		{
+			const auto& row = rows[index];
+			json << "    {\n"
+				 << "      \"order_index\": " << row.orderIndex << ",\n"
+				 << "      \"query_id\": " << row.queryId << ",\n"
+				 << "      \"source_order\": " << row.sourceOrder << ",\n"
+				 << "      \"edge_id\": " << row.edgeId << ",\n"
+				 << "      \"read_id\": " << row.readId << ",\n"
+				 << "      \"edge_seq_id\": " << row.edgeSeqId << ",\n"
+				 << "      \"decision\": \""
+				 << readAlignmentJsonEscape(row.decision) << "\",\n"
+				 << "      \"reason\": \""
+				 << readAlignmentJsonEscape(row.reason) << "\"\n"
+				 << "    }" << (index + 1 == rows.size() ? "\n" : ",\n");
+		}
+	}
