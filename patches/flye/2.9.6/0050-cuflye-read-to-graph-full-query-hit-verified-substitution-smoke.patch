+	void addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+		ReadToGraphFullQueryHitVerifiedSubstitutionResult& substitution,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitVerifiedSubstitutionCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		substitution.checks.push_back(check);
+	}
+
+	bool allReadToGraphFullQueryHitVerifiedSubstitutionChecksPassed(
+		const ReadToGraphFullQueryHitVerifiedSubstitutionResult& substitution)
+	{
+		for (const auto& check : substitution.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !substitution.checks.empty();
+	}
+
+	void markReadToGraphFullQueryHitVerifiedSubstitutionFailed(
+		ReadToGraphFullQueryHitVerifiedSubstitutionResult& substitution)
+	{
+		substitution.status = "failed";
+		substitution.state = "failed-closed";
+		substitution.decision = "failed-closed-before-graph-mutation";
+		substitution.eligible = false;
+		substitution.consumed = false;
+		substitution.notConsumed = false;
+		substitution.failedClosed = true;
+		substitution.graphMutationConsumedWorkerOutput = false;
+	}
+
+	ReadToGraphFullQueryHitVerifiedSubstitutionResult
+	evaluateReadToGraphFullQueryHitVerifiedSubstitution(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitSubstitutionGuardResult& guard,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitVerifiedSubstitutionResult result;
+		result.mode = readToGraphFullQueryHitVerifiedSubstitutionMode();
+		result.proofFault =
+			readToGraphFullQueryHitVerifiedSubstitutionProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.substitutionGuardStatus = guard.status;
+		result.guardHandoffRows = guard.handoffRows;
+		result.guardHandoffAccountingRows = guard.handoffAccountingRows;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitVerifiedSubstitutionEnabled())
+		{
+			return result;
+		}
+
+		markReadToGraphFullQueryHitVerifiedSubstitutionFailed(result);
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "explicit_verified_substitution_mode",
+			result.mode == "verified-substitution-smoke-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_VERIFIED_SUBSTITUTION_MODE="
+			"verified-substitution-smoke-v0");
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "substitution_guard_passed",
+			guard.status == "passed" && guard.eligible &&
+				!guard.failedClosed,
+			"M6u substitution guard must pass before verified substitution");
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "guard_handoff_rows_present",
+			guard.handoffRows > 0,
+			"verified substitution requires nonzero guarded handoff rows");
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "worker_row_key_gate_passed",
+			dryRun.rowKeyMatched,
+			"worker raw-overlap row keys must match CPU oracle first");
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapVerifiedSubstitutionJson.empty(),
+			"verified substitution audit JSON path must be available");
+		addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitVerifiedSubstitutionChecksPassed(result))
+		{
+			result.error = "verified substitution preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto selectedCpuRecords =
+				readToGraphSelectedCpuHandoffRecords(dryRun.queryIds);
+			result.selectedCpuHandoffRows = selectedCpuRecords.size();
+			auto selectedCpuKeys =
+				readToGraphRawOverlapRecordRowKeys(selectedCpuRecords);
+
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				wouldSubstituteObjects =
+					buildReadToGraphFullQueryHitLiveObjectVector(
+						result.workerTsv, graph, result.missingGraphEdgeRows);
+			if (result.proofFault == "drop-first-substitution-ledger-row" &&
+				!wouldSubstituteObjects.empty())
+			{
+				wouldSubstituteObjects.erase(wouldSubstituteObjects.begin());
+				result.proofFaultApplied = true;
+			}
+			result.wouldSubstituteRows = wouldSubstituteObjects.size();
+			result.substitutionLedgerRows = wouldSubstituteObjects.size();
+
+			std::vector<ReadToGraphRawOverlapRecord> substitutionRecords;
+			for (size_t index = 0; index < wouldSubstituteObjects.size();
+				 ++index)
+			{
+				const auto& object = wouldSubstituteObjects[index];
+				const int64_t queryId = object.record.queryId;
+				const int64_t edgeId = object.record.edgeId;
+				++result.substitutionQueryAccountedRows;
+				++result.substitutionEdgeAccountedRows;
+				++result.substitutionQueryEdgeAccountedRows;
+				substitutionRecords.push_back(object.record);
+
+				ReadToGraphFullQueryHitVerifiedSubstitutionLedgerEntry entry;
+				entry.orderIndex = index;
+				entry.queryId = queryId;
+				entry.sourceOrder = object.record.sourceOrder;
+				entry.edgeId = edgeId;
+				entry.readId = object.record.overlap.curId.signedId();
+				entry.edgeSeqId = object.record.overlap.extId.signedId();
+				result.ledger.push_back(entry);
+			}
+
+			auto substitutionKeys =
+				readToGraphRawOverlapRecordRowKeys(substitutionRecords);
+			result.rowKeyDiff = compareReadToGraphRawOverlapRowKeys(
+				selectedCpuKeys, substitutionKeys);
+			result.rowKeyMatched = result.rowKeyDiff.matched;
+			result.orderedRowKeyMatched = result.rowKeyDiff.orderedMatched;
+
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "selected_cpu_handoff_rows_present",
+				result.selectedCpuHandoffRows > 0,
+				"CPU oracle selected handoff shape must be nonzero");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "would_substitute_count_matches_guard_handoff",
+				result.wouldSubstituteRows == guard.handoffRows,
+				"would-substitute rows must match M6u guarded handoff rows");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_ledger_count_matches_guard_accounting",
+				result.substitutionLedgerRows == guard.handoffAccountingRows,
+				"substitution ledger rows must match M6u handoff accounting");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_query_accounting_matches_guard",
+				result.substitutionQueryAccountedRows ==
+					guard.handoffQueryAccountedRows,
+				"substitution query accounting must match M6u handoff accounting");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_edge_accounting_matches_guard",
+				result.substitutionEdgeAccountedRows ==
+					guard.handoffEdgeAccountedRows,
+				"substitution edge accounting must match M6u handoff accounting");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_query_edge_accounting_matches_guard",
+				result.substitutionQueryEdgeAccountedRows ==
+					guard.handoffQueryEdgeAccountedRows,
+				"substitution query-edge accounting must match M6u handoff accounting");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_row_keys_match_cpu_handoff",
+				result.rowKeyMatched,
+				"would-substitute row keys must match selected CPU handoff");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_row_order_matches_cpu_handoff",
+				result.orderedRowKeyMatched,
+				"would-substitute row order must match selected CPU handoff");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "substitution_ledger_order_recorded",
+				result.ledger.size() == result.substitutionLedgerRows,
+				"substitution ledger must record deterministic row order");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "would_substitute_objects_have_live_graph_edges",
+				result.missingGraphEdgeRows == 0,
+				"every would-substitute object must have a live GraphEdge");
+			addReadToGraphFullQueryHitVerifiedSubstitutionCheck(
+				result, "graph_not_mutated_after_verified_substitution",
+				!result.graphMutationConsumedWorkerOutput,
+				"verified substitution smoke must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitVerifiedSubstitutionChecksPassed(
+					result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"verified-substitution-ledger-written-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"verified substitution ledger differs from CPU handoff";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitVerifiedSubstitutionFailed(result);
+		}
+		return result;
+	}
