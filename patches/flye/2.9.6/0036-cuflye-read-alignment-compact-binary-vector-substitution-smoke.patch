+	std::string readAlignmentCompactBinaryVectorSubstitutionMode()
+	{
+		static std::string mode = []()
+		{
+			const char* raw = std::getenv(
+				"CUFLYE_READ_ALIGNMENT_COMPACT_BINARY_VECTOR_SUBSTITUTION_MODE");
+			if (!raw || !raw[0]) return std::string();
+			std::string selected(raw);
+			if (selected != "verified-goodchains-v0")
+			{
+				throw std::runtime_error(
+					"Unsupported "
+					"CUFLYE_READ_ALIGNMENT_COMPACT_BINARY_VECTOR_SUBSTITUTION_MODE: " +
+					selected);
+			}
+			return selected;
+		}();
+		return mode;
+	}
