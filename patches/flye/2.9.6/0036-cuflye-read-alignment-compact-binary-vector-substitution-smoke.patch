+	void substituteReadAlignmentPreDivergenceBatchGoodChains(
+		ReadAlignmentPreDivergenceBatchDryRunResult& result,
+		std::vector<GraphAlignment>& alignments)
+	{
+		result.vectorSubstitutionMode =
+			readAlignmentCompactBinaryVectorSubstitutionMode();
+		if (!readAlignmentCompactBinaryVectorSubstitutionEnabled())
+		{
+			result.vectorSubstitutionStatus = "disabled";
+			return;
+		}
+
+		result.vectorSubstitutionAttempted = true;
+		result.vectorSubstitutionStatus = "failed";
+		if (!readAlignmentCompactBinaryEnabled())
+		{
+			throw std::runtime_error(
+				"compact binary vector substitution requires compact binary "
+				"rehydration");
+		}
+		if (!result.matched)
+		{
+			throw std::runtime_error(
+				"compact binary vector substitution requires all selected "
+				"GPU goodChains to match CPU goodChains");
+		}
+
+		std::vector<ReadAlignmentQueryReplacement> replacements;
+		replacements.reserve(result.fixtures.size());
+		for (auto& fixture : result.fixtures)
+		{
+			fixture.vectorSubstitutionStatus = "pending";
+			if (!fixture.matched)
+			{
+				throw std::runtime_error(
+					"compact binary vector substitution found unmatched fixture " +
+					std::to_string(fixture.queryId));
+			}
+			ReadAlignmentQueryReplacement replacement;
+			replacement.queryId = fixture.queryId;
+			replacement.chains = fixture.gpuGoodChainsObject;
+			replacements.push_back(replacement);
+		}
+
+		std::vector<GraphAlignment> substitutedAlignments(alignments);
+		std::vector<size_t> replacementOffsets(replacements.size(), 0);
+		size_t substitutedChains = 0;
+		for (auto& chain : substitutedAlignments)
+		{
+			if (chain.empty()) continue;
+			int64_t queryId = chain.front().overlap.curId.signedId();
+			for (size_t index = 0; index < replacements.size(); ++index)
+			{
+				if (replacements[index].queryId != queryId) continue;
+				size_t& offset = replacementOffsets[index];
+				if (offset >= replacements[index].chains.size())
+				{
+					throw std::runtime_error(
+						"compact binary vector substitution replacement count "
+						"mismatch for query " + std::to_string(queryId));
+				}
+				chain = replacements[index].chains[offset];
+				++offset;
+				++substitutedChains;
+				break;
+			}
+		}
+		for (size_t index = 0; index < replacements.size(); ++index)
+		{
+			if (replacementOffsets[index] != replacements[index].chains.size())
+			{
+				throw std::runtime_error(
+					"compact binary vector substitution did not find every CPU "
+					"chain for query " +
+					std::to_string(replacements[index].queryId));
+			}
+		}
+		for (auto& fixture : result.fixtures)
+		{
+			for (const auto& replacement : replacements)
+			{
+				if (replacement.queryId == fixture.queryId)
+				{
+					fixture.substitutedChains = replacement.chains.size();
+					fixture.vectorSubstitutionStatus = "consumed";
+					fixture.vectorSubstitutionConsumed = true;
+				}
+			}
+		}
+
+		alignments.swap(substitutedAlignments);
+		result.totalSubstitutedChains = substitutedChains;
+		result.vectorSubstitutionStatus = "consumed";
+		result.vectorSubstitutionConsumed = true;
+		result.graphMutationConsumedWorkerOutput = true;
+		result.decision = "compact-binary-verified-goodchains-substituted";
+	}
