+
+	std::mutex& candidateDumpMutex()
+	{
+		static std::mutex dumpMutex;
+		return dumpMutex;
+	}
+
+	const char* candidateDumpPath()
+	{
+		static const char* dumpPath = std::getenv("CUFLYE_CANDIDATE_DUMP");
+		return dumpPath;
+	}
+
+	template <class Matches>
+	void dumpCandidateMatches(const FastaRecord& fastaRec, const Matches& matches)
+	{
+		const char* dumpPath = candidateDumpPath();
+		if (!dumpPath || !dumpPath[0]) return;
+
+		std::lock_guard<std::mutex> lock(candidateDumpMutex());
+		std::ofstream fout(dumpPath, std::ios::out | std::ios::app);
+		if (!fout)
+		{
+			throw std::runtime_error("Can't open CUFLYE_CANDIDATE_DUMP path");
+		}
+
+		for (const auto& match : matches)
+		{
+			fout << fastaRec.id.signedId() << "\t"
+				 << match.curPos << "\t"
+				 << match.kmerRepr << "\t"
+				 << match.extId.signedId() << "\t"
+				 << match.extPos << "\t"
+				 << (match.extId.strand() ? "+" : "-") << "\n";
+		}
+	}
 }
 
