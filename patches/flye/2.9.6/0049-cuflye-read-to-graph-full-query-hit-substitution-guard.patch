+	void addReadToGraphFullQueryHitSubstitutionGuardCheck(
+		ReadToGraphFullQueryHitSubstitutionGuardResult& guard,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitSubstitutionGuardCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		guard.checks.push_back(check);
+	}
+
+	bool allReadToGraphFullQueryHitSubstitutionGuardChecksPassed(
+		const ReadToGraphFullQueryHitSubstitutionGuardResult& guard)
+	{
+		for (const auto& check : guard.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !guard.checks.empty();
+	}
+
+	void markReadToGraphFullQueryHitSubstitutionGuardFailed(
+		ReadToGraphFullQueryHitSubstitutionGuardResult& guard)
+	{
+		guard.status = "failed";
+		guard.state = "failed-closed";
+		guard.decision = "failed-closed-before-graph-mutation";
+		guard.eligible = false;
+		guard.consumed = false;
+		guard.notConsumed = false;
+		guard.failedClosed = true;
+		guard.graphMutationConsumedWorkerOutput = false;
+	}
+
+	ReadToGraphFullQueryHitSubstitutionGuardResult
+	evaluateReadToGraphFullQueryHitSubstitutionGuard(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitObjectVectorSmokeResult& smoke,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitSubstitutionGuardResult result;
+		result.mode = readToGraphFullQueryHitSubstitutionGuardMode();
+		result.proofFault =
+			readToGraphFullQueryHitSubstitutionGuardProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.objectVectorSmokeStatus = smoke.status;
+		result.objectVectorRows = smoke.objectRows;
+		result.objectVectorAccountingRows = smoke.objectAccountingRows;
+		result.objectVectorQueryAccountedRows = smoke.queryAccountedRows;
+		result.objectVectorEdgeAccountedRows = smoke.edgeAccountedRows;
+		result.objectVectorQueryEdgeAccountedRows =
+			smoke.queryEdgeAccountedRows;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitSubstitutionGuardEnabled()) return result;
+
+		markReadToGraphFullQueryHitSubstitutionGuardFailed(result);
+		addReadToGraphFullQueryHitSubstitutionGuardCheck(
+			result, "explicit_substitution_guard_mode",
+			result.mode == "substitution-guard-dry-run-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SUBSTITUTION_GUARD_MODE="
+			"substitution-guard-dry-run-v0");
+		addReadToGraphFullQueryHitSubstitutionGuardCheck(
+			result, "object_vector_smoke_passed",
+			smoke.status == "passed" && smoke.eligible &&
+				!smoke.failedClosed,
+			"M6t object-vector smoke must pass before substitution guard");
+		addReadToGraphFullQueryHitSubstitutionGuardCheck(
+			result, "object_vector_rows_present",
+			smoke.objectRows > 0,
+			"substitution guard requires nonzero object-vector rows");
+		addReadToGraphFullQueryHitSubstitutionGuardCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitSubstitutionGuardCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapSubstitutionGuardJson.empty(),
+			"substitution guard audit JSON path must be available");
+		addReadToGraphFullQueryHitSubstitutionGuardCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitSubstitutionGuardChecksPassed(result))
+		{
+			result.error = "substitution guard preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				handoffObjects = buildReadToGraphFullQueryHitLiveObjectVector(
+					result.workerTsv, graph, result.missingGraphEdgeRows);
+			if (result.proofFault == "drop-first-handoff-row" &&
+				!handoffObjects.empty())
+			{
+				handoffObjects.erase(handoffObjects.begin());
+				result.proofFaultApplied = true;
+			}
+			result.handoffRows = handoffObjects.size();
+			result.handoffAccountingRows = handoffObjects.size();
+
+			for (size_t index = 0; index < handoffObjects.size(); ++index)
+			{
+				const auto& object = handoffObjects[index];
+				const int64_t queryId = object.record.queryId;
+				const int64_t edgeId = object.record.edgeId;
+				++result.handoffQueryAccountedRows;
+				++result.handoffEdgeAccountedRows;
+				++result.handoffQueryEdgeAccountedRows;
+
+				ReadToGraphFullQueryHitSubstitutionGuardObjectSummary
+					summary;
+				summary.orderIndex = index;
+				summary.queryId = queryId;
+				summary.sourceOrder = object.record.sourceOrder;
+				summary.edgeId = edgeId;
+				summary.readId = object.record.overlap.curId.signedId();
+				summary.edgeSeqId = object.record.overlap.extId.signedId();
+				result.objects.push_back(summary);
+			}
+			result.handoffObjectSummaryRows = result.objects.size();
+
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_count_matches_object_vector",
+				result.handoffRows == smoke.objectRows,
+				"guard handoff rows must match M6t object-vector rows");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_accounting_matches_object_vector",
+				result.handoffAccountingRows == smoke.objectAccountingRows,
+				"guard handoff accounting must match M6t object accounting");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_query_accounting_matches_object_vector",
+				result.handoffQueryAccountedRows == smoke.queryAccountedRows,
+				"guard query accounting must match M6t query accounting");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_edge_accounting_matches_object_vector",
+				result.handoffEdgeAccountedRows == smoke.edgeAccountedRows,
+				"guard edge accounting must match M6t edge accounting");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_query_edge_accounting_matches_object_vector",
+				result.handoffQueryEdgeAccountedRows ==
+					smoke.queryEdgeAccountedRows,
+				"guard query-edge accounting must match M6t query-edge accounting");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_order_recorded",
+				result.handoffObjectSummaryRows == result.handoffRows,
+				"guard must record deterministic handoff object order");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "handoff_objects_have_live_graph_edges",
+				result.missingGraphEdgeRows == 0,
+				"every guarded object must have a live GraphEdge");
+			addReadToGraphFullQueryHitSubstitutionGuardCheck(
+				result, "graph_not_mutated_after_substitution_guard",
+				!result.graphMutationConsumedWorkerOutput,
+				"substitution guard must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitSubstitutionGuardChecksPassed(result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"substitution-guard-audited-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"substitution guard handoff differs from object vector";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitSubstitutionGuardFailed(result);
+		}
+		return result;
+	}
