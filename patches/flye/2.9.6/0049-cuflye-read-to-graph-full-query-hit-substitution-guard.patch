+	std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+	buildReadToGraphFullQueryHitLiveObjectVector(
+		const std::string& workerTsv,
+		RepeatGraph& graph,
+		size_t& missingGraphEdgeRows)
+	{
+		auto records = readToGraphRawOverlapRecords(workerTsv);
+		std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject> objects;
+		for (const auto& record : records)
+		{
+			if (!record.passesChainInputFilter) continue;
+			if (record.edgeId == 0)
+			{
+				++missingGraphEdgeRows;
+				continue;
+			}
+			FastaRecord::Id edgeId = checkedReadAlignmentFastaIdFromSigned(
+				record.edgeId, "edge_id", workerTsv);
+			GraphEdge* edge = graph.getEdge(edgeId);
+			if (!edge)
+			{
+				++missingGraphEdgeRows;
+				continue;
+			}
+			ReadToGraphFullQueryHitObjectVectorSmokeObject object;
+			object.record = record;
+			object.edge = edge;
+			objects.push_back(object);
+		}
+		return objects;
+	}
