+	void dumpOverlapRanges(const std::vector<OverlapRange>& overlaps)
+	{
+		const char* dumpPath = overlapDumpPath();
+		if (!dumpPath || !dumpPath[0]) return;
+
+		std::lock_guard<std::mutex> lock(overlapDumpMutex());
+		std::ofstream fout(dumpPath, std::ios::out | std::ios::app);
+		if (!fout)
+		{
+			throw std::runtime_error("Can't open CUFLYE_OVERLAP_DUMP path");
+		}
+
+		fout << std::setprecision(9);
+		for (const auto& ovlp : overlaps)
+		{
+			fout << ovlp.curId.signedId() << "\t"
+				 << ovlp.curBegin << "\t"
+				 << ovlp.curEnd << "\t"
+				 << ovlp.curLen << "\t"
+				 << ovlp.extId.signedId() << "\t"
+				 << ovlp.extBegin << "\t"
+				 << ovlp.extEnd << "\t"
+				 << ovlp.extLen << "\t"
+				 << ovlp.score << "\t"
+				 << ovlp.seqDivergence << "\n";
+		}
+	}
