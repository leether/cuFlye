+		std::string readToGraphFullQueryHitWorkerSafeFileStem(
+			const std::string& path)
+		{
+			std::vector<std::string> components;
+			size_t end = path.size();
+			while (end > 0)
+			{
+				while (end > 0 && path[end - 1] == '/') --end;
+				if (end == 0) break;
+				size_t begin = path.find_last_of('/', end - 1);
+				size_t componentBegin =
+					begin == std::string::npos ? 0 : begin + 1;
+				components.push_back(path.substr(componentBegin,
+												  end - componentBegin));
+				if (begin == std::string::npos) break;
+				end = begin;
+				if (components.size() == 3) break;
+			}
+			std::string stem;
+			for (auto component = components.rbegin();
+				 component != components.rend(); ++component)
+			{
+				if (!stem.empty()) stem.push_back('_');
+				for (char rawCh : *component)
+				{
+					unsigned char ch = static_cast<unsigned char>(rawCh);
+					if (std::isalnum(ch) || rawCh == '-' || rawCh == '_' ||
+						rawCh == '.')
+					{
+						stem.push_back(rawCh);
+					}
+					else
+					{
+						stem.push_back('_');
+					}
+				}
+			}
+			if (stem.empty()) return "actual";
+			return stem;
+		}
