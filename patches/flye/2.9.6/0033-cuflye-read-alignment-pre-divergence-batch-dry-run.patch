+	void prepareReadAlignmentPreDivergenceBatchDryRun(
+		const std::vector<ReadAlignmentPreDivergenceBatchFixture>& fixtures,
+		ReadAlignmentPreDivergenceBatchDryRunResult& result)
+	{
+		if (fixtures.empty())
+		{
+			throw std::runtime_error(
+				"cuFlye read alignment pre-divergence batch dry-run has no "
+				"selected replay fixtures");
+		}
+		result.mode = readAlignmentPreDivergenceChainMode();
+		result.proofFault = readAlignmentPreDivergenceChainProofFault();
+		result.status = "failed";
+		result.decision = "failed-closed-before-graph-mutation";
+		result.failedClosed = true;
+		result.graphMutationConsumedWorkerOutput = false;
+		result.attempted = true;
+		result.workerOutputRoot = joinReplayPath(
+			std::string(readAlignmentReplayDumpDir()),
+			"predivergence-batch-worker");
+		result.batchOutputDir =
+			joinReplayPath(result.workerOutputRoot, "read-alignment-output");
+		result.fixtureList =
+			joinReplayPath(result.workerOutputRoot, "read-alignment-fixtures.list");
+		result.batchJson =
+			joinReplayPath(result.workerOutputRoot,
+						   "read-alignment-worker-batch.json");
+		result.stdoutLog =
+			joinReplayPath(result.workerOutputRoot,
+						   "read-alignment-worker-stdout.log");
+		result.stderrLog =
+			joinReplayPath(result.workerOutputRoot,
+						   "read-alignment-worker-stderr.log");
+		result.auditJson = joinReplayPath(
+			result.workerOutputRoot,
+			"read-alignment-predivergence-batch-dry-run.json");
+
+		ensureReplayDirectory(std::string(readAlignmentReplayDumpDir()));
+		ensureReplayDirectory(result.workerOutputRoot);
+		ensureReplayDirectory(result.batchOutputDir);
+
+		result.fixtures = fixtures;
+		result.fixtureCount = result.fixtures.size();
+		for (auto& fixture : result.fixtures)
+		{
+			fixture.workerTsv = joinReplayPath(
+				joinReplayPath(result.batchOutputDir,
+							   replayQueryDirName(fixture.queryId)),
+				"read-alignment.tsv");
+			fixture.status = "pending";
+			result.totalCpuPreDivergenceChains +=
+				fixture.cpuPreDivergenceChains;
+			result.totalCpuGoodChains += fixture.cpuGoodChains;
+			result.totalCpuGoodRecords += fixture.cpuGoodRecords;
+		}
+	}
+
+	void runReadAlignmentPreDivergenceBatchWorker(
+		ReadAlignmentPreDivergenceBatchDryRunResult& result)
+	{
+		std::vector<int64_t> queryIds;
+		queryIds.reserve(result.fixtures.size());
+		for (const auto& fixture : result.fixtures)
+		{
+			queryIds.push_back(fixture.queryId);
+		}
+		writeReadAlignmentFixtureList(result.fixtureList, queryIds);
+
+		std::string workerBin =
+			readAlignmentRequiredEnv("CUFLYE_READ_ALIGNMENT_WORKER_BIN");
+		result.workerCommand = readAlignmentShellQuote(workerBin) +
+			" --backend cuda --device " +
+			readAlignmentShellQuote(
+				readAlignmentOptionalEnv("CUFLYE_READ_ALIGNMENT_WORKER_DEVICE",
+										 "0")) +
+			" --batch-fixtures-file " + readAlignmentShellQuote(result.fixtureList) +
+			" --batch-output-dir " + readAlignmentShellQuote(result.batchOutputDir) +
+			" --batch-json-output " + readAlignmentShellQuote(result.batchJson) +
+			" --allow-heterogeneous-batch --emit-pre-divergence-chains "
+			"--warmup-runs " +
+			readAlignmentShellQuote(readAlignmentOptionalEnv(
+				"CUFLYE_READ_ALIGNMENT_WORKER_WARMUP_RUNS", "0")) +
+			" --benchmark-runs " +
+			readAlignmentShellQuote(readAlignmentOptionalEnv(
+				"CUFLYE_READ_ALIGNMENT_WORKER_BENCHMARK_RUNS", "1"));
+		std::string memoryBudget = readAlignmentOptionalEnv(
+			"CUFLYE_READ_ALIGNMENT_WORKER_MEMORY_BUDGET_BYTES", "");
+		if (!memoryBudget.empty())
+		{
+			result.workerCommand += " --memory-budget-bytes " +
+									readAlignmentShellQuote(memoryBudget);
+		}
+		result.workerCommand += " > " +
+								readAlignmentShellQuote(result.stdoutLog) +
+								" 2> " +
+								readAlignmentShellQuote(result.stderrLog);
+		auto workerStart = std::chrono::steady_clock::now();
+		result.workerExitStatus = std::system(result.workerCommand.c_str());
+		auto workerEnd = std::chrono::steady_clock::now();
+		result.workerWallMs = readAlignmentElapsedMs(workerStart, workerEnd);
+		if (result.workerExitStatus != 0)
+		{
+			throw std::runtime_error(
+				"CUDA read-alignment pre-divergence batch worker failed with "
+				"status " + std::to_string(result.workerExitStatus));
+		}
+	}
