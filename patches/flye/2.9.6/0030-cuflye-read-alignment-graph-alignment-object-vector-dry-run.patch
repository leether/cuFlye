+	std::vector<ReadAlignmentDumpRecord>
+	canonicalReadAlignmentRecordsFromGraphAlignments(
+		const std::vector<GraphAlignment>& alignments)
+	{
+		std::vector<ReadAlignmentDumpRecord> records;
+		for (size_t chainId = 0; chainId < alignments.size(); ++chainId)
+		{
+			const auto& chain = alignments[chainId];
+			for (size_t segmentId = 0; segmentId < chain.size(); ++segmentId)
+			{
+				ReadAlignmentTypedSegment typed;
+				typed.chainId = static_cast<int64_t>(chainId);
+				typed.segmentId = static_cast<int64_t>(segmentId);
+				typed.alignment = chain[segmentId];
+				records.push_back(readAlignmentTypedSegmentToDumpRecord(typed));
+			}
+		}
+		std::sort(records.begin(), records.end());
+		return records;
+	}
+
+	std::vector<GraphAlignment> rehydrateGraphAlignmentObjectVector(
+		const std::vector<ReadAlignmentTypedSegment>& typedRecords,
+		const std::string& path)
+	{
+		std::vector<GraphAlignment> alignments;
+		int64_t currentChain = -1;
+		int64_t expectedSegment = 0;
+		for (const auto& typed : typedRecords)
+		{
+			if (typed.chainId != currentChain)
+			{
+				currentChain = typed.chainId;
+				expectedSegment = 0;
+				alignments.emplace_back();
+			}
+			if (typed.segmentId != expectedSegment)
+			{
+				throw std::runtime_error(path + ": non-contiguous segment_id in "
+										 "GraphAlignment object-vector");
+			}
+			alignments.back().push_back(typed.alignment);
+			++expectedSegment;
+		}
+		return alignments;
+	}
+
+	std::vector<GraphAlignment> readAlignmentCpuSliceForQuery(
+		const std::vector<GraphAlignment>& alignments,
+		int64_t queryId)
+	{
+		std::vector<GraphAlignment> slice;
+		for (const auto& chain : alignments)
+		{
+			if (chain.empty()) continue;
+			if (chain.front().overlap.curId.signedId() == queryId)
+			{
+				slice.push_back(chain);
+			}
+		}
+		return slice;
+	}
