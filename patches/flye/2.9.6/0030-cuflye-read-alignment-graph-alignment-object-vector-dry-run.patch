+	void addReadAlignmentObjectRehydrationCheck(
+		ReadAlignmentObjectRehydrationResult& objectRehydration,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadAlignmentObjectRehydrationCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		objectRehydration.checks.push_back(check);
+	}
+
+	bool allReadAlignmentObjectRehydrationChecksPassed(
+		const ReadAlignmentObjectRehydrationResult& objectRehydration)
+	{
+		for (const auto& check : objectRehydration.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !objectRehydration.checks.empty();
+	}
+
+	void markReadAlignmentObjectRehydrationFailed(
+		ReadAlignmentObjectRehydrationResult& objectRehydration)
+	{
+		objectRehydration.status = "failed";
+		objectRehydration.state = "failed-closed";
+		objectRehydration.decision = "failed-closed-before-graph-mutation";
+		objectRehydration.eligible = false;
+		objectRehydration.consumed = false;
+		objectRehydration.notConsumed = false;
+		objectRehydration.failedClosed = true;
+	}
+
+	ReadAlignmentObjectRehydrationResult
+	evaluateReadAlignmentObjectRehydration(
+		const std::vector<int64_t>& queryIds,
+		const std::string& batchOutputDir,
+		const ReadAlignmentRehydrationResult& rehydration,
+		const std::string& objectJson,
+		RepeatGraph& graph,
+		const std::vector<GraphAlignment>& cpuAlignments)
+	{
+		ReadAlignmentObjectRehydrationResult result;
+		result.mode = readAlignmentObjectRehydrationMode();
+		result.proofFault = readAlignmentObjectRehydrationProofFault();
+		if (!readAlignmentObjectRehydrationEnabled()) return result;
+
+		markReadAlignmentObjectRehydrationFailed(result);
+		addReadAlignmentObjectRehydrationCheck(
+			result, "explicit_object_rehydration_mode",
+			result.mode == "graph-alignment-object-vector-v0",
+			"CUFLYE_READ_ALIGNMENT_OBJECT_REHYDRATION_MODE="
+			"graph-alignment-object-vector-v0");
+		addReadAlignmentObjectRehydrationCheck(
+			result, "typed_rehydration_passed",
+			rehydration.status == "passed" && rehydration.eligible,
+			"M5k typed read-alignment rehydration must pass");
+		addReadAlignmentObjectRehydrationCheck(
+			result, "fixture_count_nonzero", !queryIds.empty(),
+			"at least one replay fixture must be selected");
+		addReadAlignmentObjectRehydrationCheck(
+			result, "audit_metadata_available", !objectJson.empty(),
+			"object-vector rehydration audit JSON path must be available");
+
+		if (!allReadAlignmentObjectRehydrationChecksPassed(result)) return result;
+
+		result.status = "passed";
+		result.state = "not-consumed";
+		result.decision = "graph-alignment-object-vector-match-not-consumed";
+		result.eligible = true;
+		result.notConsumed = true;
+		result.failedClosed = false;
+
+		for (int64_t queryId : queryIds)
+		{
+			ReadAlignmentFixtureObjectRehydration fixture;
+			fixture.queryId = queryId;
+			fixture.fixtureDir = readAlignmentFixtureDirForQuery(queryId);
+			fixture.workerTsv = joinReplayPath(
+				joinReplayPath(batchOutputDir, replayQueryDirName(queryId)),
+				"read-alignment.tsv");
+			try
+			{
+				auto workerRecords = readAlignmentDumpRecords(fixture.workerTsv);
+				fixture.workerRecords = workerRecords.size();
+				auto typedRecords =
+					rehydrateTypedReadAlignmentRecords(workerRecords, graph,
+													   fixture.workerTsv);
+				fixture.typedRecords = typedRecords.size();
+				auto objectVector =
+					rehydrateGraphAlignmentObjectVector(typedRecords,
+														fixture.workerTsv);
+				if (result.proofFault == "drop-first-graph-alignment-chain" &&
+					!objectVector.empty())
+				{
+					objectVector.erase(objectVector.begin());
+					fixture.proofFaultApplied = true;
+				}
+				fixture.objectChains = objectVector.size();
+				auto objectRecords =
+					canonicalReadAlignmentRecordsFromGraphAlignments(objectVector);
+				fixture.objectRecords = objectRecords.size();
+
+				auto cpuSlice =
+					readAlignmentCpuSliceForQuery(cpuAlignments, queryId);
+				fixture.cpuChains = cpuSlice.size();
+				auto cpuRecords =
+					canonicalReadAlignmentRecordsFromGraphAlignments(cpuSlice);
+				fixture.cpuRecords = cpuRecords.size();
+
+				if (cpuRecords == objectRecords)
+				{
+					fixture.status = "passed";
+					fixture.objectVectorStatus = "match";
+					result.totalObjectRecords += fixture.objectRecords;
+					result.totalObjectChains += fixture.objectChains;
+				}
+				else
+				{
+					fixture.status = "failed";
+					fixture.objectVectorStatus = "mismatch";
+					fixture.error =
+						"rehydrated GraphAlignment object-vector differs from "
+						"CPU _readAlignments slice";
+					markReadAlignmentObjectRehydrationFailed(result);
+				}
+			}
+			catch (const std::exception& exc)
+			{
+				fixture.status = "failed";
+				fixture.error = exc.what();
+				markReadAlignmentObjectRehydrationFailed(result);
+			}
+			result.fixtures.push_back(fixture);
+		}
+
+		if (result.fixtures.empty()) markReadAlignmentObjectRehydrationFailed(result);
+		return result;
+	}
