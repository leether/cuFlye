+	OverlapDumpRecord overlapRangeToDumpRecord(const OverlapRange& ovlp)
+	{
+		OverlapDumpRecord record;
+		record.curId = ovlp.curId.signedId();
+		record.curBegin = ovlp.curBegin;
+		record.curEnd = ovlp.curEnd;
+		record.curLen = ovlp.curLen;
+		record.extId = ovlp.extId.signedId();
+		record.extBegin = ovlp.extBegin;
+		record.extEnd = ovlp.extEnd;
+		record.extLen = ovlp.extLen;
+		record.score = ovlp.score;
+		std::ostringstream divergence;
+		divergence << std::setprecision(9) << ovlp.seqDivergence;
+		record.seqDivergence = std::stod(divergence.str());
+		return record;
+	}
+
+	std::vector<OverlapDumpRecord> canonicalOverlapRecordsFromRanges(
+		const std::vector<OverlapRange>& overlaps)
+	{
+		std::vector<OverlapDumpRecord> records;
+		records.reserve(overlaps.size());
+		for (const auto& ovlp : overlaps)
+		{
+			records.push_back(overlapRangeToDumpRecord(ovlp));
+		}
+		std::sort(records.begin(), records.end());
+		return records;
+	}
