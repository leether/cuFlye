+	std::string compactJsonForJsonl(const std::string& text)
+	{
+		std::ostringstream compact;
+		bool inString = false;
+		bool escaped = false;
+		for (char ch : text)
+		{
+			if (inString)
+			{
+				compact << ch;
+				if (escaped)
+				{
+					escaped = false;
+				}
+				else if (ch == '\\')
+				{
+					escaped = true;
+				}
+				else if (ch == '"')
+				{
+					inString = false;
+				}
+			}
+			else
+			{
+				if (ch == '"')
+				{
+					inString = true;
+					compact << ch;
+				}
+				else if (!std::isspace(static_cast<unsigned char>(ch)))
+				{
+					compact << ch;
+				}
+			}
+		}
+		return compact.str();
+	}
+
+	void writeOverlapWorkerRequestJsonl(
+		const std::string& path,
+		const std::vector<std::string>& requestJsonPaths)
+	{
+		std::ostringstream jsonl;
+		for (const auto& requestJsonPath : requestJsonPaths)
+		{
+			jsonl << compactJsonForJsonl(readTextFile(requestJsonPath)) << "\n";
+		}
+		writeTextFile(path, jsonl.str());
+	}
