+	ReadAlignmentWorkerValidationResult validateReadAlignmentWorkerOutputs(
+		const std::vector<int64_t>& queryIds,
+		const std::string& batchOutputDir)
+	{
+		ReadAlignmentWorkerValidationResult validation;
+		validation.status = "failed";
+		validation.fixtureCount = queryIds.size();
+		for (int64_t queryId : queryIds)
+		{
+			ReadAlignmentWorkerFixtureValidation fixture;
+			fixture.queryId = queryId;
+			fixture.fixtureDir = readAlignmentFixtureDirForQuery(queryId);
+			fixture.oracleTsv = joinReplayPath(fixture.fixtureDir,
+											   "oracle.read-alignment.tsv");
+			fixture.workerTsv = joinReplayPath(
+				joinReplayPath(batchOutputDir, replayQueryDirName(queryId)),
+				"read-alignment.tsv");
+			fixture.oracleReadable = readableFile(fixture.oracleTsv);
+			fixture.workerReadable = readableFile(fixture.workerTsv);
+			if (fixture.oracleReadable && fixture.workerReadable)
+			{
+				auto oracleRows = readCanonicalAlignmentRows(fixture.oracleTsv);
+				auto workerRows = readCanonicalAlignmentRows(fixture.workerTsv);
+				fixture.oracleRecords = oracleRows.size();
+				fixture.workerRecords = workerRows.size();
+				fixture.matched = !oracleRows.empty() && oracleRows == workerRows;
+			}
+			if (fixture.matched) ++validation.validatedFixtureCount;
+			else ++validation.mismatchedFixtureCount;
+			validation.fixtures.push_back(fixture);
+		}
+		validation.consumptionEligible =
+			validation.fixtureCount > 0 &&
+			validation.validatedFixtureCount == validation.fixtureCount &&
+			validation.mismatchedFixtureCount == 0;
+		validation.status = validation.consumptionEligible ? "passed" : "failed";
+		return validation;
+	}
