+	void addReadAlignmentGraphGuardCheck(ReadAlignmentGraphGuardResult& guard,
+										 const std::string& name,
+										 bool passed,
+										 const std::string& detail)
+	{
+		ReadAlignmentGraphGuardCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		guard.checks.push_back(check);
+	}
+
+	bool allReadAlignmentGraphGuardChecksPassed(
+		const ReadAlignmentGraphGuardResult& guard)
+	{
+		for (const auto& check : guard.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !guard.checks.empty();
+	}
+
+	ReadAlignmentGraphGuardResult evaluateReadAlignmentGraphGuard(
+		const ReadAlignmentWorkerValidationResult& validation,
+		int workerStatus,
+		size_t fixtureCount,
+		const std::string& guardJson)
+	{
+		ReadAlignmentGraphGuardResult guard;
+		guard.mode = readAlignmentGraphConsumptionMode();
+		guard.status = "failed";
+		guard.decision = "failed-closed-before-graph-mutation";
+		guard.graphConsumptionState = "failed-closed";
+		guard.failedClosed = true;
+		guard.notConsumed = false;
+
+		addReadAlignmentGraphGuardCheck(
+			guard, "explicit_worker_mode",
+			readAlignmentWorkerMode() == "cuda-bulk-persistent-v0",
+			"CUFLYE_READ_ALIGNMENT_WORKER_MODE=cuda-bulk-persistent-v0");
+		addReadAlignmentGraphGuardCheck(
+			guard, "explicit_guard_mode", guard.mode == "dry-run-v0",
+			"CUFLYE_READ_ALIGNMENT_GRAPH_CONSUMPTION_MODE=dry-run-v0");
+		addReadAlignmentGraphGuardCheck(
+			guard, "fixture_dump_enabled",
+			readAlignmentReplayDumpEnabled() && readAlignmentReplayMultiDumpEnabled(),
+			"replay fixture dump must be enabled with query ids");
+		addReadAlignmentGraphGuardCheck(
+			guard, "fixture_count_nonzero", fixtureCount > 0,
+			"at least one replay fixture must be selected");
+		addReadAlignmentGraphGuardCheck(
+			guard, "worker_exit_success", workerStatus == 0,
+			"CUDA read-alignment worker must exit successfully");
+		addReadAlignmentGraphGuardCheck(
+			guard, "validation_passed",
+			validation.status == "passed" && validation.consumptionEligible,
+			"worker output must match every CPU oracle");
+		addReadAlignmentGraphGuardCheck(
+			guard, "audit_metadata_available", !guardJson.empty(),
+			"guard audit JSON path must be available");
+
+		if (allReadAlignmentGraphGuardChecksPassed(guard))
+		{
+			guard.status = "passed";
+			guard.eligibility = "eligible";
+			guard.graphConsumptionState = "not-consumed";
+			guard.decision = "dry-run-not-consumed";
+			guard.eligible = true;
+			guard.notConsumed = true;
+			guard.failedClosed = false;
+		}
+		return guard;
+	}
