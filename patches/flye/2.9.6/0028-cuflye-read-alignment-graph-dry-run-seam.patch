+	}
+
+	std::string readAlignmentShellQuote(const std::string& value)
+	{
+		std::string quoted = "'";
+		for (char ch : value)
+		{
+			if (ch == '\'') quoted += "'\\''";
+			else quoted += ch;
+		}
+		quoted += "'";
+		return quoted;
+	}
