+	std::vector<std::string> readCanonicalAlignmentRows(const std::string& path)
+	{
+		std::ifstream input(path);
+		if (!input)
+		{
+			throw std::runtime_error("Can't open read alignment TSV: " + path);
+		}
+		std::vector<std::string> rows;
+		std::string line;
+		while (std::getline(input, line))
+		{
+			if (!line.empty() && line.back() == '\r') line.pop_back();
+			if (line.empty()) continue;
+			rows.push_back(line);
+		}
+		std::sort(rows.begin(), rows.end());
+		return rows;
+	}
