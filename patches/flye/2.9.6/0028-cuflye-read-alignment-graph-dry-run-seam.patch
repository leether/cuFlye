+	void runReadAlignmentWorkerDryRunSeam()
+	{
+		if (!readAlignmentWorkerEnabled()) return;
+
+		std::string outputRoot =
+			readAlignmentRequiredEnv("CUFLYE_READ_ALIGNMENT_WORKER_OUTPUT_DIR");
+		ensureReplayDirectory(outputRoot);
+		std::string batchOutputDir =
+			joinReplayPath(outputRoot, "read-alignment-output");
+		ensureReplayDirectory(batchOutputDir);
+		std::string fixtureList =
+			joinReplayPath(outputRoot, "read-alignment-fixtures.list");
+		std::string batchJson =
+			joinReplayPath(outputRoot, "read-alignment-worker-batch.json");
+		std::string validationJson =
+			joinReplayPath(outputRoot, "read-alignment-worker-validation.json");
+		std::string guardJson =
+			joinReplayPath(outputRoot, "read-alignment-graph-consumption-guard.json");
+		std::string seamSummary =
+			joinReplayPath(outputRoot, "read-alignment-seam-summary.json");
+		std::string stdoutLog =
+			joinReplayPath(outputRoot, "read-alignment-worker-stdout.log");
+		std::string stderrLog =
+			joinReplayPath(outputRoot, "read-alignment-worker-stderr.log");
+
+		auto queryIds = sortedReadAlignmentReplayQueryIds();
+		writeReadAlignmentFixtureList(fixtureList, queryIds);
+
+		std::string workerBin =
+			readAlignmentOptionalEnv("CUFLYE_READ_ALIGNMENT_WORKER_BIN", "");
+		std::string command;
+		int workerStatus = 1;
+		if (!workerBin.empty())
+		{
+			command = readAlignmentShellQuote(workerBin) +
+				" --backend cuda --device " +
+				readAlignmentShellQuote(
+					readAlignmentOptionalEnv("CUFLYE_READ_ALIGNMENT_WORKER_DEVICE",
+											 "0")) +
+				" --batch-fixtures-file " + readAlignmentShellQuote(fixtureList) +
+				" --batch-output-dir " + readAlignmentShellQuote(batchOutputDir) +
+				" --batch-json-output " + readAlignmentShellQuote(batchJson) +
+				" --allow-heterogeneous-batch --cuda-persistent-arena "
+				"--cuda-persistent-bulk-output --warmup-runs " +
+				readAlignmentShellQuote(readAlignmentOptionalEnv(
+					"CUFLYE_READ_ALIGNMENT_WORKER_WARMUP_RUNS", "0")) +
+				" --benchmark-runs " +
+				readAlignmentShellQuote(readAlignmentOptionalEnv(
+					"CUFLYE_READ_ALIGNMENT_WORKER_BENCHMARK_RUNS", "1"));
+			std::string memoryBudget = readAlignmentOptionalEnv(
+				"CUFLYE_READ_ALIGNMENT_WORKER_MEMORY_BUDGET_BYTES", "");
+			if (!memoryBudget.empty())
+			{
+				command += " --memory-budget-bytes " +
+						   readAlignmentShellQuote(memoryBudget);
+			}
+			command += " > " + readAlignmentShellQuote(stdoutLog) +
+					   " 2> " + readAlignmentShellQuote(stderrLog);
+			workerStatus = std::system(command.c_str());
+		}
+
+		ReadAlignmentWorkerValidationResult validation;
+		if (workerStatus == 0)
