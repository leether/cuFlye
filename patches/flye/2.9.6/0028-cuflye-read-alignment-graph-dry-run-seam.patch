+	bool readableFile(const std::string& path)
+	{
+		std::ifstream input(path);
+		return input.good();
+	}
+
+	std::string readAlignmentJsonEscape(const std::string& value)
+	{
+		std::ostringstream escaped;
+		for (char ch : value)
+		{
+			switch (ch)
+			{
+			case '\\':
+				escaped << "\\\\";
+				break;
+			case '"':
+				escaped << "\\\"";
+				break;
+			case '\n':
+				escaped << "\\n";
+				break;
+			case '\r':
+				escaped << "\\r";
+				break;
+			case '\t':
+				escaped << "\\t";
+				break;
+			default:
+				escaped << ch;
+				break;
+			}
+		}
+		return escaped.str();
+	}
+
+	const char* readAlignmentBoolJson(bool value)
