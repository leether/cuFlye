+	double readToGraphFullQueryHitWorkerResponseNumber(
+		const std::string& response,
+		const std::string& fieldName,
+		double defaultValue)
+	{
+		size_t pos = readToGraphFullQueryHitWorkerResponseValueStart(
+			response, fieldName);
+		if (pos == std::string::npos) return defaultValue;
+		size_t end = pos;
+		while (end < response.size() &&
+			   (std::isdigit(static_cast<unsigned char>(response[end])) ||
+				response[end] == '-' || response[end] == '+' ||
+				response[end] == '.' || response[end] == 'e' ||
+				response[end] == 'E'))
+		{
+			++end;
+		}
+		if (end == pos) return defaultValue;
+		try
+		{
+			return std::stod(response.substr(pos, end - pos));
+		}
+		catch (const std::exception&)
+		{
+			return defaultValue;
+		}
+	}
