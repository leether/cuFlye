+	size_t readToGraphFullQueryHitWorkerResponseValueStart(
+		const std::string& response,
+		const std::string& fieldName)
+	{
+		std::string key = "\"" + fieldName + "\"";
+		size_t pos = response.find(key);
+		if (pos == std::string::npos) return std::string::npos;
+		pos += key.size();
+		while (pos < response.size() &&
+			   std::isspace(static_cast<unsigned char>(response[pos])))
+		{
+			++pos;
+		}
+		if (pos >= response.size() || response[pos] != ':')
+		{
+			return std::string::npos;
+		}
+		++pos;
+		while (pos < response.size() &&
+			   std::isspace(static_cast<unsigned char>(response[pos])))
+		{
+			++pos;
+		}
+		return pos;
+	}
+
+	bool readToGraphFullQueryHitWorkerResponseStringEquals(
+		const std::string& response,
+		const std::string& fieldName,
+		const std::string& expectedValue)
+	{
+		size_t pos = readToGraphFullQueryHitWorkerResponseValueStart(
+			response, fieldName);
+		if (pos == std::string::npos ||
+			pos >= response.size() ||
+			response[pos] != '"')
+		{
+			return false;
+		}
+		++pos;
+		return response.compare(pos, expectedValue.size(), expectedValue) == 0 &&
+			pos + expectedValue.size() < response.size() &&
+			response[pos + expectedValue.size()] == '"';
+	}
+
+	std::string readToGraphFullQueryHitWorkerResponseString(
+		const std::string& response,
+		const std::string& fieldName,
+		const std::string& defaultValue)
+	{
+		size_t pos = readToGraphFullQueryHitWorkerResponseValueStart(
+			response, fieldName);
+		if (pos == std::string::npos ||
+			pos >= response.size() ||
+			response[pos] != '"')
+		{
+			return defaultValue;
+		}
+		++pos;
+		std::string value;
+		bool escaping = false;
+		while (pos < response.size())
+		{
+			char ch = response[pos++];
+			if (escaping)
+			{
+				value.push_back(ch);
+				escaping = false;
+			}
+			else if (ch == '\\')
+			{
+				escaping = true;
+			}
+			else if (ch == '"')
+			{
+				return value;
+			}
+			else
+			{
+				value.push_back(ch);
+			}
+		}
+		return defaultValue;
+	}
