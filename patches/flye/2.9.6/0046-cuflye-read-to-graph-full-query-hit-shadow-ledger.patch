+	void addReadToGraphFullQueryHitShadowLedgerCheck(
+		ReadToGraphFullQueryHitShadowLedgerResult& ledger,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitShadowLedgerCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		ledger.checks.push_back(check);
+	}
+
+	bool allReadToGraphFullQueryHitShadowLedgerChecksPassed(
+		const ReadToGraphFullQueryHitShadowLedgerResult& ledger)
+	{
+		for (const auto& check : ledger.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !ledger.checks.empty();
+	}
