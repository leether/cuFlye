+	ReadToGraphFullQueryHitShadowLedgerResult
+	evaluateReadToGraphFullQueryHitShadowLedger(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphRawOverlapRehydrationResult& rehydration)
+	{
+		ReadToGraphFullQueryHitShadowLedgerResult result;
+		result.mode = readToGraphFullQueryHitShadowLedgerMode();
+		result.proofFault = readToGraphFullQueryHitShadowLedgerProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.rehydrationStatus = rehydration.status;
+		result.workerRecords = rehydration.workerRecords;
+		result.rehydratedRecords = rehydration.rehydratedRecords;
+		if (!readToGraphFullQueryHitShadowLedgerEnabled()) return result;
+
+		markReadToGraphFullQueryHitShadowLedgerFailed(result);
+		addReadToGraphFullQueryHitShadowLedgerCheck(
+			result, "explicit_shadow_ledger_mode",
+			result.mode == "raw-overlap-chain-input-shadow-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SHADOW_LEDGER_MODE="
+			"raw-overlap-chain-input-shadow-v0");
+		addReadToGraphFullQueryHitShadowLedgerCheck(
+			result, "rehydration_passed",
+			rehydration.status == "passed" && rehydration.eligible &&
+				!rehydration.failedClosed,
+			"M6p raw-overlap rehydration must pass before shadow ledger");
+		addReadToGraphFullQueryHitShadowLedgerCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitShadowLedgerCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapShadowLedgerJson.empty(),
+			"shadow ledger audit JSON path must be available");
+		addReadToGraphFullQueryHitShadowLedgerCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitShadowLedgerChecksPassed(result))
+		{
+			result.error = "shadow ledger preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto records = readToGraphRawOverlapRecords(result.workerTsv);
+			if (result.proofFault == "drop-first-ledger-row" &&
+				!records.empty())
+			{
+				records.erase(records.begin());
+				result.proofFaultApplied = true;
+			}
+			result.ledgerRows = records.size();
+			std::map<int64_t, ReadToGraphFullQueryHitShadowLedgerQuerySummary>
+				byQuery;
+			for (const auto& record : records)
+			{
+				auto& summary = byQuery[record.queryId];
+				summary.queryId = record.queryId;
+				++summary.ledgerRows;
+				if (record.passesChainInputFilter)
+				{
+					++summary.chainInputFilterRows;
+				}
+				if (record.edgeId == 0)
+				{
+					++summary.unresolvedEdgeIdZeroRows;
+				}
+				else
+				{
+					++summary.resolvedEdgeIdRows;
+				}
+			}
+			for (const auto& entry : byQuery)
+			{
+				const auto& summary = entry.second;
+				result.queries.push_back(summary);
+				result.chainInputFilterRows += summary.chainInputFilterRows;
+				result.unresolvedEdgeIdZeroRows +=
+					summary.unresolvedEdgeIdZeroRows;
+				result.resolvedEdgeIdRows += summary.resolvedEdgeIdRows;
+			}
+			result.futureRawOverlapShadowRows = result.ledgerRows;
+			result.futureChainInputShadowRows = result.chainInputFilterRows;
+			result.graphEdgeConsumptionCandidateRows = 0;
+
+			addReadToGraphFullQueryHitShadowLedgerCheck(
+				result, "ledger_count_matches_rehydration",
+				result.ledgerRows == result.rehydratedRecords,
+				"ledger row count must match M6p rehydrated record count");
+			addReadToGraphFullQueryHitShadowLedgerCheck(
+				result, "edge_id_rows_accounted",
+				result.unresolvedEdgeIdZeroRows + result.resolvedEdgeIdRows ==
+					result.ledgerRows,
+				"every ledger row must be counted as unresolved or resolved edge_id");
+			addReadToGraphFullQueryHitShadowLedgerCheck(
+				result, "graph_edge_consumption_candidates_blocked",
+				result.graphEdgeConsumptionCandidateRows == 0,
+				"M6q records shadow eligibility but exposes no graph edge "
+				"consumption candidates");
+			addReadToGraphFullQueryHitShadowLedgerCheck(
+				result, "graph_not_mutated_after_ledger",
+				!result.graphMutationConsumedWorkerOutput,
+				"ledger evaluation must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitShadowLedgerChecksPassed(result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision = "shadow-ledger-written-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"shadow ledger rows differ from rehydrated raw-overlap rows";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitShadowLedgerFailed(result);
+		}
+		return result;
+	}
