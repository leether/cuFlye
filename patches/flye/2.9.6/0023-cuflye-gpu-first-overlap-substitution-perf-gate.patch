+	OverlapWorkerVectorSubstitutionResult maybeUseGpuFirstOverlapWorkerCache(
+		const FastaRecord& fastaRec,
+		bool forceLocal,
+		int maxOverlaps,
+		bool keepAlignment,
+		bool onlyMaxExt,
+		bool nuclAlignment,
+		bool partitionBadMappings)
+	{
+		OverlapWorkerVectorSubstitutionResult substitution;
+		if (!overlapWorkerEnabled()) return substitution;
+		if (!overlapWorkerVectorSubstitutionGpuFirstEnabled()) return substitution;
+
+		validateOverlapWorkerReplayConfig();
+		const char* dumpRoot = overlapReplayDumpDir();
+		if (!dumpRoot || !dumpRoot[0]) return substitution;
+		if (Parameters::get().numThreads != 1)
+		{
+			throw std::runtime_error(
+				"cuFlye overlap replay fixture dump requires --threads 1");
+		}
+
+		int64_t queryId = fastaRec.id.signedId();
+		if (!overlapReplayQuerySelected(queryId)) return substitution;
+
+		OverlapWorkerReplayShape replayShape = makeOverlapWorkerReplayShape(
+			forceLocal, maxOverlaps, keepAlignment, onlyMaxExt, nuclAlignment,
+			partitionBadMappings);
+		if (overlapWorkerVectorSubstitutionProofFault() ==
+			"force-unsupported-selected-shape")
+		{
+			replayShape.supported = false;
+			replayShape.unsupportedReason =
+				replayShape.unsupportedReason.empty()
+					? "proof fault forced unsupported selected shape"
+					: replayShape.unsupportedReason +
+						  "; proof fault forced unsupported selected shape";
+		}
+
+		auto& sessionBatchCache = overlapWorkerSessionBatchCache();
+		if (!sessionBatchCache.ready ||
+			!sessionBatchCacheContainsQuery(sessionBatchCache, queryId))
+		{
+			return substitution;
+		}
+
+		std::string outputRoot = overlapWorkerOutputDir(dumpRoot);
+		std::string queryDone =
+			vectorSubstitutionQueryDoneFile(outputRoot, queryId);
+		if (fileExists(queryDone)) return substitution;
+
+		OverlapWorkerSeamTiming timing;
+		auto seamStart = overlapWorkerTimingNow();
+		auto requestIoStart = overlapWorkerTimingNow();
+		ensureDirectory(outputRoot);
+		std::string ledgerJsonl = joinPath(
+			outputRoot, "worker-vector-substitution-ledger.jsonl");
+		std::string vectorSubstitutionJson = joinPath(
+			outputRoot, "worker-vector-substitution.json");
+		std::string seamSummary = joinPath(outputRoot, "seam-summary.json");
+		std::string fixtureDir =
+			sessionBatchCacheFixtureForQuery(sessionBatchCache, queryId);
+		timing.requestIoMs = overlapWorkerElapsedMs(requestIoStart);
+
+		if (!replayShape.supported)
+		{
+			markVectorSubstitutionFailed(substitution);
+			substitution.mode = overlapWorkerVectorSubstitutionMode();
+			substitution.proofFault =
+				overlapWorkerVectorSubstitutionProofFault();
+			substitution.attempted = true;
+			substitution.selectedQueryId = queryId;
+			substitution.selectedFixtureDir = fixtureDir;
+			substitution.selectedFixtureName = pathBasename(fixtureDir);
+			substitution.error =
+				"unsupported selected overlap replay shape: " +
+				replayShape.unsupportedReason;
+			addVectorSubstitutionCheck(substitution, "supported_shape", false,
+									   replayShape.unsupportedReason);
+			writeOverlapWorkerVectorSubstitutionJson(vectorSubstitutionJson,
+													 substitution);
+			timing.seamTotalMs = overlapWorkerElapsedMs(seamStart);
+			appendOverlapWorkerVectorSubstitutionLedgerEntry(
+				ledgerJsonl, queryId, fixtureDir, replayShape, true,
+				"failed-closed-unsupported-selected-shape",
+				replayShape.unsupportedReason, substitution, timing);
+			writeOverlapWorkerSeamSummary(
+				seamSummary, sessionBatchCache.requestJson,
+				sessionBatchCache.responseJson, sessionBatchCache.fixtureList,
+				sessionBatchCache.queryIdsFile, sessionBatchCache.validationJson,
+				sessionBatchCache.validation.status, true,
+				sessionBatchCache.shadowJson, sessionBatchCache.shadow.status,
+				sessionBatchCache.shadow.shadowConsumptionEligible,
+				sessionBatchCache.graphGuardJson, sessionBatchCache.graphGuard,
+				sessionBatchCache.rehydrationJson, sessionBatchCache.rehydration,
+				sessionBatchCache.objectRehydrationJson,
+				sessionBatchCache.objectRehydration,
+				vectorSubstitutionJson, substitution,
+				"gpu-first-unsupported-selected-shape-before-live-cpu-overlap",
+				sessionBatchCache.batchJson, sessionBatchCache.batchOutputDir,
+				sessionBatchCache.fixtures.size());
+			throw std::runtime_error(
+				"cuFlye overlap worker seam fail-closed; unsupported selected "
+				"GPU-first overlap replay shape; substitution_json=" +
+				vectorSubstitutionJson + "; seam_summary=" + seamSummary);
+		}
+
+		auto substitutionStart = overlapWorkerTimingNow();
+		substitution = evaluateOverlapWorkerGpuFirstSubstitution(
+			sessionBatchCache, replayShape, vectorSubstitutionJson, queryId);
+		writeOverlapWorkerVectorSubstitutionJson(vectorSubstitutionJson,
+												 substitution);
+		timing.substitutionComparisonMs =
+			overlapWorkerElapsedMs(substitutionStart);
+		timing.seamTotalMs = overlapWorkerElapsedMs(seamStart);
+
+		std::string ledgerDecision = "gpu-first-not-consumed";
+		std::string ledgerReason =
+			"selected supported shape evaluated from verified worker cache before live CPU overlap";
+		if (substitution.failedClosed)
+		{
+			ledgerDecision = "failed-closed";
+			ledgerReason = substitution.error;
+		}
+		else if (substitution.consumed)
+		{
+			ledgerDecision = "gpu-first-from-session-batch-cache";
+		}
+		appendOverlapWorkerVectorSubstitutionLedgerEntry(
+			ledgerJsonl, queryId, fixtureDir, replayShape, true, ledgerDecision,
+			ledgerReason, substitution, timing);
+
+		if (substitution.failedClosed)
+		{
+			writeOverlapWorkerSeamSummary(
+				seamSummary, sessionBatchCache.requestJson,
+				sessionBatchCache.responseJson, sessionBatchCache.fixtureList,
+				sessionBatchCache.queryIdsFile, sessionBatchCache.validationJson,
+				sessionBatchCache.validation.status, true,
+				sessionBatchCache.shadowJson, sessionBatchCache.shadow.status,
+				sessionBatchCache.shadow.shadowConsumptionEligible,
+				sessionBatchCache.graphGuardJson, sessionBatchCache.graphGuard,
+				sessionBatchCache.rehydrationJson, sessionBatchCache.rehydration,
+				sessionBatchCache.objectRehydrationJson,
+				sessionBatchCache.objectRehydration,
+				vectorSubstitutionJson, substitution,
+				"gpu-first-substitution-failed-before-live-cpu-overlap",
+				sessionBatchCache.batchJson, sessionBatchCache.batchOutputDir,
+				sessionBatchCache.fixtures.size());
+			throw std::runtime_error(
+				"cuFlye overlap worker seam fail-closed; GPU-first overlap "
+				"vector substitution failed; substitution_json=" +
+				vectorSubstitutionJson + "; seam_summary=" + seamSummary);
+		}
+		if (substitution.consumed)
+		{
+			writeOverlapWorkerSeamSummary(
+				seamSummary, sessionBatchCache.requestJson,
+				sessionBatchCache.responseJson, sessionBatchCache.fixtureList,
+				sessionBatchCache.queryIdsFile, sessionBatchCache.validationJson,
+				sessionBatchCache.validation.status, true,
+				sessionBatchCache.shadowJson, sessionBatchCache.shadow.status,
+				sessionBatchCache.shadow.shadowConsumptionEligible,
+				sessionBatchCache.graphGuardJson, sessionBatchCache.graphGuard,
+				sessionBatchCache.rehydrationJson, sessionBatchCache.rehydration,
+				sessionBatchCache.objectRehydrationJson,
+				sessionBatchCache.objectRehydration,
+				vectorSubstitutionJson, substitution,
+				"gpu-first-substitution-consumed-before-live-cpu-overlap",
+				sessionBatchCache.batchJson, sessionBatchCache.batchOutputDir,
+				sessionBatchCache.fixtures.size());
+			writeOverlapWorkerVectorSubstitutionDoneFile(queryDone, substitution);
+		}
+		return substitution;
+	}
