+	OverlapWorkerVectorSubstitutionResult evaluateOverlapWorkerGpuFirstSubstitution(
+		const OverlapWorkerSessionBatchCache& sessionBatchCache,
+		const OverlapWorkerReplayShape& currentShape,
+		const std::string& vectorSubstitutionJson,
+		int64_t currentQueryId)
+	{
+		OverlapWorkerVectorSubstitutionResult result;
+		result.mode = overlapWorkerVectorSubstitutionMode();
+		result.proofFault = overlapWorkerVectorSubstitutionProofFault();
+		if (!overlapWorkerVectorSubstitutionGpuFirstEnabled()) return result;
+
+		markVectorSubstitutionFailed(result);
+		result.attempted = true;
+		result.selectedQueryId = currentQueryId;
+		result.selectedFixtureDir =
+			sessionBatchCacheFixtureForQuery(sessionBatchCache, currentQueryId);
+		result.selectedFixtureName = pathBasename(result.selectedFixtureDir);
+		result.workerPath = joinPath(joinPath(sessionBatchCache.batchOutputDir,
+											  result.selectedFixtureName),
+									 "overlaps.tsv");
+
+		addVectorSubstitutionCheck(result, "explicit_gpu_first_mode",
+								   result.mode == "gpu-first-supported-v0",
+								   "CUFLYE_OVERLAP_VECTOR_SUBSTITUTION_MODE selects gpu-first-supported-v0");
+		addVectorSubstitutionCheck(result, "session_batch_cache_ready",
+								   sessionBatchCache.ready,
+								   "verified session batch cache must be ready");
+		addVectorSubstitutionCheck(result, "selected_query_in_session_batch",
+								   sessionBatchCacheContainsQuery(sessionBatchCache,
+																  currentQueryId),
+								   "selected query must be present in the verified session batch");
+		addVectorSubstitutionCheck(result, "supported_shape",
+								   currentShape.supported,
+								   "GPU-first substitution is limited to supported replay shapes");
+		addVectorSubstitutionCheck(result, "object_rehydration_passed",
+								   sessionBatchCache.objectRehydration.status ==
+									   "passed" &&
+									   sessionBatchCache.objectRehydration.eligible,
+								   "M4q object rehydration must pass for the cached batch");
+		addVectorSubstitutionCheck(result, "selected_fixture_available",
+								   !result.selectedFixtureDir.empty(),
+								   "selected overlap fixture must be available from the cached batch");
+		addVectorSubstitutionCheck(result, "audit_metadata_available",
+								   !vectorSubstitutionJson.empty(),
+								   "vector substitution audit JSON path must be available");
+
+		if (!allVectorSubstitutionChecksPassed(result)) return result;
+
+		try
+		{
+			auto workerRecords = readCanonicalOverlapDump(result.workerPath);
+			result.workerRecords = workerRecords.size();
+			auto typedRecords = rehydrateTypedOverlapRecords(workerRecords,
+															 result.workerPath);
+			auto objectRecords = rehydrateOverlapRangeObjects(typedRecords);
+			if (result.proofFault == "drop-first-gpu-first-overlap" &&
+				!objectRecords.empty())
+			{
+				objectRecords.erase(objectRecords.begin());
+				result.proofFaultApplied = true;
+			}
+			result.objectRecords = objectRecords.size();
+
+			if (overlapWorkerGpuFirstAuditEnabled())
+			{
+				auto oracleRecords = readCanonicalOverlapDump(
+					joinPath(result.selectedFixtureDir, "oracle.overlaps.tsv"));
+				result.cpuRecords = oracleRecords.size();
+				auto objectDumpRecords =
+					canonicalOverlapRecordsFromRanges(objectRecords);
+				if (oracleRecords != objectDumpRecords)
+				{
+					result.error =
+						"gpu-first audit object vector differs from captured CPU oracle";
+					return result;
+				}
+			}
+
+			result.status = "passed";
+			result.state = "consumed";
+			result.decision = "gpu-first-supported-overlap-vector-substituted";
+			result.selectedOverlapSource =
+				"worker-overlap-range-object-vector-gpu-first";
+			result.eligible = true;
+			result.accepted = true;
+			result.consumed = true;
+			result.notConsumed = false;
+			result.failedClosed = false;
+			result.graphFacingReturnedWorkerOutput = true;
+			result.graphMutationConsumedWorkerOutput = true;
+			result.overlaps = objectRecords;
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+		}
+
+		return result;
+	}
