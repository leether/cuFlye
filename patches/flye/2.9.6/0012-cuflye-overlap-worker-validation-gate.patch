+	bool operator<(const OverlapDumpRecord& lhs, const OverlapDumpRecord& rhs)
+	{
+		if (lhs.curId != rhs.curId) return lhs.curId < rhs.curId;
+		if (lhs.curBegin != rhs.curBegin) return lhs.curBegin < rhs.curBegin;
+		if (lhs.curEnd != rhs.curEnd) return lhs.curEnd < rhs.curEnd;
+		if (lhs.curLen != rhs.curLen) return lhs.curLen < rhs.curLen;
+		if (lhs.extId != rhs.extId) return lhs.extId < rhs.extId;
+		if (lhs.extBegin != rhs.extBegin) return lhs.extBegin < rhs.extBegin;
+		if (lhs.extEnd != rhs.extEnd) return lhs.extEnd < rhs.extEnd;
+		if (lhs.extLen != rhs.extLen) return lhs.extLen < rhs.extLen;
+		if (lhs.score != rhs.score) return lhs.score < rhs.score;
+		return lhs.seqDivergence < rhs.seqDivergence;
+	}
