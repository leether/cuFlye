+	std::string pathBasename(const std::string& path)
+	{
+		if (path.empty()) return path;
+		size_t end = path.find_last_not_of('/');
+		if (end == std::string::npos) return path;
+		size_t slash = path.find_last_of('/', end);
+		if (slash == std::string::npos) return path.substr(0, end + 1);
+		return path.substr(slash + 1, end - slash);
 	}
 
+	std::vector<std::string> splitOverlapTabLine(const std::string& line)
+	{
+		std::vector<std::string> fields;
+		std::string field;
+		std::stringstream stream(line);
+		while (std::getline(stream, field, '\t')) fields.push_back(field);
+		return fields;
+	}
+
+	int64_t parseOverlapDumpInt(const std::string& value,
+								const std::string& name,
+								const std::string& path,
+								size_t lineNo)
+	{
+		if (value.empty() || value[0] == '+')
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) + ": " +
+									 name + " must be a signed decimal integer");
+		}
+		size_t parsedChars = 0;
+		long long parsed = std::stoll(value, &parsedChars);
+		if (parsedChars != value.size())
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) + ": " +
+									 name + " must be a decimal integer");
+		}
+		return static_cast<int64_t>(parsed);
+	}
+
+	double parseOverlapDumpFloat(const std::string& value,
+								 const std::string& path,
+								 size_t lineNo)
+	{
+		size_t parsedChars = 0;
+		double parsed = std::stod(value, &parsedChars);
+		if (parsedChars != value.size() || !std::isfinite(parsed) || parsed < 0.0)
+		{
+			throw std::runtime_error(
+				path + ":" + std::to_string(lineNo) +
+				": seq_divergence must be finite and non-negative");
+		}
+		return parsed;
+	}
+
+	OverlapDumpRecord parseOverlapDumpRecord(const std::string& line,
+											 const std::string& path,
+											 size_t lineNo)
+	{
+		if (line.empty())
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": blank overlap records are not allowed");
+		}
+		if (!line.empty() && line[line.size() - 1] == '\r')
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": CRLF records are not allowed");
+		}
+		auto fields = splitOverlapTabLine(line);
+		if (fields.size() != 10)
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": expected 10 tab-separated fields");
+		}
+
+		OverlapDumpRecord record;
+		record.curId = parseOverlapDumpInt(fields[0], "cur_id", path, lineNo);
+		record.curBegin = parseOverlapDumpInt(fields[1], "cur_begin", path, lineNo);
+		record.curEnd = parseOverlapDumpInt(fields[2], "cur_end", path, lineNo);
+		record.curLen = parseOverlapDumpInt(fields[3], "cur_len", path, lineNo);
+		record.extId = parseOverlapDumpInt(fields[4], "ext_id", path, lineNo);
+		record.extBegin = parseOverlapDumpInt(fields[5], "ext_begin", path, lineNo);
+		record.extEnd = parseOverlapDumpInt(fields[6], "ext_end", path, lineNo);
+		record.extLen = parseOverlapDumpInt(fields[7], "ext_len", path, lineNo);
+		record.score = parseOverlapDumpInt(fields[8], "score", path, lineNo);
+		record.seqDivergence = parseOverlapDumpFloat(fields[9], path, lineNo);
+
+		if (record.curId == 0 || record.extId == 0)
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": ids must not be zero");
+		}
+		if (record.curLen <= 0 || record.extLen <= 0)
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": lengths must be positive");
+		}
+		if (record.curBegin < 0 || record.curEnd < 0 ||
+			record.extBegin < 0 || record.extEnd < 0)
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": ranges must be non-negative");
+		}
+		if (record.curBegin > record.curEnd || record.curEnd >= record.curLen)
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": current range must satisfy begin <= end < len");
+		}
+		if (record.extBegin > record.extEnd || record.extEnd >= record.extLen)
+		{
+			throw std::runtime_error(path + ":" + std::to_string(lineNo) +
+									 ": extension range must satisfy begin <= end < len");
+		}
+		return record;
+	}
+
+	std::vector<OverlapDumpRecord> readCanonicalOverlapDump(const std::string& path)
+	{
+		std::ifstream input(path);
+		if (!input)
+		{
+			throw std::runtime_error("cannot read overlap dump: " + path);
+		}
+		std::vector<OverlapDumpRecord> records;
+		std::string line;
+		size_t lineNo = 0;
+		while (std::getline(input, line))
+		{
+			++lineNo;
+			records.push_back(parseOverlapDumpRecord(line, path, lineNo));
+		}
+		if (records.empty())
+		{
+			throw std::runtime_error("overlap dump is empty: " + path);
+		}
+		std::sort(records.begin(), records.end());
+		return records;
+	}
+
+	OverlapWorkerValidationResult validateOverlapWorkerOutputs(
+		const std::vector<std::string>& fixtures,
+		const std::string& batchOutputDir)
+	{
+		OverlapWorkerValidationResult result;
+		result.mode = overlapWorkerValidationMode();
+		result.consumptionEligible = true;
+
+		for (const auto& fixtureDir : fixtures)
+		{
+			OverlapWorkerFixtureValidation fixture;
+			fixture.fixtureDir = fixtureDir;
+			fixture.fixtureName = pathBasename(fixtureDir);
+			fixture.oraclePath = joinPath(fixtureDir, "oracle.overlaps.tsv");
+			fixture.workerPath = joinPath(joinPath(batchOutputDir, fixture.fixtureName),
+										  "overlaps.tsv");
+			try
+			{
+				auto oracleRecords = readCanonicalOverlapDump(fixture.oraclePath);
+				fixture.oracleAbiValid = true;
+				fixture.oracleRecords = oracleRecords.size();
+				auto workerRecords = readCanonicalOverlapDump(fixture.workerPath);
+				fixture.workerAbiValid = true;
+				fixture.workerRecords = workerRecords.size();
+				if (oracleRecords == workerRecords)
+				{
+					fixture.status = "passed";
+					fixture.canonicalDiffStatus = "match";
+				}
+				else
+				{
+					fixture.status = "failed";
+					fixture.canonicalDiffStatus = "mismatch";
+					fixture.error = "worker output canonical records differ from oracle";
+					result.consumptionEligible = false;
+				}
+			}
+			catch (const std::exception& exc)
+			{
+				fixture.status = "failed";
+				fixture.error = exc.what();
+				result.consumptionEligible = false;
+			}
+			result.fixtures.push_back(fixture);
+		}
+
+		if (result.fixtures.empty()) result.consumptionEligible = false;
+		result.status = result.consumptionEligible ? "passed" : "failed";
+		return result;
+	}
