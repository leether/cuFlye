+			 << boolJson(validation.consumptionEligible) << ",\n"
+			 << "  \"graph_mutation_consumed_worker_output\": false,\n"
+			 << "  \"fixtures\": [\n";
+		for (size_t i = 0; i < validation.fixtures.size(); ++i)
+		{
+			const auto& fixture = validation.fixtures[i];
+			json << "    {\n"
+				 << "      \"fixture_dir\": \"" << jsonEscape(fixture.fixtureDir) << "\",\n"
+				 << "      \"fixture_name\": \"" << jsonEscape(fixture.fixtureName) << "\",\n"
+				 << "      \"oracle_path\": \"" << jsonEscape(fixture.oraclePath) << "\",\n"
+				 << "      \"worker_path\": \"" << jsonEscape(fixture.workerPath) << "\",\n"
+				 << "      \"status\": \"" << jsonEscape(fixture.status) << "\",\n"
+				 << "      \"oracle_abi_valid\": " << boolJson(fixture.oracleAbiValid) << ",\n"
+				 << "      \"worker_abi_valid\": " << boolJson(fixture.workerAbiValid) << ",\n"
+				 << "      \"oracle_records\": " << fixture.oracleRecords << ",\n"
+				 << "      \"worker_records\": " << fixture.workerRecords << ",\n"
+				 << "      \"canonical_diff_status\": \""
+				 << jsonEscape(fixture.canonicalDiffStatus) << "\"";
+			if (!fixture.error.empty())
+			{
+				json << ",\n      \"error\": \"" << jsonEscape(fixture.error) << "\"\n";
+			}
+			else
+			{
+				json << "\n";
+			}
+			json << "    }" << (i + 1 == validation.fixtures.size() ? "\n" : ",\n");
+		}
+		json << "  ]\n"
+			 << "}\n";
+		writeTextFile(path, json.str());
+	}
