+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		binding.checks.push_back(check);
+	}
+
+	bool allReadToGraphFullQueryHitGraphEdgeBindingChecksPassed(
+		const ReadToGraphFullQueryHitGraphEdgeBindingResult& binding)
+	{
+		for (const auto& check : binding.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !binding.checks.empty();
+	}
+
+	void markReadToGraphFullQueryHitGraphEdgeBindingFailed(
+		ReadToGraphFullQueryHitGraphEdgeBindingResult& binding)
+	{
+		binding.status = "failed";
+		binding.state = "failed-closed";
+		binding.decision = "failed-closed-before-graph-mutation";
+		binding.eligible = false;
+		binding.consumed = false;
+		binding.notConsumed = false;
+		binding.failedClosed = true;
+		binding.graphMutationConsumedWorkerOutput = false;
+	}
+
+	ReadToGraphFullQueryHitGraphEdgeBindingResult
+	evaluateReadToGraphFullQueryHitGraphEdgeBinding(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphRawOverlapRehydrationResult& rehydration,
+		const ReadToGraphFullQueryHitShadowLedgerResult& ledger,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitGraphEdgeBindingResult result;
+		result.mode = readToGraphFullQueryHitGraphEdgeBindingMode();
+		result.proofFault =
+			readToGraphFullQueryHitGraphEdgeBindingProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.ledgerStatus = ledger.status;
+		result.ledgerRows = ledger.ledgerRows;
+		result.chainInputFilterRows = ledger.chainInputFilterRows;
+		if (!readToGraphFullQueryHitGraphEdgeBindingEnabled()) return result;
+
+		markReadToGraphFullQueryHitGraphEdgeBindingFailed(result);
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "explicit_graph_edge_binding_mode",
+			result.mode == "graph-edge-binding-dry-run-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_GRAPH_EDGE_BINDING_MODE="
+			"graph-edge-binding-dry-run-v0");
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "rehydration_passed",
+			rehydration.status == "passed" && rehydration.eligible &&
+				!rehydration.failedClosed,
+			"M6p raw-overlap rehydration must pass before graph-edge binding");
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "shadow_ledger_passed",
+			ledger.status == "passed" && ledger.eligible &&
+				!ledger.failedClosed,
+			"M6q shadow ledger must pass before graph-edge binding");
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "chain_input_rows_present",
+			ledger.chainInputFilterRows > 0,
+			"graph-edge binding requires chain-input-positive rows");
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapGraphEdgeBindingJson.empty(),
+			"graph-edge binding audit JSON path must be available");
+		addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitGraphEdgeBindingChecksPassed(result))
+		{
+			result.error = "graph-edge binding preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto records = readToGraphRawOverlapRecords(result.workerTsv);
+			std::vector<ReadToGraphRawOverlapRecord> bindingRecords;
+			for (const auto& record : records)
+			{
+				if (record.passesChainInputFilter)
+				{
+					bindingRecords.push_back(record);
+				}
+			}
+			if (result.proofFault == "drop-first-binding-row" &&
+				!bindingRecords.empty())
+			{
+				bindingRecords.erase(bindingRecords.begin());
+				result.proofFaultApplied = true;
+			}
+			result.bindingRows = bindingRecords.size();
+
+			std::map<int64_t,
+					 ReadToGraphFullQueryHitGraphEdgeBindingQuerySummary>
+				byQuery;
+			for (const auto& record : bindingRecords)
+			{
+				auto& summary = byQuery[record.queryId];
+				summary.queryId = record.queryId;
+				++summary.chainInputRows;
+
+				if (record.edgeId == 0)
+				{
+					++result.missingGraphEdgeRows;
+					++summary.missingGraphEdgeRows;
+					continue;
+				}
+
+				++result.resolvedEdgeIdRows;
+				++summary.resolvedEdgeIdRows;
+				FastaRecord::Id edgeId = checkedReadAlignmentFastaIdFromSigned(
+					record.edgeId, "edge_id", result.workerTsv);
+				GraphEdge* edge = graph.getEdge(edgeId);
+				if (edge)
+				{
+					++result.liveGraphEdgeRows;
+					++summary.liveGraphEdgeRows;
+				}
+				else
+				{
+					++result.missingGraphEdgeRows;
+					++summary.missingGraphEdgeRows;
+				}
+			}
+			for (const auto& entry : byQuery)
+			{
+				result.queries.push_back(entry.second);
+			}
+
+			addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+				result, "binding_count_matches_chain_input",
+				result.bindingRows == ledger.chainInputFilterRows,
+				"binding rows must match M6q chain-input-positive rows");
+			addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+				result, "binding_rows_have_resolved_edge_ids",
+				result.resolvedEdgeIdRows == result.bindingRows,
+				"every binding row must have a resolved nonzero edge_id");
+			addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+				result, "binding_rows_have_live_graph_edges",
+				result.liveGraphEdgeRows == result.bindingRows,
+				"every binding row edge_id must map to a live GraphEdge");
+			addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+				result, "graph_not_mutated_after_binding",
+				!result.graphMutationConsumedWorkerOutput,
+				"graph-edge binding audit must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitGraphEdgeBindingChecksPassed(result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision = "graph-edge-binding-audited-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"graph-edge binding rows differ from ledger chain-input rows";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitGraphEdgeBindingFailed(result);
+		}
+		return result;
+	}
