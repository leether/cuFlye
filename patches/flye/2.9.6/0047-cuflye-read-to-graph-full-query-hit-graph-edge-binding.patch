+	void addReadToGraphFullQueryHitGraphEdgeBindingCheck(
+		ReadToGraphFullQueryHitGraphEdgeBindingResult& binding,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitGraphEdgeBindingCheck check;
