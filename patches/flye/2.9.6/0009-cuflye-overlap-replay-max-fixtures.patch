+	size_t overlapReplayMaxFixtures()
+	{
+		static size_t maxFixtures = []()
+		{
+			const char* raw = std::getenv("CUFLYE_OVERLAP_REPLAY_MAX_FIXTURES");
+			if (!raw || !raw[0]) return static_cast<size_t>(1);
+			long long parsed = std::stoll(raw);
+			if (parsed < 1)
+			{
+				throw std::runtime_error(
+					"CUFLYE_OVERLAP_REPLAY_MAX_FIXTURES must be >= 1");
+			}
+			return static_cast<size_t>(parsed);
+		}();
+		return maxFixtures;
+	}
