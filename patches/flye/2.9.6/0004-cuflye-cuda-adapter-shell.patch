+	template <class Matches>
+	void collectCandidateMatchesCudaAdapter(const FastaRecord& fastaRec,
+											Matches& matches)
+	{
+		std::lock_guard<std::mutex> lock(cudaAdapterMutex());
+		PackedCudaFixture& fixture = packedCudaFixtureCache();
+		loadPackedCudaFixture(fixture);
+
+		int64_t queryId = fastaRec.id.signedId();
+		auto expectedSeq = fixture.readSequences.find(queryId);
+		if (expectedSeq == fixture.readSequences.end())
+		{
+			throw std::runtime_error(
+				"cuFlye CUDA adapter fail-closed; adapter=external-packed-v0; "
+				"unsupported real Flye shape: query id " +
+				std::to_string(queryId) + " is absent from packed reads TSV");
+		}
+		if (expectedSeq->second != fastaRec.sequence.str())
+		{
+			throw std::runtime_error(
+				"cuFlye CUDA adapter fail-closed; adapter=external-packed-v0; "
+				"unsupported real Flye shape: query sequence does not match "
+				"packed reads TSV for query id " + std::to_string(queryId));
+		}
+
+		for (const auto& record : fixture.records)
+		{
+			if (record.queryId != queryId) continue;
+			matches.emplace_back(record.queryPos,
+								 record.targetPos,
+								 record.targetId,
+								 record.kmerRepr);
+		}
+	}
