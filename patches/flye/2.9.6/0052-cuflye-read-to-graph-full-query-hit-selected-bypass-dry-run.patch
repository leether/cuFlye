+
+	bool allReadToGraphFullQueryHitSelectedBypassDryRunChecksPassed(
+		const ReadToGraphFullQueryHitSelectedBypassDryRunResult& bypass)
+	{
+		for (const auto& check : bypass.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !bypass.checks.empty();
+	}
+
+	void addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+		ReadToGraphFullQueryHitSelectedBypassDryRunResult& bypass,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		bypass.checks.push_back(check);
+	}
