+		dryRun.rawOverlapSelectedBypassDryRunBypassedRows =
+			bypass.selectedBypassedRows;
+		dryRun.rawOverlapSelectedBypassDryRunCpuOwnedRows =
+			bypass.cpuOwnedResidualRows;
+		dryRun.rawOverlapSelectedBypassDryRunMergedRows =
+			bypass.mergedLedgerRows;
+	}
