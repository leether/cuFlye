+	ReadToGraphFullQueryHitSelectedBypassDryRunResult
+	evaluateReadToGraphFullQueryHitSelectedBypassDryRun(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitSelectedBypassPlanResult& plan,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitSelectedBypassDryRunResult result;
+		result.mode = readToGraphFullQueryHitSelectedBypassDryRunMode();
+		result.proofFault =
+			readToGraphFullQueryHitSelectedBypassDryRunProofFault();
+		result.workerTsv = dryRun.workerOutputTsv;
+		result.bypassPlanStatus = plan.status;
+		result.bypassPlanLedgerRows = plan.selectedBypassLedgerRows;
+		result.bypassPlanCpuOwnedRows = plan.cpuOwnedResidualRows;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitSelectedBypassDryRunEnabled())
+		{
+			return result;
+		}
+
+		markReadToGraphFullQueryHitSelectedBypassDryRunFailed(result);
+		addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+			result, "explicit_selected_bypass_dry_run_mode",
+			result.mode == "selected-bypass-dry-run-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SELECTED_BYPASS_DRY_RUN_MODE="
+			"selected-bypass-dry-run-v0");
+		addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+			result, "selected_bypass_plan_passed",
+			plan.status == "passed" && plan.eligible && !plan.failedClosed,
+			"M6w selected bypass plan must pass before selected bypass dry-run");
+		addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+			result, "selected_bypass_plan_row_keys_matched",
+			plan.bypassRowKeyMatched && plan.bypassOrderedRowKeyMatched,
+			"M6w bypass plan must match selected CPU handoff row keys and order");
+		addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+			result, "audit_metadata_available",
+			!dryRun.rawOverlapSelectedBypassDryRunJson.empty(),
+			"selected bypass dry-run audit JSON path must be available");
+		addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitSelectedBypassDryRunChecksPassed(result))
+		{
+			result.error = "selected bypass dry-run preconditions failed";
+			return result;
+		}
+
+		try
+		{
+			auto allCpuRecords =
+				readToGraphOracleRawOverlapRecords(dryRun.queryIds);
+			auto selectedCpuRecords =
+				readToGraphSelectedCpuHandoffRecords(dryRun.queryIds);
+			result.totalCpuRawOverlapRows = allCpuRecords.size();
+			auto selectedCpuKeys =
+				readToGraphRawOverlapRecordRowKeys(selectedCpuRecords);
+			std::set<ReadToGraphRawOverlapRowKey> selectedCpuKeySet;
+			for (const auto& key : selectedCpuKeys)
+			{
+				selectedCpuKeySet.insert(key);
+			}
+
+			std::vector<ReadToGraphFullQueryHitObjectVectorSmokeObject>
+				bypassObjects =
+					buildReadToGraphFullQueryHitLiveObjectVector(
+						result.workerTsv, graph, result.missingGraphEdgeRows);
+			if (result.proofFault == "drop-first-selected-bypass-row" &&
+				!bypassObjects.empty())
+			{
+				bypassObjects.erase(bypassObjects.begin());
+				result.proofFaultApplied = true;
+			}
+			result.selectedBypassPayloadRows = bypassObjects.size();
+			result.selectedBypassedRows = bypassObjects.size();
+
+			std::vector<ReadToGraphRawOverlapRecord> bypassRecords;
+			std::set<ReadToGraphRawOverlapRowKey> bypassKeys;
+			for (size_t index = 0; index < bypassObjects.size(); ++index)
+			{
+				const auto& object = bypassObjects[index];
+				const auto key =
+					readToGraphRawOverlapRecordToRowKey(object.record);
+				bypassKeys.insert(key);
+				bypassRecords.push_back(object.record);
+				result.selectedBypassRows.push_back(
+					readToGraphFullQueryHitSelectedBypassPlanRow(
+						index, object.record, "selected-bypassed-dry-run",
+						"m6w-bypass-plan-row"));
+			}
+			auto bypassRecordKeys =
+				readToGraphRawOverlapRecordRowKeys(bypassRecords);
+			result.selectedBypassRowKeyDiff =
+				compareReadToGraphRawOverlapRowKeys(
+					selectedCpuKeys, bypassRecordKeys);
+			result.selectedBypassRowKeyMatched =
+				result.selectedBypassRowKeyDiff.matched;
+			result.selectedBypassOrderedRowKeyMatched =
+				result.selectedBypassRowKeyDiff.orderedMatched;
+			result.selectedBypassUnexpectedRows =
+				result.selectedBypassRowKeyDiff.extraRows;
+
+			result.cpuOwnedRows = plan.cpuOwnedRows;
+			result.cpuOwnedResidualRows = result.cpuOwnedRows.size();
+			for (const auto& record : allCpuRecords)
+			{
+				const auto key = readToGraphRawOverlapRecordToRowKey(record);
+				if (bypassKeys.count(key) != 0)
+				{
+					result.mergedLedger.push_back(
+						readToGraphFullQueryHitSelectedBypassPlanRow(
+							result.mergedLedger.size(), record,
+							"selected-bypassed-dry-run",
+							"m6w-bypass-plan-row"));
+				}
+				else if (selectedCpuKeySet.count(key) != 0)
+				{
+					++result.selectedBypassMissingRows;
+					result.mergedLedger.push_back(
+						readToGraphFullQueryHitSelectedBypassPlanRow(
+							result.mergedLedger.size(), record,
+							"selected-bypass-payload-missing",
+							"selected-row-not-present-in-bypass-payload"));
+				}
+				else
+				{
+					std::string reason = "not-selected-for-bypass";
+					if (record.edgeId == 0)
+					{
+						reason = "unsupported-unresolved-edge-id";
+					}
+					result.mergedLedger.push_back(
+						readToGraphFullQueryHitSelectedBypassPlanRow(
+							result.mergedLedger.size(), record,
+							"cpu-owned", reason));
+				}
+			}
+			result.mergedLedgerRows = result.mergedLedger.size();
+
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "selected_bypass_rows_present",
+				result.selectedBypassedRows > 0,
+				"selected bypass dry-run requires nonzero bypassed rows");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "selected_bypassed_count_matches_bypass_plan",
+				result.selectedBypassedRows == plan.selectedBypassLedgerRows,
+				"selected bypass dry-run rows must match M6w bypass ledger rows");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "selected_bypass_payload_matches_bypass_plan",
+				result.selectedBypassRowKeyMatched,
+				"selected bypass payload row keys must match M6w bypass plan");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "selected_bypass_payload_order_matches_bypass_plan",
+				result.selectedBypassOrderedRowKeyMatched,
+				"selected bypass payload row order must match M6w bypass plan");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "cpu_owned_residual_rows_preserved",
+				result.cpuOwnedResidualRows == plan.cpuOwnedResidualRows &&
+					result.cpuOwnedResidualRows == result.cpuOwnedRows.size(),
+				"CPU-owned residual rows must be preserved from M6w plan");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "merged_ledger_accounts_for_input",
+				result.mergedLedgerRows == result.totalCpuRawOverlapRows,
+				"merged bypass-plus-CPU-owned ledger must account for all CPU raw-overlap rows");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "merged_ledger_count_matches_components",
+				result.selectedBypassedRows + result.cpuOwnedResidualRows +
+					result.selectedBypassMissingRows == result.mergedLedgerRows,
+				"merged ledger rows must equal bypassed, CPU-owned, and missing selected rows");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "selected_bypass_missing_rows_zero",
+				result.selectedBypassMissingRows == 0,
+				"selected bypass dry-run must not miss selected bypass rows");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "selected_bypass_unexpected_rows_zero",
+				result.selectedBypassUnexpectedRows == 0,
+				"selected bypass dry-run must not add unexpected bypass rows");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "bypass_objects_have_live_graph_edges",
+				result.missingGraphEdgeRows == 0,
+				"every selected bypass dry-run object must have a live GraphEdge");
+			addReadToGraphFullQueryHitSelectedBypassDryRunCheck(
+				result, "graph_not_mutated_after_selected_bypass_dry_run",
+				!result.graphMutationConsumedWorkerOutput,
+				"selected bypass dry-run must not mutate graph state");
+
+			if (allReadToGraphFullQueryHitSelectedBypassDryRunChecksPassed(
+					result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"selected-bypass-dry-run-written-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"selected bypass dry-run differs from M6w bypass plan";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitSelectedBypassDryRunFailed(result);
+		}
+		return result;
+	}
+
