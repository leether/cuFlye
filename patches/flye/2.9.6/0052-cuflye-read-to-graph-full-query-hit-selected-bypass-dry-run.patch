+	void markReadToGraphFullQueryHitSelectedBypassDryRunFailed(
+		ReadToGraphFullQueryHitSelectedBypassDryRunResult& bypass)
+	{
+		bypass.status = "failed";
+		bypass.state = "failed-closed";
+		bypass.decision = "failed-closed-before-graph-mutation";
+		bypass.eligible = false;
+		bypass.consumed = false;
+		bypass.notConsumed = false;
+		bypass.failedClosed = true;
+		bypass.graphMutationConsumedWorkerOutput = false;
