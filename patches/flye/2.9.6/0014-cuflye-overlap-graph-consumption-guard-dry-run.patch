+	void addGraphGuardCheck(OverlapWorkerGraphGuardResult& guard,
+							const std::string& name,
+							bool passed,
+							const std::string& detail)
+	{
+		OverlapWorkerGraphGuardCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		guard.checks.push_back(check);
+	}
+
+	bool allGraphGuardChecksPassed(const OverlapWorkerGraphGuardResult& guard)
+	{
+		for (const auto& check : guard.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !guard.checks.empty();
+	}
+
+	OverlapWorkerGraphGuardResult evaluateOverlapWorkerGraphGuard(
+		const OverlapWorkerValidationResult& validation,
+		const OverlapWorkerShadowResult& shadow,
+		size_t fixtureCount,
+		const std::string& guardJson)
+	{
+		OverlapWorkerGraphGuardResult guard;
+		guard.mode = overlapWorkerGraphConsumptionMode();
+		if (!overlapWorkerGraphConsumptionDryRunEnabled()) return guard;
+
+		guard.status = "failed";
+		guard.decision = "failed-closed-before-graph-mutation";
+		guard.graphConsumptionState = "failed-closed";
+		guard.failedClosed = true;
+		guard.notConsumed = false;
+
+		addGraphGuardCheck(guard, "explicit_guard_mode",
+						   guard.mode == "dry-run-v0",
+						   "CUFLYE_OVERLAP_GRAPH_CONSUMPTION_MODE=dry-run-v0");
+		addGraphGuardCheck(guard, "validation_passed",
+						   validation.status == "passed" &&
+							   validation.consumptionEligible,
+						   "worker output validation must pass");
+		addGraphGuardCheck(guard, "shadow_mode_selected",
+						   overlapWorkerShadowEnabled(),
+						   "CUFLYE_OVERLAP_WORKER_SHADOW_MODE=canonical-overlap-v0");
+		addGraphGuardCheck(guard, "shadow_passed",
+						   shadow.status == "passed" &&
+							   shadow.shadowConsumptionEligible,
+						   "in-memory shadow comparison must pass");
+		addGraphGuardCheck(guard, "fixture_count_matches_request",
+						   fixtureCount == overlapReplayMaxFixtures(),
+						   "captured fixture count must match request");
+		addGraphGuardCheck(guard, "audit_metadata_available",
+						   !guardJson.empty(),
+						   "guard audit JSON path must be available");
+
+		if (allGraphGuardChecksPassed(guard))
+		{
+			guard.status = "passed";
+			guard.eligibility = "eligible";
+			guard.graphConsumptionState = "not-consumed";
+			guard.decision = "dry-run-not-consumed";
+			guard.eligible = true;
+			guard.notConsumed = true;
+			guard.failedClosed = false;
 		}
+		return guard;
+	}
