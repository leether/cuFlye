+	std::vector<GraphAlignment> runReadAlignmentPreDivergenceWorker(
+		const FastaRecord::Id& seqId,
+		RepeatGraph& graph,
+		ReadAlignmentPreDivergenceDryRunResult& result)
+	{
+		result.mode = readAlignmentPreDivergenceChainMode();
+		result.proofFault = readAlignmentPreDivergenceChainProofFault();
+		result.status = "failed";
+		result.decision = "failed-closed-before-graph-mutation";
+		result.failedClosed = true;
+		result.queryId = seqId.signedId();
+		result.fixtureDir = readAlignmentFixtureDirForQuery(seqId.signedId());
+		result.workerOutputDir =
+			joinReplayPath(result.fixtureDir, "predivergence-worker");
+		result.workerTsv = joinReplayPath(result.workerOutputDir,
+										  "read-alignment.tsv");
+		result.workerJson = joinReplayPath(result.workerOutputDir, "worker.json");
+		result.stdoutLog = joinReplayPath(result.workerOutputDir, "stdout.log");
+		result.stderrLog = joinReplayPath(result.workerOutputDir, "stderr.log");
+		result.auditJson = joinReplayPath(
+			result.fixtureDir, "read-alignment-predivergence-dry-run.json");
+		result.attempted = true;
+
+		ensureReplayDirectory(result.workerOutputDir);
+		std::string workerBin =
+			readAlignmentRequiredEnv("CUFLYE_READ_ALIGNMENT_WORKER_BIN");
+		result.workerCommand = readAlignmentShellQuote(workerBin) +
+			" --backend cuda --device " +
+			readAlignmentShellQuote(
+				readAlignmentOptionalEnv("CUFLYE_READ_ALIGNMENT_WORKER_DEVICE",
+										 "0")) +
+			" --fixture-dir " + readAlignmentShellQuote(result.fixtureDir) +
+			" --output-tsv " + readAlignmentShellQuote(result.workerTsv) +
+			" --json-output " + readAlignmentShellQuote(result.workerJson) +
+			" --emit-pre-divergence-chains --warmup-runs " +
+			readAlignmentShellQuote(readAlignmentOptionalEnv(
+				"CUFLYE_READ_ALIGNMENT_WORKER_WARMUP_RUNS", "0")) +
+			" --benchmark-runs " +
+			readAlignmentShellQuote(readAlignmentOptionalEnv(
+				"CUFLYE_READ_ALIGNMENT_WORKER_BENCHMARK_RUNS", "1"));
+		std::string memoryBudget = readAlignmentOptionalEnv(
+			"CUFLYE_READ_ALIGNMENT_WORKER_MEMORY_BUDGET_BYTES", "");
+		if (!memoryBudget.empty())
+		{
+			result.workerCommand += " --memory-budget-bytes " +
+									readAlignmentShellQuote(memoryBudget);
+		}
+		result.workerCommand += " > " + readAlignmentShellQuote(result.stdoutLog) +
+								" 2> " + readAlignmentShellQuote(result.stderrLog);
+		result.workerExitStatus = std::system(result.workerCommand.c_str());
+		if (result.workerExitStatus != 0)
+		{
+			throw std::runtime_error(
+				"CUDA read-alignment pre-divergence worker failed with status " +
+				std::to_string(result.workerExitStatus));
+		}
+
+		result.workerTsvReadable = readableFile(result.workerTsv);
+		if (!result.workerTsvReadable)
+		{
+			throw std::runtime_error(
+				"CUDA read-alignment pre-divergence worker did not write TSV: " +
+				result.workerTsv);
+		}
+
+		auto workerRecords = readAlignmentDumpRecords(result.workerTsv);
+		result.workerRecords = workerRecords.size();
+		auto typedRecords =
+			rehydrateTypedReadAlignmentRecords(workerRecords, graph,
+											   result.workerTsv);
+		auto objectVector =
+			rehydrateGraphAlignmentObjectVector(typedRecords, result.workerTsv);
+		result.gpuPreDivergenceChains = objectVector.size();
+		return objectVector;
+	}
