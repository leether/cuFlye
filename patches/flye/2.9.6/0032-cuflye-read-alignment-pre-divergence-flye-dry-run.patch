+	std::string readAlignmentPreDivergenceChainMode()
+	{
+		static std::string mode = []()
+		{
+			const char* raw =
+				std::getenv("CUFLYE_READ_ALIGNMENT_PREDIVERGENCE_CHAIN_MODE");
+			if (!raw || !raw[0]) return std::string();
+			std::string selected(raw);
+			if (selected != "selected-read-dry-run-v0")
+			{
+				throw std::runtime_error(
+					"Unsupported "
+					"CUFLYE_READ_ALIGNMENT_PREDIVERGENCE_CHAIN_MODE: " +
+					selected);
+			}
+			return selected;
+		}();
+		return mode;
+	}
