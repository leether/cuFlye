+	OverlapWorkerVectorSubstitutionResult evaluateOverlapWorkerVectorSubstitution(
+		const std::vector<std::string>& fixtures,
+		const std::string& batchOutputDir,
+		const OverlapWorkerObjectRehydrationResult& objectRehydration,
+		const std::string& substitutionJson,
+		const std::string& currentFixtureDir,
+		int64_t currentQueryId,
+		const std::vector<OverlapRange>& currentCpuOverlaps)
+	{
+		OverlapWorkerVectorSubstitutionResult result;
+		result.mode = overlapWorkerVectorSubstitutionMode();
+		result.proofFault = overlapWorkerVectorSubstitutionProofFault();
+		if (!overlapWorkerVectorSubstitutionEnabled()) return result;
+
+		markVectorSubstitutionFailed(result);
+		result.attempted = true;
+		result.selectedQueryId = currentQueryId;
+		result.selectedFixtureDir = currentFixtureDir;
+		result.selectedFixtureName = pathBasename(currentFixtureDir);
+		result.workerPath = joinPath(joinPath(batchOutputDir,
+											  result.selectedFixtureName),
+									 "overlaps.tsv");
+		result.cpuRecords = currentCpuOverlaps.size();
+
+		addVectorSubstitutionCheck(result, "explicit_vector_substitution_mode",
+								   result.mode == "verified-overlap-range-v0",
+								   "CUFLYE_OVERLAP_VECTOR_SUBSTITUTION_MODE=verified-overlap-range-v0");
+		addVectorSubstitutionCheck(result, "object_rehydration_passed",
+								   objectRehydration.status == "passed" &&
+									   objectRehydration.eligible,
+								   "M4q object rehydration must pass");
+		addVectorSubstitutionCheck(result, "selected_fixture_available",
+								   !currentFixtureDir.empty(),
+								   "selected overlap fixture must be available");
+		addVectorSubstitutionCheck(result, "fixture_count_matches_request",
+								   fixtures.size() == overlapReplayMaxFixtures(),
+								   "captured fixture count must match request");
+		addVectorSubstitutionCheck(result, "selected_query_is_current_capture",
+								   !overlapReplayCapturedQueryIds().empty() &&
+									   overlapReplayCapturedQueryIds().back() ==
+										   currentQueryId,
+								   "substitution is limited to the current captured query");
+		addVectorSubstitutionCheck(result, "cpu_kmer_matches_absent",
+								   !overlapRangesHaveKmerMatches(currentCpuOverlaps),
+								   "M4r substitution requires CPU OverlapRange kmerMatches to be unset");
+		addVectorSubstitutionCheck(result, "audit_metadata_available",
+								   !substitutionJson.empty(),
+								   "vector substitution audit JSON path must be available");
+
+		if (!allVectorSubstitutionChecksPassed(result)) return result;
+
+		try
+		{
+			auto workerRecords = readCanonicalOverlapDump(result.workerPath);
+			result.workerRecords = workerRecords.size();
+			auto typedRecords = rehydrateTypedOverlapRecords(workerRecords,
+															 result.workerPath);
+			auto objectRecords = rehydrateOverlapRangeObjects(typedRecords);
+			if (result.proofFault == "drop-first-substitution-overlap" &&
+				!objectRecords.empty())
+			{
+				objectRecords.erase(objectRecords.begin());
+				result.proofFaultApplied = true;
+			}
+			result.objectRecords = objectRecords.size();
+
+			auto cpuRecords = canonicalOverlapRecordsFromRanges(currentCpuOverlaps);
+			auto objectDumpRecords = canonicalOverlapRecordsFromRanges(objectRecords);
+			if (cpuRecords != objectDumpRecords)
+			{
+				result.error =
+					"verified substitution object vector differs from current CPU overlaps";
+				return result;
+			}
+
+			result.status = "passed";
+			result.state = "consumed";
+			result.decision = "verified-overlap-range-vector-substituted";
+			result.selectedOverlapSource = "worker-overlap-range-object-vector";
+			result.eligible = true;
+			result.accepted = true;
+			result.consumed = true;
+			result.notConsumed = false;
+			result.failedClosed = false;
+			result.graphFacingReturnedWorkerOutput = true;
+			result.graphMutationConsumedWorkerOutput = true;
+			result.overlaps = objectRecords;
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+		}
+
 		return result;
 	}
 
