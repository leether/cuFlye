+	std::string overlapWorkerVectorSubstitutionMode()
+	{
+		static std::string mode = []()
+		{
+			const char* raw = std::getenv("CUFLYE_OVERLAP_VECTOR_SUBSTITUTION_MODE");
+			if (!raw || !raw[0]) return std::string();
+			std::string selected(raw);
+			if (selected != "verified-overlap-range-v0")
+			{
+				throw std::runtime_error(
+					"Unsupported CUFLYE_OVERLAP_VECTOR_SUBSTITUTION_MODE: " +
+					selected);
+			}
+			return selected;
+		}();
+		return mode;
+	}
+
+	bool overlapWorkerVectorSubstitutionEnabled()
+	{
