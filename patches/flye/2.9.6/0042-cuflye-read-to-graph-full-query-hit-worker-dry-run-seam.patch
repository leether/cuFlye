+	std::vector<ReadToGraphRawOverlapRowKey> readToGraphRawOverlapRowKeys(
+		const std::string& path)
+	{
+		std::ifstream input(path);
+		if (!input)
+		{
+			throw std::runtime_error("Can't open read-to-graph raw-overlap TSV: " +
+									 path);
+		}
+		std::string schema;
+		std::string header;
+		if (!std::getline(input, schema) ||
+			schema != "# schema=cuflye-read-to-graph-raw-overlap-v0")
+		{
+			throw std::runtime_error(path + ": unexpected raw-overlap schema");
+		}
+		const char* expectedHeader =
+			"query_id\tsource_order\traw_overlap_count\tchain_input_count\t"
+			"read_id\tread_begin\tread_end\tread_len\tedge_seq_id\t"
+			"edge_begin\tedge_end\tedge_len\tedge_id\tscore\t"
+			"seq_divergence\tpasses_chain_input_filter";
+		if (!std::getline(input, header) || header != expectedHeader)
+		{
+			throw std::runtime_error(path + ": unexpected raw-overlap header");
+		}
+
+		std::vector<ReadToGraphRawOverlapRowKey> keys;
+		std::string line;
+		size_t lineNumber = 2;
+		while (std::getline(input, line))
+		{
+			++lineNumber;
+			if (!line.empty() && line.back() == '\r') line.pop_back();
+			if (line.empty()) continue;
+			keys.push_back(parseReadToGraphRawOverlapRowKey(
+				readAlignmentSplitTab(line), path, lineNumber));
+		}
+		return keys;
+	}
+
+	std::vector<ReadToGraphRawOverlapRowKey>
+	readToGraphOracleRawOverlapRowKeys(const std::vector<int64_t>& queryIds)
+	{
+		std::vector<ReadToGraphRawOverlapRowKey> keys;
+		for (auto queryId : queryIds)
+		{
+			std::string path = joinReplayPath(
+				readToGraphSourcePackQueryDir(queryId), "raw-overlaps.tsv");
+			auto queryKeys = readToGraphRawOverlapRowKeys(path);
+			keys.insert(keys.end(), queryKeys.begin(), queryKeys.end());
+		}
+		return keys;
+	}
+
+	ReadToGraphRawOverlapRowKeyDiff compareReadToGraphRawOverlapRowKeys(
+		const std::vector<ReadToGraphRawOverlapRowKey>& leftInput,
+		const std::vector<ReadToGraphRawOverlapRowKey>& rightInput)
+	{
+		ReadToGraphRawOverlapRowKeyDiff diff;
+		diff.leftRecords = leftInput.size();
+		diff.rightRecords = rightInput.size();
+		diff.orderedMatched = leftInput == rightInput;
+		std::vector<ReadToGraphRawOverlapRowKey> left = leftInput;
+		std::vector<ReadToGraphRawOverlapRowKey> right = rightInput;
+		std::sort(left.begin(), left.end());
+		std::sort(right.begin(), right.end());
+
+		size_t leftIdx = 0;
+		size_t rightIdx = 0;
+		while (leftIdx < left.size() || rightIdx < right.size())
+		{
+			if (leftIdx < left.size() && rightIdx < right.size() &&
+				left[leftIdx] == right[rightIdx])
+			{
+				++diff.matchedRows;
+				++leftIdx;
+				++rightIdx;
+			}
+			else if (rightIdx == right.size() ||
+					 (leftIdx < left.size() && left[leftIdx] < right[rightIdx]))
+			{
+				++diff.missingRows;
+				if (diff.missingExamples.size() < 5)
+				{
+					diff.missingExamples.push_back(
+						readToGraphRawOverlapRowKeyText(left[leftIdx]));
+				}
+				++leftIdx;
+			}
+			else
+			{
+				++diff.extraRows;
+				if (diff.extraExamples.size() < 5)
+				{
+					diff.extraExamples.push_back(
+						readToGraphRawOverlapRowKeyText(right[rightIdx]));
+				}
+				++rightIdx;
+			}
+		}
+		diff.matched = diff.missingRows == 0 &&
+			diff.extraRows == 0 &&
+			diff.leftRecords == diff.rightRecords;
+		return diff;
 	}
 
