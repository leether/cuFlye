+	void runReadToGraphFullQueryHitWorkerDryRunSeam()
+	{
+		if (!readToGraphFullQueryHitWorkerDryRunEnabled()) return;
+
+		ReadToGraphFullQueryHitWorkerDryRunResult result;
+		result.mode = readToGraphFullQueryHitWorkerMode();
+		result.sourcePackDir = std::string(readToGraphSourcePackDir());
+		result.workerOutputRoot = readAlignmentRequiredEnv(
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_WORKER_OUTPUT_DIR");
+		result.workerRequestJson = joinReplayPath(
+			result.workerOutputRoot, "full-query-hit-worker-request.json");
+		result.workerResponseJson = joinReplayPath(
+			result.workerOutputRoot, "full-query-hit-worker-response.json");
+		result.workerOutputTsv = joinReplayPath(
+			result.workerOutputRoot, "full-query-hit-worker.raw-overlaps.tsv");
+		result.stdoutLog = joinReplayPath(
+			result.workerOutputRoot, "full-query-hit-worker-stdout.log");
+		result.stderrLog = joinReplayPath(
+			result.workerOutputRoot, "full-query-hit-worker-stderr.log");
+		result.auditJson = joinReplayPath(
+			result.workerOutputRoot,
+			"full-query-hit-worker-dry-run.json");
+		result.queryIds = sortedReadToGraphSourcePackQueryIds();
+		ensureReplayDirectory(result.workerOutputRoot);
+
+		try
+		{
+			auto oracleKeys =
+				readToGraphOracleRawOverlapRowKeys(result.queryIds);
+			result.expectedOutputRecords = oracleKeys.size();
+			result.diff.leftRecords = oracleKeys.size();
+			if (result.expectedOutputRecords == 0)
+			{
+				throw std::runtime_error(
+					"selected read-to-graph source pack has zero raw-overlap "
+					"oracle records");
+			}
+			writeReadToGraphFullQueryHitWorkerRequestJson(
+				result.workerRequestJson,
+				"read-to-graph-full-query-hit-dry-run",
+				result.sourcePackDir,
+				result.workerOutputTsv,
+				result.workerResponseJson,
+				result.expectedOutputRecords);
