+	void markReadToGraphFullQueryHitWorkerDryRunFailed(
+		ReadToGraphFullQueryHitWorkerDryRunResult& result,
+		const std::string& error)
+	{
+		if (result.diff.leftRecords > 0 &&
+			result.diff.rightRecords == 0 &&
+			result.diff.matchedRows == 0 &&
+			result.diff.missingRows == 0)
+		{
+			result.diff.missingRows = result.diff.leftRecords;
+		}
+		result.status = "failed-before-graph-mutation";
+		result.decision = "fail-closed-before-graph-mutation";
+		result.failedClosed = true;
+		result.graphMutationConsumedWorkerOutput = false;
+		result.workerOutputConsumptionEligible = false;
+		result.error = error;
+	}
