+	int64_t parseReadToGraphRawOverlapInt64(
+		const std::string& text, const std::string& fieldName,
+		const std::string& path, size_t lineNumber)
+	{
+		size_t parsedChars = 0;
+		int64_t value = std::stoll(text, &parsedChars);
+		if (parsedChars != text.size())
+		{
+			throw std::runtime_error(
+				path + ":" + std::to_string(lineNumber) + ": " + fieldName +
+				" must be a decimal integer");
+		}
+		return value;
+	}
+
+	ReadToGraphRawOverlapRowKey parseReadToGraphRawOverlapRowKey(
+		const std::vector<std::string>& fields,
+		const std::string& path,
+		size_t lineNumber)
+	{
+		if (fields.size() != 16)
+		{
+			throw std::runtime_error(
+				path + ":" + std::to_string(lineNumber) +
+				": raw-overlap row must have 16 fields");
+		}
+		ReadToGraphRawOverlapRowKey key;
+		key.queryId = parseReadToGraphRawOverlapInt64(
+			fields[0], "query_id", path, lineNumber);
+		key.readId = parseReadToGraphRawOverlapInt64(
+			fields[4], "read_id", path, lineNumber);
+		key.readBegin = parseReadToGraphRawOverlapInt64(
+			fields[5], "read_begin", path, lineNumber);
+		key.readEnd = parseReadToGraphRawOverlapInt64(
+			fields[6], "read_end", path, lineNumber);
+		key.readLen = parseReadToGraphRawOverlapInt64(
+			fields[7], "read_len", path, lineNumber);
+		key.edgeSeqId = parseReadToGraphRawOverlapInt64(
+			fields[8], "edge_seq_id", path, lineNumber);
+		key.edgeBegin = parseReadToGraphRawOverlapInt64(
+			fields[9], "edge_begin", path, lineNumber);
+		key.edgeEnd = parseReadToGraphRawOverlapInt64(
+			fields[10], "edge_end", path, lineNumber);
+		key.edgeLen = parseReadToGraphRawOverlapInt64(
+			fields[11], "edge_len", path, lineNumber);
+		key.score = parseReadToGraphRawOverlapInt64(
+			fields[13], "score", path, lineNumber);
+		return key;
+	}
