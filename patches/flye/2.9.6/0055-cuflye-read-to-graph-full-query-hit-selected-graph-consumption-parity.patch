+	bool allReadToGraphFullQueryHitSelectedGraphConsumptionParityChecksPassed(
+		const ReadToGraphFullQueryHitSelectedGraphConsumptionParityResult& parity)
+	{
+		for (const auto& check : parity.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !parity.checks.empty();
+	}
+
+	void addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+		ReadToGraphFullQueryHitSelectedGraphConsumptionParityResult& parity,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		parity.checks.push_back(check);
+	}
