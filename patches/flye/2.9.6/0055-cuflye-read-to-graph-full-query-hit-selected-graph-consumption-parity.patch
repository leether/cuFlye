+	ReadToGraphFullQueryHitSelectedGraphConsumptionParityResult
+	evaluateReadToGraphFullQueryHitSelectedGraphConsumptionParity(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult& smoke,
+		RepeatGraph& graph)
+	{
+		ReadToGraphFullQueryHitSelectedGraphConsumptionParityResult result;
+		result.mode =
+			readToGraphFullQueryHitSelectedGraphConsumptionParityMode();
+		result.proofFault =
+			readToGraphFullQueryHitSelectedGraphConsumptionParityProofFault();
+		result.selectedCpuBypassSmokeStatus = smoke.status;
+		result.graphMutationConsumedWorkerOutput =
+			dryRun.graphMutationConsumedWorkerOutput;
+		if (!readToGraphFullQueryHitSelectedGraphConsumptionParityEnabled())
+		{
+			return result;
+		}
+
+		auto parityStart = std::chrono::steady_clock::now();
+		markReadToGraphFullQueryHitSelectedGraphConsumptionParityFailed(result);
+		addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+			result, "explicit_selected_graph_consumption_parity_mode",
+			result.mode == "selected-graph-consumption-parity-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SELECTED_GRAPH_CONSUMPTION_PARITY_MODE="
+			"selected-graph-consumption-parity-v0");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+			result, "selected_cpu_bypass_smoke_passed",
+			smoke.status == "passed" && smoke.eligible &&
+				!smoke.failedClosed,
+			"M6y selected CPU-bypass smoke must pass before graph-consumption parity");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+			result, "selected_cpu_bypass_smoke_timed",
+			smoke.selectedCpuBypassSmokeTotalMs > 0.0 &&
+				smoke.selectedCpuSkipAccountingMs > 0.0 &&
+				smoke.cudaSupplierHandoffMs > 0.0,
+			"M6z selected CPU-bypass timing attribution must be recorded");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+			result, "selected_cpu_bypass_smoke_row_keys_matched",
+			smoke.finalMergedRowKeyMatched &&
+				smoke.finalMergedOrderedRowKeyMatched,
+			"M6y final merged ledger must match CPU oracle row keys");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+			result, "graph_not_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have reached graph mutation");
+
+		if (!allReadToGraphFullQueryHitSelectedGraphConsumptionParityChecksPassed(
+				result))
+		{
+			result.error =
+				"selected graph-consumption parity preconditions failed";
+			result.graphConsumptionParityTotalMs = readAlignmentElapsedMs(
+				parityStart, std::chrono::steady_clock::now());
+			return result;
+		}
+
+		try
+		{
+			auto graphFacingStart = std::chrono::steady_clock::now();
+			result.totalCpuRawOverlapRows = smoke.totalCpuRawOverlapRows;
+			result.finalMergedLedgerRows = smoke.finalMergedLedgerRows;
+			result.finalMergedRowKeyMatched = smoke.finalMergedRowKeyMatched;
+			result.finalMergedOrderedRowKeyMatched =
+				smoke.finalMergedOrderedRowKeyMatched;
+			result.graphFacingLedger = smoke.finalMergedLedger;
+			if (result.proofFault == "drop-first-graph-facing-row" &&
+				!result.graphFacingLedger.empty())
+			{
+				result.graphFacingLedger.erase(result.graphFacingLedger.begin());
+				result.droppedGraphFacingRows = 1;
+				result.proofFaultApplied = true;
+			}
+			for (const auto& row : result.graphFacingLedger)
+			{
+				if (row.decision == "cuda-supplied-selected-bypass")
+				{
+					++result.graphFacingCudaSuppliedRows;
+				}
+				else if (row.decision == "cpu-owned")
+				{
+					++result.graphFacingCpuOwnedRows;
+				}
+				if (row.edgeId == 0 ||
+					graph.getEdge(checkedReadAlignmentFastaIdFromSigned(
+						row.edgeId, "edge_id", dryRun.workerOutputTsv)) == nullptr)
+				{
+					++result.missingGraphEdgeRows;
+				}
+			}
+			result.graphFacingRows = result.graphFacingLedger.size();
+			result.graphFacingBuildMs = readAlignmentElapsedMs(
+				graphFacingStart, std::chrono::steady_clock::now());
+
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "final_merged_ledger_rows_present",
+				result.finalMergedLedgerRows > 0,
+				"final merged ledger rows must be nonzero");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "graph_facing_rows_match_final_merged_ledger",
+				result.graphFacingRows == result.finalMergedLedgerRows,
+				"graph-facing handoff must account for every final merged row");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "graph_facing_cuda_rows_match_smoke",
+				result.graphFacingCudaSuppliedRows ==
+					smoke.finalCudaSuppliedRows,
+				"graph-facing handoff must preserve CUDA-supplied selected rows");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "graph_facing_cpu_owned_rows_match_smoke",
+				result.graphFacingCpuOwnedRows == smoke.cpuOwnedResidualRows,
+				"graph-facing handoff must preserve CPU-owned residual rows");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "graph_facing_rows_have_live_edges",
+				result.missingGraphEdgeRows == 0,
+				"every graph-facing row must bind to a live GraphEdge");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "dropped_graph_facing_rows_zero",
+				result.droppedGraphFacingRows == 0,
+				"graph-facing handoff must not drop selected or CPU-owned rows");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "graph_facing_build_timed",
+				result.graphFacingBuildMs > 0.0,
+				"graph-facing parity build timing must be recorded");
+			result.graphConsumptionParityTotalMs = readAlignmentElapsedMs(
+				parityStart, std::chrono::steady_clock::now());
+			addReadToGraphFullQueryHitSelectedGraphConsumptionParityCheck(
+				result, "graph_consumption_parity_total_timed",
+				result.graphConsumptionParityTotalMs > 0.0,
+				"graph-consumption parity total timing must be recorded");
+
+			if (allReadToGraphFullQueryHitSelectedGraphConsumptionParityChecksPassed(
+					result))
+			{
+				result.status = "passed";
+				result.state = "not-consumed";
+				result.decision =
+					"selected-graph-consumption-parity-written-not-consumed";
+				result.eligible = true;
+				result.consumed = false;
+				result.notConsumed = true;
+				result.failedClosed = false;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"selected graph-consumption parity differs from M6y smoke";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			result.graphConsumptionParityTotalMs = readAlignmentElapsedMs(
+				parityStart, std::chrono::steady_clock::now());
+			markReadToGraphFullQueryHitSelectedGraphConsumptionParityFailed(
+				result);
+		}
+		return result;
+	}
