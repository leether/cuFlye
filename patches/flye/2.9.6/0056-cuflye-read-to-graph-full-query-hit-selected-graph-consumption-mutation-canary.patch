+	void markReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryFailed(
+		ReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryResult& canary)
+	{
+		canary.status = "failed";
+		canary.state = "failed-closed";
+		canary.decision = "failed-closed-before-graph-mutation-commit";
+		canary.eligible = false;
+		canary.accepted = false;
+		canary.consumed = false;
+		canary.failedClosed = true;
+		canary.graphMutationConsumedWorkerOutput = false;
+	}
+
+	bool allReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryChecksPassed(
+		const ReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryResult& canary)
+	{
+		for (const auto& check : canary.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !canary.checks.empty();
+	}
+
+	void addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+		ReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryResult& canary,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		ReadToGraphFullQueryHitSelectedBypassPlanCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		canary.checks.push_back(check);
+	}
+
+	std::vector<GraphAlignment> complementReadToGraphMutationCanaryChains(
+		const std::vector<GraphAlignment>& chains,
+		RepeatGraph& graph)
+	{
+		std::vector<GraphAlignment> complChains(chains);
+		for (auto& chain : complChains)
+		{
+			for (auto& aln : chain)
+			{
+				aln.edge = graph.complementEdge(aln.edge);
+				aln.overlap = aln.overlap.complement();
+			}
+			std::reverse(chain.begin(), chain.end());
+		}
+		return complChains;
+	}
+
+	typedef std::function<std::vector<GraphAlignment>(
+		const std::vector<EdgeAlignment>&)> ReadToGraphMutationCanaryChainBuilder;
+	typedef std::function<float(const GraphAlignment&, bool)>
+		ReadToGraphMutationCanaryDivergenceComputer;
+
+	struct ReadToGraphMutationCanaryReplacement
+	{
+		int64_t queryId = 0;
+		std::vector<GraphAlignment> chains;
+	};
+
+	ReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryResult
+	evaluateReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanary(
+		const ReadToGraphFullQueryHitWorkerDryRunResult& dryRun,
+		const ReadToGraphFullQueryHitSelectedCpuBypassSmokeResult& smoke,
+		const ReadToGraphFullQueryHitSelectedGraphConsumptionParityResult& parity,
+		RepeatGraph& graph,
+		std::vector<GraphAlignment>& readAlignments,
+		const ReadToGraphMutationCanaryChainBuilder& buildChains,
+		const ReadToGraphMutationCanaryDivergenceComputer& computeDivergence)
+	{
+		ReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryResult result;
+		result.mode =
+			readToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryMode();
+		result.proofFault =
+			readToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryProofFault();
+		result.selectedGraphConsumptionParityStatus = parity.status;
+		if (!readToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryEnabled())
+		{
+			return result;
+		}
+
+		auto totalStart = std::chrono::steady_clock::now();
+		result.attempted = true;
+		result.totalReadAlignmentsBefore = readAlignments.size();
+		result.totalReadAlignmentsAfter = result.totalReadAlignmentsBefore;
+		markReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryFailed(
+			result);
+		addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+			result, "explicit_selected_graph_consumption_mutation_canary_mode",
+			result.mode == "selected-graph-consumption-mutation-canary-v0",
+			"CUFLYE_READ_TO_GRAPH_FULL_QUERY_HIT_SELECTED_GRAPH_CONSUMPTION_MUTATION_CANARY_MODE="
+			"selected-graph-consumption-mutation-canary-v0");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+			result, "selected_graph_consumption_parity_passed",
+			parity.status == "passed" && parity.eligible &&
+				!parity.failedClosed,
+			"M7a selected graph-consumption parity must pass before mutation canary");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+			result, "selected_cpu_bypass_smoke_passed",
+			smoke.status == "passed" && smoke.eligible &&
+				!smoke.failedClosed,
+			"M6y selected CPU-bypass smoke must pass before mutation canary");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+			result, "worker_output_readable",
+			dryRun.workerOutputReadable,
+			"validated worker raw-overlap TSV must be readable");
+		addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+			result, "graph_not_previously_mutated",
+			!dryRun.graphMutationConsumedWorkerOutput,
+			"worker output must not have been consumed before M7b canary");
+
+		if (!allReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryChecksPassed(
+				result))
+		{
+			result.error =
+				"selected graph-consumption mutation canary preconditions failed";
+			result.totalMs = readAlignmentElapsedMs(
+				totalStart, std::chrono::steady_clock::now());
+			return result;
+		}
+
+		try
+		{
+			auto rebuildStart = std::chrono::steady_clock::now();
+			auto workerRecords = readToGraphRawOverlapRecords(dryRun.workerOutputTsv);
+			result.workerRecords = workerRecords.size();
+			std::map<int64_t, std::vector<ReadToGraphRawOverlapRecord> >
+				recordsByQuery;
+			for (const auto& record : workerRecords)
+			{
+				if (!record.passesChainInputFilter) continue;
+				++result.chainInputRows;
+				if (record.edgeId == 0)
+				{
+					++result.missingGraphEdgeRows;
+					continue;
+				}
+				recordsByQuery[record.queryId].push_back(record);
+			}
+			result.selectedQueryCount = recordsByQuery.size();
+
+			std::vector<ReadToGraphMutationCanaryReplacement> replacements;
+			for (auto& item : recordsByQuery)
+			{
+				std::vector<EdgeAlignment> edgeAlignments;
+				edgeAlignments.reserve(item.second.size());
+				for (const auto& record : item.second)
+				{
+					GraphEdge* edge = graph.getEdge(
+						checkedReadAlignmentFastaIdFromSigned(
+							record.edgeId, "edge_id", dryRun.workerOutputTsv));
+					if (!edge)
+					{
+						++result.missingGraphEdgeRows;
+						continue;
+					}
+					edgeAlignments.push_back({record.overlap, edge});
+				}
+				std::sort(edgeAlignments.begin(), edgeAlignments.end(),
+					[](const EdgeAlignment& left, const EdgeAlignment& right)
+					{return left.overlap.curBegin < right.overlap.curBegin;});
+
+				auto preDivergenceChains = buildChains(edgeAlignments);
+				result.rebuiltPreDivergenceChains +=
+					preDivergenceChains.size();
+				std::vector<GraphAlignment> goodChains;
+				for (const auto& chain : preDivergenceChains)
+				{
+					float divergence = computeDivergence(
+						chain, (bool)Config::get("reads_base_alignment"));
+					if (divergence <
+						static_cast<float>(
+							Config::get("read_align_ovlp_divergence")))
+					{
+						goodChains.push_back(chain);
+					}
+				}
+				if (result.proofFault == "drop-first-canary-chain" &&
+					!result.proofFaultApplied && !goodChains.empty())
+				{
+					goodChains.erase(goodChains.begin());
+					result.proofFaultApplied = true;
+				}
+				result.rebuiltGoodChains += goodChains.size();
+				result.rebuiltGoodRecords +=
+					canonicalReadAlignmentRecordsFromGraphAlignments(
+						goodChains).size();
+
+				ReadToGraphMutationCanaryReplacement replacement;
+				replacement.queryId = item.first;
+				replacement.chains = goodChains;
+				replacements.push_back(replacement);
+			}
+			result.rebuildMs = readAlignmentElapsedMs(
+				rebuildStart, std::chrono::steady_clock::now());
+
+			auto compareStart = std::chrono::steady_clock::now();
+			bool allSelectedRecordsMatched = !replacements.empty();
+			for (const auto& replacement : replacements)
+			{
+				auto cpuSlice = readAlignmentCpuSliceForQuery(
+					readAlignments, replacement.queryId);
+				result.cpuSliceChains += cpuSlice.size();
+				auto cpuRecords =
+					canonicalReadAlignmentRecordsFromGraphAlignments(cpuSlice);
+				auto canaryRecords =
+					canonicalReadAlignmentRecordsFromGraphAlignments(
+						replacement.chains);
+				result.cpuSliceRecords += cpuRecords.size();
+				if (cpuRecords != canaryRecords)
+				{
+					allSelectedRecordsMatched = false;
+				}
+			}
+			result.selectedCanaryRecordsMatched = allSelectedRecordsMatched;
+			result.compareMs = readAlignmentElapsedMs(
+				compareStart, std::chrono::steady_clock::now());
+
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "selected_queries_present",
+				result.selectedQueryCount > 0,
+				"mutation canary requires at least one selected query");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "worker_records_present",
+				result.workerRecords > 0 && result.chainInputRows > 0,
+				"worker raw-overlap TSV must provide chain-input rows");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "worker_rows_have_live_edges",
+				result.missingGraphEdgeRows == 0,
+				"all canary rows must bind to live GraphEdge objects");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "rebuilt_good_chains_present",
+				result.rebuiltGoodChains > 0 && result.rebuiltGoodRecords > 0,
+				"canary must rebuild nonzero Flye goodChains");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "cpu_slice_present",
+				result.cpuSliceChains > 0 && result.cpuSliceRecords > 0,
+				"existing _readAlignments must contain the selected CPU/GPU slice");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "selected_canary_records_match_cpu_slice",
+				result.selectedCanaryRecordsMatched,
+				"full-query-hit rebuilt selected goodChains must match _readAlignments slice");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "proof_fault_not_applied",
+				!result.proofFaultApplied,
+				"no mutation canary proof fault may be applied in the positive path");
+
+			if (!allReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryChecksPassed(
+					result))
+			{
+				result.error =
+					"selected graph-consumption mutation canary records differ";
+				result.totalMs = readAlignmentElapsedMs(
+					totalStart, std::chrono::steady_clock::now());
+				return result;
+			}
+
+			auto substitutionStart = std::chrono::steady_clock::now();
+			auto beforeRecords =
+				canonicalReadAlignmentRecordsFromGraphAlignments(readAlignments);
+			std::vector<GraphAlignment> substitutedAlignments(readAlignments);
+			std::vector<size_t> forwardOffsets(replacements.size(), 0);
+			std::vector<size_t> complementOffsets(replacements.size(), 0);
+			std::vector<std::vector<GraphAlignment> > complementReplacements;
+			complementReplacements.reserve(replacements.size());
+			for (const auto& replacement : replacements)
+			{
+				complementReplacements.push_back(
+					complementReadToGraphMutationCanaryChains(
+						replacement.chains, graph));
+			}
+			for (auto& chain : substitutedAlignments)
+			{
+				if (chain.empty()) continue;
+				int64_t queryId = chain.front().overlap.curId.signedId();
+				for (size_t index = 0; index < replacements.size(); ++index)
+				{
+					if (queryId == replacements[index].queryId)
+					{
+						size_t& offset = forwardOffsets[index];
+						if (offset >= replacements[index].chains.size())
+						{
+							throw std::runtime_error(
+								"M7b forward replacement count mismatch for query " +
+								std::to_string(queryId));
+						}
+						chain = replacements[index].chains[offset];
+						++offset;
+						++result.substitutedForwardChains;
+						break;
+					}
+					if (queryId == -replacements[index].queryId)
+					{
+						size_t& offset = complementOffsets[index];
+						if (offset >= complementReplacements[index].size())
+						{
+							throw std::runtime_error(
+								"M7b complement replacement count mismatch for query " +
+								std::to_string(queryId));
+						}
+						chain = complementReplacements[index][offset];
+						++offset;
+						++result.substitutedComplementChains;
+						break;
+					}
+				}
+			}
+			for (size_t index = 0; index < replacements.size(); ++index)
+			{
+				if (forwardOffsets[index] != replacements[index].chains.size())
+				{
+					throw std::runtime_error(
+						"M7b did not replace every forward selected chain for query " +
+						std::to_string(replacements[index].queryId));
+				}
+				if (complementOffsets[index] !=
+					complementReplacements[index].size())
+				{
+					throw std::runtime_error(
+						"M7b did not replace every complement selected chain for query " +
+						std::to_string(replacements[index].queryId));
+				}
+			}
+			auto afterRecords =
+				canonicalReadAlignmentRecordsFromGraphAlignments(
+					substitutedAlignments);
+			result.finalAlignmentRecordsMatched = beforeRecords == afterRecords;
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "forward_selected_chains_substituted",
+				result.substitutedForwardChains == result.rebuiltGoodChains,
+				"every rebuilt selected forward goodChain must be substituted");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "complement_selected_chains_substituted",
+				result.substitutedComplementChains == result.rebuiltGoodChains,
+				"every selected complement goodChain must be substituted");
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "final_alignment_records_match_before_substitution",
+				result.finalAlignmentRecordsMatched,
+				"guarded substitution must preserve canonical _readAlignments records");
+			result.substitutionMs = readAlignmentElapsedMs(
+				substitutionStart, std::chrono::steady_clock::now());
+			addReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryCheck(
+				result, "substitution_timed",
+				result.substitutionMs > 0.0,
+				"mutation canary substitution timing must be recorded");
+
+			if (allReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryChecksPassed(
+					result))
+			{
+				readAlignments.swap(substitutedAlignments);
+				result.totalReadAlignmentsAfter = readAlignments.size();
+				result.status = "passed";
+				result.state = "consumed";
+				result.decision =
+					"selected-graph-consumption-mutation-canary-substituted";
+				result.eligible = true;
+				result.accepted = true;
+				result.consumed = true;
+				result.failedClosed = false;
+				result.graphMutationConsumedWorkerOutput = true;
+				result.error.clear();
+			}
+			else
+			{
+				result.error =
+					"selected graph-consumption mutation canary substitution failed";
+			}
+		}
+		catch (const std::exception& exc)
+		{
+			result.error = exc.what();
+			markReadToGraphFullQueryHitSelectedGraphConsumptionMutationCanaryFailed(
