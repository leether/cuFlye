+
+	std::string jsonEscape(const std::string& text)
+	{
+		std::ostringstream escaped;
+		for (char ch : text)
+		{
+			switch (ch)
+			{
+			case '\\': escaped << "\\\\"; break;
+			case '"': escaped << "\\\""; break;
+			case '\n': escaped << "\\n"; break;
+			case '\r': escaped << "\\r"; break;
+			case '\t': escaped << "\\t"; break;
+			default: escaped << ch; break;
+			}
+		}
+		return escaped.str();
+	}
