+	void maybeInvokeOverlapWorker(const std::string& dumpRoot, size_t dumpIndex)
+	{
+		if (!overlapWorkerEnabled()) return;
+		if (dumpIndex + 1 < overlapReplayMaxFixtures()) return;
+
+		auto& fixtures = overlapReplayCapturedFixtures();
+		if (fixtures.empty())
+		{
+			throw std::runtime_error("cuFlye overlap worker seam has no fixtures");
+		}
+
+		std::string workerBin = overlapEnvRequired("CUFLYE_OVERLAP_WORKER_BIN");
+		std::string outputRoot = overlapWorkerOutputDir(dumpRoot);
+		ensureDirectory(outputRoot);
+
+		std::string fixtureList = joinPath(outputRoot, "worker-fixtures.txt");
+		std::string requestJson = joinPath(outputRoot, "worker-request.json");
+		std::string responseJson = joinPath(outputRoot, "worker-response.json");
+		std::string batchJson = joinPath(outputRoot, "worker-batch.json");
+		std::string batchOutputDir = joinPath(outputRoot, "worker-output");
+		std::string stdoutLog = joinPath(outputRoot, "worker-stdout.log");
+		std::string stderrLog = joinPath(outputRoot, "worker-stderr.log");
+		std::string seamSummary = joinPath(outputRoot, "seam-summary.json");
+		std::string requestId = "flye-overlap-worker-" + std::to_string(fixtures.size());
+
+		writeOverlapWorkerFixtureList(fixtureList, fixtures);
+		writeOverlapWorkerRequestJson(requestJson, requestId, fixtureList,
+									  batchOutputDir, batchJson, responseJson,
+									  fixtures.size());
+
+		std::string command = shellQuote(workerBin) + " --worker-request-json " +
+							  shellQuote(requestJson) + " > " + shellQuote(stdoutLog) +
+							  " 2> " + shellQuote(stderrLog);
+		int status = std::system(command.c_str());
+		if (status != 0)
+		{
+			throw std::runtime_error(
+				"cuFlye overlap worker seam fail-closed; worker exited non-zero; "
+				"request_json=" + requestJson + "; response_json=" + responseJson);
+		}
+		ensureReadableFile(responseJson, "overlap worker response JSON");
+		writeOverlapWorkerSeamSummary(seamSummary, requestJson, responseJson,
+									  fixtureList, batchJson, batchOutputDir,
+									  fixtures.size());
+		throw std::runtime_error(
+			"cuFlye overlap worker seam stopped before graph mutation; "
+			"request_json=" + requestJson + "; response_json=" + responseJson +
+			"; seam_summary=" + seamSummary);
+	}
