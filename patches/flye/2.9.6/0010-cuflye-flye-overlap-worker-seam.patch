+	void ensureParentDirectory(const std::string& path)
+	{
+		size_t slash = path.find_last_of('/');
+		if (slash == std::string::npos || slash == 0) return;
+		ensureDirectory(path.substr(0, slash));
+	}
+
+	void writeTextFile(const std::string& path, const std::string& text)
+	{
+		ensureParentDirectory(path);
+		std::ofstream output(path);
+		if (!output)
+		{
+			throw std::runtime_error("cuFlye overlap worker seam cannot write: " +
+									 path);
+		}
+		output << text;
+	}
+
+	std::string overlapWorkerOutputDir(const std::string& dumpRoot)
+	{
+		const char* outputDir = std::getenv("CUFLYE_OVERLAP_WORKER_OUTPUT_DIR");
+		if (outputDir && outputDir[0]) return outputDir;
+		if (overlapWorkerEnabled())
+		{
+			return overlapEnvRequired("CUFLYE_OVERLAP_WORKER_OUTPUT_DIR");
+		}
+		return joinPath(dumpRoot, "overlap-worker");
