+			overlapEnvRequired("CUFLYE_OVERLAP_WORKER_OUTPUT_DIR");
+			const auto& queryIds = overlapReplayQueryIds();
+			if (!queryIds.empty() && overlapReplayMaxFixtures() != queryIds.size())
+			{
+				throw std::runtime_error(
+					"CUFLYE_OVERLAP_REPLAY_MAX_FIXTURES must equal the number of "
+					"CUFLYE_OVERLAP_REPLAY_QUERY_IDS entries in overlap worker "
+					"allowlist mode");
+			}
+			return true;
+		}();
+		(void)validated;
+	}
