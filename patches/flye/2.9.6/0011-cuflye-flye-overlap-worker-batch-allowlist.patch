+	std::string stripWhitespace(const std::string& text)
+	{
+		std::string stripped;
+		for (char ch : text)
+		{
+			if (!std::isspace(static_cast<unsigned char>(ch))) stripped += ch;
+		}
+		return stripped;
+	}
+
+	std::vector<int64_t> parseOverlapReplayQueryIds(const char* raw)
+	{
+		std::vector<int64_t> ids;
+		if (!raw || !raw[0]) return ids;
+
+		std::stringstream input(raw);
+		std::string token;
+		while (std::getline(input, token, ','))
+		{
+			token = stripWhitespace(token);
+			if (token.empty())
+			{
+				throw std::runtime_error(
+					"CUFLYE_OVERLAP_REPLAY_QUERY_IDS contains an empty query id");
+			}
+			size_t parsedChars = 0;
+			int64_t parsed = std::stoll(token, &parsedChars);
+			if (parsedChars != token.size())
+			{
+				throw std::runtime_error(
+					"CUFLYE_OVERLAP_REPLAY_QUERY_IDS contains a non-integer query id: " +
+					token);
+			}
+			if (std::find(ids.begin(), ids.end(), parsed) != ids.end())
+			{
+				throw std::runtime_error(
+					"CUFLYE_OVERLAP_REPLAY_QUERY_IDS contains a duplicate query id: " +
+					token);
+			}
+			ids.push_back(parsed);
+		}
+		if (ids.empty())
+		{
+			throw std::runtime_error("CUFLYE_OVERLAP_REPLAY_QUERY_IDS is empty");
+		}
+		return ids;
+	}
+
+	const std::vector<int64_t>& overlapReplayQueryIds()
+	{
+		static std::vector<int64_t> ids =
+			parseOverlapReplayQueryIds(std::getenv("CUFLYE_OVERLAP_REPLAY_QUERY_IDS"));
+		return ids;
+	}
+
+	std::string overlapReplayQueryIdsRaw()
+	{
+		static std::string raw = []()
+		{
+			const char* value = std::getenv("CUFLYE_OVERLAP_REPLAY_QUERY_IDS");
+			return value && value[0] ? std::string(value) : std::string();
+		}();
+		return raw;
+	}
+
+	bool overlapReplayQuerySelected(int64_t queryId)
+	{
+		const char* requestedQuery = std::getenv("CUFLYE_OVERLAP_REPLAY_QUERY_ID");
+		const auto& queryIds = overlapReplayQueryIds();
+		if (requestedQuery && requestedQuery[0] && !queryIds.empty())
+		{
+			throw std::runtime_error(
+				"Set only one of CUFLYE_OVERLAP_REPLAY_QUERY_ID or "
+				"CUFLYE_OVERLAP_REPLAY_QUERY_IDS");
+		}
+		if (requestedQuery && requestedQuery[0])
+		{
+			return std::stoll(requestedQuery) == queryId;
+		}
+		if (queryIds.empty()) return true;
+		return std::find(queryIds.begin(), queryIds.end(), queryId) != queryIds.end();
+	}
+
