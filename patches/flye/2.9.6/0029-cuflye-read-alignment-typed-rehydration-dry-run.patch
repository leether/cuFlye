+	void checkReadAlignmentRange(int64_t begin,
+								 int64_t end,
+								 int64_t len,
+								 const std::string& name,
+								 const std::string& path)
+	{
+		if (begin < 0 || end < begin || len < end)
+		{
+			throw std::runtime_error(path + ": invalid " + name +
+									 " begin/end/len range");
+		}
+	}
