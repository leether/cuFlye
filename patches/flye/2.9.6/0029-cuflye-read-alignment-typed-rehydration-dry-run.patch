+	FastaRecord::Id readAlignmentFastaIdFromSigned(int64_t signedId)
+	{
+		if (signedId > 0)
+		{
+			return FastaRecord::Id(static_cast<uint32_t>((signedId - 1) * 2));
+		}
+		return FastaRecord::Id(static_cast<uint32_t>((-signedId) * 2 - 1));
+	}
+
+	FastaRecord::Id checkedReadAlignmentFastaIdFromSigned(
+		int64_t signedId,
+		const std::string& name,
+		const std::string& path)
+	{
+		if (signedId < -static_cast<int64_t>(std::numeric_limits<int32_t>::max()) ||
+			signedId > static_cast<int64_t>(std::numeric_limits<int32_t>::max()) ||
+			signedId == 0)
+		{
+			throw std::runtime_error(path + ": " + name +
+									 " is outside Flye signed-id range");
+		}
+		return readAlignmentFastaIdFromSigned(signedId);
+	}
