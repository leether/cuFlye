+	ReadAlignmentTypedSegment readAlignmentRecordToTypedSegment(
+		const ReadAlignmentDumpRecord& record,
+		RepeatGraph& graph,
+		const std::string& path)
+	{
+		if (record.chainId < 0 || record.segmentId < 0)
+		{
+			throw std::runtime_error(path +
+									 ": chain_id and segment_id must be non-negative");
+		}
+		checkReadAlignmentRange(record.readBegin, record.readEnd, record.readLen,
+								"read", path);
+		checkReadAlignmentRange(record.edgeBegin, record.edgeEnd, record.edgeLen,
+								"edge", path);
+
+		ReadAlignmentTypedSegment typed;
+		typed.chainId = record.chainId;
+		typed.segmentId = record.segmentId;
+
+		OverlapRange overlap;
+		overlap.curId = checkedReadAlignmentFastaIdFromSigned(record.readId,
+															  "read_id", path);
+		overlap.curBegin = checkedReadAlignmentInt32(record.readBegin,
+													 "read_begin", path);
+		overlap.curEnd = checkedReadAlignmentInt32(record.readEnd,
+												   "read_end", path);
+		overlap.curLen = checkedReadAlignmentInt32(record.readLen,
+												   "read_len", path);
+		overlap.extId = checkedReadAlignmentFastaIdFromSigned(record.edgeSeqId,
+															  "edge_seq_id", path);
+		overlap.extBegin = checkedReadAlignmentInt32(record.edgeBegin,
+													 "edge_begin", path);
+		overlap.extEnd = checkedReadAlignmentInt32(record.edgeEnd,
+												   "edge_end", path);
+		overlap.extLen = checkedReadAlignmentInt32(record.edgeLen,
+												   "edge_len", path);
+		overlap.score = checkedReadAlignmentInt32(record.score, "score", path);
+		overlap.seqDivergence = record.seqDivergence;
+
+		FastaRecord::Id edgeId = checkedReadAlignmentFastaIdFromSigned(
+			record.edgeId, "edge_id", path);
+		GraphEdge* edge = graph.getEdge(edgeId);
+		if (!edge)
+		{
+			throw std::runtime_error(path + ": edge_id " +
+									 std::to_string(record.edgeId) +
+									 " is absent from the current repeat graph");
+		}
+		typed.alignment.overlap = overlap;
+		typed.alignment.edge = edge;
+		return typed;
+	}
+
+	std::vector<ReadAlignmentTypedSegment> rehydrateTypedReadAlignmentRecords(
+		const std::vector<ReadAlignmentDumpRecord>& records,
+		RepeatGraph& graph,
+		const std::string& path)
+	{
+		std::vector<ReadAlignmentTypedSegment> typedRecords;
+		typedRecords.reserve(records.size());
+		for (const auto& record : records)
+		{
+			typedRecords.push_back(
+				readAlignmentRecordToTypedSegment(record, graph, path));
+		}
+		return typedRecords;
+	}
+
+	ReadAlignmentDumpRecord readAlignmentTypedSegmentToDumpRecord(
+		const ReadAlignmentTypedSegment& typed)
+	{
+		ReadAlignmentDumpRecord record;
+		const auto& overlap = typed.alignment.overlap;
+		record.chainId = typed.chainId;
+		record.segmentId = typed.segmentId;
+		record.readId = overlap.curId.signedId();
+		record.readBegin = overlap.curBegin;
+		record.readEnd = overlap.curEnd;
+		record.readLen = overlap.curLen;
+		record.edgeId = typed.alignment.edge->edgeId.signedId();
+		record.edgeSeqId = overlap.extId.signedId();
+		record.edgeBegin = overlap.extBegin;
+		record.edgeEnd = overlap.extEnd;
+		record.edgeLen = overlap.extLen;
+		record.score = overlap.score;
+		record.seqDivergence = overlap.seqDivergence;
+		return record;
+	}
+
+	std::vector<ReadAlignmentDumpRecord> canonicalReadAlignmentRecordsFromTyped(
+		const std::vector<ReadAlignmentTypedSegment>& typedRecords)
+	{
+		std::vector<ReadAlignmentDumpRecord> records;
+		records.reserve(typedRecords.size());
+		for (const auto& typed : typedRecords)
+		{
+			records.push_back(readAlignmentTypedSegmentToDumpRecord(typed));
+		}
+		std::sort(records.begin(), records.end());
+		return records;
+	}
+
+	size_t validateReadAlignmentTypedChains(
+		const std::vector<ReadAlignmentTypedSegment>& typedRecords,
+		const std::string& path)
+	{
+		size_t chainCount = 0;
+		int64_t currentChain = -1;
+		int64_t expectedSegment = 0;
+		for (const auto& typed : typedRecords)
+		{
+			if (typed.chainId != currentChain)
+			{
+				currentChain = typed.chainId;
+				expectedSegment = 0;
+				++chainCount;
+			}
+			if (typed.segmentId != expectedSegment)
+			{
+				throw std::runtime_error(path + ": non-contiguous segment_id in "
+										 "rehydrated GraphAlignment-shaped chain");
+			}
+			++expectedSegment;
+		}
+		return chainCount;
+	}
