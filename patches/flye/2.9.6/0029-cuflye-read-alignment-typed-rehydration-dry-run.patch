+	ReadAlignmentDumpRecord parseReadAlignmentDumpRecord(
+		const std::string& line,
+		const std::string& path,
+		size_t lineNumber)
+	{
+		ReadAlignmentDumpRecord record;
+		double seqDivergence = 0.0;
+		std::istringstream stream(line);
+		std::string extra;
+		if (!(stream >> record.chainId >> record.segmentId >> record.readId >>
+			  record.readBegin >> record.readEnd >> record.readLen >>
+			  record.edgeId >> record.edgeSeqId >> record.edgeBegin >>
+			  record.edgeEnd >> record.edgeLen >> record.score >>
+			  seqDivergence) ||
+			stream >> extra)
+		{
+			throw std::runtime_error(path + ": malformed read-alignment row at line " +
+									 std::to_string(lineNumber));
+		}
+		record.seqDivergence = static_cast<float>(seqDivergence);
+		if (!std::isfinite(seqDivergence) || !std::isfinite(record.seqDivergence))
+		{
+			throw std::runtime_error(path + ": non-finite seq_divergence at line " +
+									 std::to_string(lineNumber));
+		}
+		return record;
+	}
+
+	std::vector<ReadAlignmentDumpRecord> readAlignmentDumpRecords(
+		const std::string& path)
+	{
+		std::ifstream input(path);
+		if (!input)
+		{
+			throw std::runtime_error("Can't open read alignment TSV: " + path);
+		}
+		std::vector<ReadAlignmentDumpRecord> records;
+		std::string line;
+		size_t lineNumber = 0;
+		while (std::getline(input, line))
+		{
+			++lineNumber;
+			if (!line.empty() && line.back() == '\r') line.pop_back();
+			if (line.empty()) continue;
+			records.push_back(parseReadAlignmentDumpRecord(line, path, lineNumber));
+		}
+		std::sort(records.begin(), records.end());
+		return records;
+	}
