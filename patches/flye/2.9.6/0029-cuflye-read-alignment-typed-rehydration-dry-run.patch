+
+	bool allReadAlignmentRehydrationChecksPassed(
+		const ReadAlignmentRehydrationResult& rehydration)
+	{
+		for (const auto& check : rehydration.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !rehydration.checks.empty();
+	}
+
+	void markReadAlignmentRehydrationFailed(
+		ReadAlignmentRehydrationResult& rehydration)
+	{
+		rehydration.status = "failed";
+		rehydration.state = "failed-closed";
+		rehydration.decision = "failed-closed-before-graph-mutation";
+		rehydration.eligible = false;
+		rehydration.consumed = false;
+		rehydration.notConsumed = false;
+		rehydration.failedClosed = true;
+	}
+
+	ReadAlignmentRehydrationResult evaluateReadAlignmentRehydration(
+		const std::vector<int64_t>& queryIds,
+		const std::string& batchOutputDir,
+		const ReadAlignmentWorkerValidationResult& validation,
+		const ReadAlignmentGraphGuardResult& guard,
+		const std::string& rehydrationJson,
+		RepeatGraph& graph)
+	{
+		ReadAlignmentRehydrationResult result;
+		result.mode = readAlignmentRehydrationMode();
+		result.proofFault = readAlignmentRehydrationProofFault();
+		if (!readAlignmentRehydrationEnabled()) return result;
+
+		markReadAlignmentRehydrationFailed(result);
+		addReadAlignmentRehydrationCheck(
+			result, "explicit_rehydration_mode",
+			result.mode == "typed-graph-alignment-v0",
+			"CUFLYE_READ_ALIGNMENT_REHYDRATION_MODE=typed-graph-alignment-v0");
+		addReadAlignmentRehydrationCheck(
+			result, "graph_guard_passed",
+			guard.status == "passed" && guard.eligible,
+			"M5j read-alignment graph guard must be eligible");
+		addReadAlignmentRehydrationCheck(
+			result, "validation_passed",
+			validation.status == "passed" && validation.consumptionEligible,
+			"worker output validation must pass");
+		addReadAlignmentRehydrationCheck(
+			result, "fixture_count_nonzero", !queryIds.empty(),
+			"at least one replay fixture must be selected");
+		addReadAlignmentRehydrationCheck(
+			result, "audit_metadata_available", !rehydrationJson.empty(),
+			"rehydration audit JSON path must be available");
+
+		if (!allReadAlignmentRehydrationChecksPassed(result)) return result;
+
+		result.status = "passed";
+		result.state = "not-consumed";
+		result.decision = "typed-graph-alignment-match-not-consumed";
+		result.eligible = true;
+		result.notConsumed = true;
+		result.failedClosed = false;
+
+		for (int64_t queryId : queryIds)
+		{
+			ReadAlignmentFixtureRehydration fixture;
+			fixture.queryId = queryId;
+			fixture.fixtureDir = readAlignmentFixtureDirForQuery(queryId);
+			fixture.oracleTsv = joinReplayPath(fixture.fixtureDir,
+											   "oracle.read-alignment.tsv");
+			fixture.workerTsv = joinReplayPath(
+				joinReplayPath(batchOutputDir, replayQueryDirName(queryId)),
+				"read-alignment.tsv");
+			try
+			{
+				auto oracleRecords = readAlignmentDumpRecords(fixture.oracleTsv);
+				auto workerRecords = readAlignmentDumpRecords(fixture.workerTsv);
+				fixture.oracleRecords = oracleRecords.size();
+				fixture.workerRecords = workerRecords.size();
+				if (result.proofFault == "drop-first-worker-record" &&
+					!workerRecords.empty())
+				{
+					workerRecords.erase(workerRecords.begin());
+					fixture.proofFaultApplied = true;
+				}
+				auto typedRecords =
+					rehydrateTypedReadAlignmentRecords(workerRecords, graph,
+													   fixture.workerTsv);
+				fixture.rehydratedRecords = typedRecords.size();
+				fixture.rehydratedChains =
+					validateReadAlignmentTypedChains(typedRecords, fixture.workerTsv);
+				auto rehydratedRecords =
+					canonicalReadAlignmentRecordsFromTyped(typedRecords);
+				if (oracleRecords == rehydratedRecords)
+				{
+					fixture.status = "passed";
+					fixture.typedGraphAlignmentStatus = "match";
+					result.totalRehydratedRecords += fixture.rehydratedRecords;
+					result.totalRehydratedChains += fixture.rehydratedChains;
+				}
+				else
+				{
+					fixture.status = "failed";
+					fixture.typedGraphAlignmentStatus = "mismatch";
+					fixture.error =
+						"rehydrated GraphAlignment-shaped records differ from CPU oracle";
+					markReadAlignmentRehydrationFailed(result);
+				}
+			}
+			catch (const std::exception& exc)
+			{
+				fixture.status = "failed";
+				fixture.error = exc.what();
+				markReadAlignmentRehydrationFailed(result);
+			}
+			result.fixtures.push_back(fixture);
+		}
+
+		if (result.fixtures.empty()) markReadAlignmentRehydrationFailed(result);
+		return result;
+	}
