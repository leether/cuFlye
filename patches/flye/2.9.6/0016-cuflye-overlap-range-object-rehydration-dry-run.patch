+	void addObjectRehydrationCheck(
+		OverlapWorkerObjectRehydrationResult& objectRehydration,
+		const std::string& name,
+		bool passed,
+		const std::string& detail)
+	{
+		OverlapWorkerObjectRehydrationCheck check;
+		check.name = name;
+		check.required = true;
+		check.passed = passed;
+		check.detail = detail;
+		objectRehydration.checks.push_back(check);
+	}
+
+	bool allObjectRehydrationChecksPassed(
+		const OverlapWorkerObjectRehydrationResult& objectRehydration)
+	{
+		for (const auto& check : objectRehydration.checks)
+		{
+			if (check.required && !check.passed) return false;
+		}
+		return !objectRehydration.checks.empty();
+	}
+
+	void markObjectRehydrationFailed(
+		OverlapWorkerObjectRehydrationResult& objectRehydration)
+	{
+		objectRehydration.status = "failed";
+		objectRehydration.state = "failed-closed";
+		objectRehydration.decision = "failed-closed-before-graph-mutation";
+		objectRehydration.eligible = false;
+		objectRehydration.consumed = false;
+		objectRehydration.notConsumed = false;
+		objectRehydration.failedClosed = true;
+	}
+
+	OverlapWorkerObjectRehydrationResult
+	compareOverlapWorkerObjectRehydrationOutputs(
+		const std::vector<std::string>& fixtures,
+		const std::string& batchOutputDir,
+		const OverlapWorkerRehydrationResult& rehydration,
+		const std::string& objectJson)
+	{
+		OverlapWorkerObjectRehydrationResult result;
+		result.mode = overlapWorkerObjectRehydrationMode();
+		result.proofFault = overlapWorkerObjectRehydrationProofFault();
+		if (!overlapWorkerObjectRehydrationEnabled()) return result;
+
+		markObjectRehydrationFailed(result);
+		addObjectRehydrationCheck(result, "explicit_object_rehydration_mode",
+								  result.mode == "overlap-range-object-v0",
+								  "CUFLYE_OVERLAP_OBJECT_REHYDRATION_MODE=overlap-range-object-v0");
+		addObjectRehydrationCheck(result, "typed_rehydration_passed",
+								  rehydration.status == "passed" &&
+									  rehydration.eligible,
+								  "M4p typed rehydration must pass");
+		addObjectRehydrationCheck(result, "fixture_count_matches_request",
+								  fixtures.size() == overlapReplayMaxFixtures(),
+								  "captured fixture count must match request");
+		addObjectRehydrationCheck(result, "audit_metadata_available",
+								  !objectJson.empty(),
+								  "object rehydration audit JSON path must be available");
+
+		if (!allObjectRehydrationChecksPassed(result)) return result;
+
+		result.status = "passed";
+		result.state = "not-consumed";
+		result.decision = "overlap-range-object-match-not-consumed";
+		result.eligible = true;
+		result.notConsumed = true;
+		result.failedClosed = false;
+
+		auto& cpuRecordsByFixture = overlapReplayCapturedCpuRecords();
+		for (const auto& fixtureDir : fixtures)
+		{
+			OverlapWorkerFixtureObjectRehydration fixture;
+			fixture.fixtureDir = fixtureDir;
+			fixture.fixtureName = pathBasename(fixtureDir);
+			fixture.workerPath = joinPath(joinPath(batchOutputDir, fixture.fixtureName),
+										  "overlaps.tsv");
+			try
+			{
+				auto cpuIt = cpuRecordsByFixture.find(fixtureDir);
+				if (cpuIt == cpuRecordsByFixture.end())
+				{
+					throw std::runtime_error(
+						"missing captured CPU overlap records for fixture");
+				}
+				fixture.cpuRecords = cpuIt->second.size();
+				auto workerRecords = readCanonicalOverlapDump(fixture.workerPath);
+				fixture.workerRecords = workerRecords.size();
+				auto typedRecords = rehydrateTypedOverlapRecords(workerRecords,
+																fixture.workerPath);
+				fixture.typedRecords = typedRecords.size();
+				auto objectRecords = rehydrateOverlapRangeObjects(typedRecords);
+				if (result.proofFault == "drop-first-overlap-range" &&
+					!objectRecords.empty())
+				{
+					objectRecords.erase(objectRecords.begin());
+					fixture.proofFaultApplied = true;
+				}
+				fixture.objectRecords = objectRecords.size();
+				auto objectDumpRecords = canonicalOverlapRecordsFromRanges(objectRecords);
+				if (cpuIt->second == objectDumpRecords)
+				{
+					fixture.status = "passed";
+					fixture.objectVectorStatus = "match";
+				}
+				else
+				{
+					fixture.status = "failed";
+					fixture.objectVectorStatus = "mismatch";
+					fixture.error =
+						"rehydrated OverlapRange object vector differs from captured CPU records";
+					markObjectRehydrationFailed(result);
+				}
+			}
+			catch (const std::exception& exc)
+			{
+				fixture.status = "failed";
+				fixture.error = exc.what();
+				markObjectRehydrationFailed(result);
+			}
+			result.fixtures.push_back(fixture);
 		}
+
+		if (result.fixtures.empty()) markObjectRehydrationFailed(result);
+		return result;
+	}
