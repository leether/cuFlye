+	std::string overlapWorkerObjectRehydrationMode()
+	{
+		static std::string mode = []()
+		{
+			const char* raw = std::getenv("CUFLYE_OVERLAP_OBJECT_REHYDRATION_MODE");
+			if (!raw || !raw[0]) return std::string();
+			std::string selected(raw);
+			if (selected != "overlap-range-object-v0")
+			{
+				throw std::runtime_error(
+					"Unsupported CUFLYE_OVERLAP_OBJECT_REHYDRATION_MODE: " +
+					selected);
+			}
+			return selected;
+		}();
+		return mode;
+	}
+
+	bool overlapWorkerObjectRehydrationEnabled()
+	{
+		return !overlapWorkerObjectRehydrationMode().empty();
+	}
