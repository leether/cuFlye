+	std::vector<unsigned char> readAlignmentBinaryFile(const std::string& path)
+	{
+		std::ifstream input(path, std::ios::binary);
+		if (!input)
+		{
+			throw std::runtime_error("Can't open compact read alignment binary: " +
+									 path);
+		}
+		input.seekg(0, std::ios::end);
+		std::streamoff size = input.tellg();
+		if (size < 0)
+		{
+			throw std::runtime_error("Can't size compact read alignment binary: " +
+									 path);
+		}
+		input.seekg(0, std::ios::beg);
+		std::vector<unsigned char> data(static_cast<size_t>(size));
+		if (!data.empty())
+		{
+			input.read(reinterpret_cast<char*>(data.data()),
+					   static_cast<std::streamsize>(data.size()));
+		}
+		if (!input)
+		{
+			throw std::runtime_error("Can't read compact read alignment binary: " +
+									 path);
+		}
+		return data;
+	}
+
+	uint32_t readAlignmentBinaryU32(const std::vector<unsigned char>& data,
+									size_t offset,
+									const std::string& path)
+	{
+		if (offset + 4 > data.size())
+		{
+			throw std::runtime_error(path + ": compact binary u32 read out of bounds");
+		}
+		uint32_t value = 0;
+		for (size_t index = 0; index < 4; ++index)
+		{
+			value |= static_cast<uint32_t>(data[offset + index]) << (index * 8);
+		}
+		return value;
+	}
+
+	uint64_t readAlignmentBinaryU64(const std::vector<unsigned char>& data,
+									size_t offset,
+									const std::string& path)
+	{
+		if (offset + 8 > data.size())
+		{
+			throw std::runtime_error(path + ": compact binary u64 read out of bounds");
+		}
+		uint64_t value = 0;
+		for (size_t index = 0; index < 8; ++index)
+		{
+			value |= static_cast<uint64_t>(data[offset + index]) << (index * 8);
+		}
+		return value;
+	}
+
+	int32_t readAlignmentBinaryI32(const std::vector<unsigned char>& data,
+								   size_t offset,
+								   const std::string& path)
+	{
+		uint32_t bits = readAlignmentBinaryU32(data, offset, path);
+		int32_t value = 0;
+		std::memcpy(&value, &bits, sizeof(value));
+		return value;
+	}
+
+	int64_t readAlignmentBinaryI64(const std::vector<unsigned char>& data,
+								   size_t offset,
+								   const std::string& path)
+	{
+		uint64_t bits = readAlignmentBinaryU64(data, offset, path);
+		int64_t value = 0;
+		std::memcpy(&value, &bits, sizeof(value));
+		return value;
+	}
+
+	float readAlignmentBinaryF32(const std::vector<unsigned char>& data,
+								 size_t offset,
+								 const std::string& path)
+	{
+		uint32_t bits = readAlignmentBinaryU32(data, offset, path);
+		float value = 0.0f;
+		std::memcpy(&value, &bits, sizeof(value));
+		if (!std::isfinite(value))
+		{
+			throw std::runtime_error(path +
+									 ": compact binary non-finite seq_divergence");
+		}
+		return value;
+	}
+
+	bool readAlignmentSha256HexValid(const std::string& text)
+	{
+		if (text.size() != 64) return false;
+		for (char ch : text)
+		{
+			if (!std::isxdigit(static_cast<unsigned char>(ch))) return false;
+		}
+		return true;
+	}
+
+	std::string readAlignmentSha256File(const std::string& path)
+	{
+		std::string command = "sha256sum " + readAlignmentShellQuote(path);
+		std::array<char, 256> buffer{};
+		std::string output;
+		std::unique_ptr<FILE, int (*)(FILE*)> pipe(
+			popen(command.c_str(), "r"), pclose);
+		if (!pipe)
+		{
+			throw std::runtime_error("Can't run sha256sum for compact binary: " +
+									 path);
+		}
+		while (std::fgets(buffer.data(),
+						  static_cast<int>(buffer.size()), pipe.get()))
+		{
+			output += buffer.data();
+		}
+		std::istringstream parsed(output);
+		std::string digest;
+		if (!(parsed >> digest) || !readAlignmentSha256HexValid(digest))
+		{
+			throw std::runtime_error("sha256sum returned malformed output for " +
+									 path);
+		}
+		return digest;
+	}
+
+	void writeReadAlignmentBinaryFile(const std::string& path,
+									  const std::vector<unsigned char>& data)
+	{
+		std::ofstream output(path, std::ios::binary);
+		if (!output)
+		{
+			throw std::runtime_error("Can't open compact binary for write: " +
+									 path);
+		}
+		if (!data.empty())
+		{
+			output.write(reinterpret_cast<const char*>(data.data()),
+						 static_cast<std::streamsize>(data.size()));
+		}
+		if (!output)
+		{
+			throw std::runtime_error("Can't write compact binary: " + path);
+		}
+	}
+
+	void truncateReadAlignmentCompactBinaryPayload(const std::string& path)
+	{
+		std::vector<unsigned char> data = readAlignmentBinaryFile(path);
+		if (data.empty())
+		{
+			throw std::runtime_error("Can't truncate empty compact binary: " +
+									 path);
+		}
+		data.pop_back();
+		writeReadAlignmentBinaryFile(path, data);
+	}
+
+	ReadAlignmentDumpRecord readAlignmentCompactBinaryRecord(
+		const std::vector<unsigned char>& data,
+		size_t offset,
+		int64_t& queryId,
+		const std::string& path)
+	{
+		ReadAlignmentDumpRecord record;
+		queryId = readAlignmentBinaryI64(data, offset + 0, path);
+		record.chainId = readAlignmentBinaryI32(data, offset + 8, path);
+		record.segmentId = readAlignmentBinaryI32(data, offset + 12, path);
+		(void)readAlignmentBinaryI32(data, offset + 16, path);
+		(void)readAlignmentBinaryI64(data, offset + 20, path);
+		record.readId = readAlignmentBinaryI64(data, offset + 28, path);
+		record.readBegin = readAlignmentBinaryI32(data, offset + 36, path);
+		record.readEnd = readAlignmentBinaryI32(data, offset + 40, path);
+		record.readLen = readAlignmentBinaryI32(data, offset + 44, path);
+		record.edgeId = readAlignmentBinaryI64(data, offset + 48, path);
+		(void)readAlignmentBinaryI32(data, offset + 56, path);
+		(void)readAlignmentBinaryI32(data, offset + 60, path);
+		record.edgeSeqId = readAlignmentBinaryI64(data, offset + 64, path);
+		record.edgeBegin = readAlignmentBinaryI32(data, offset + 72, path);
+		record.edgeEnd = readAlignmentBinaryI32(data, offset + 76, path);
+		record.edgeLen = readAlignmentBinaryI32(data, offset + 80, path);
+		record.score = readAlignmentBinaryI32(data, offset + 84, path);
+		record.seqDivergence = readAlignmentBinaryF32(data, offset + 88, path);
+		return record;
+	}
+
+	ReadAlignmentCompactBinaryPayload readAlignmentCompactBinaryPayload(
+		const std::string& path,
+		const std::vector<int64_t>& queryIds,
+		size_t expectedFixtureCount)
+	{
+		ReadAlignmentCompactBinaryPayload payload;
+		payload.path = path;
+		payload.sha256 = readAlignmentSha256File(path);
+		std::string expectedSha = readAlignmentCompactBinaryExpectedSha256();
+		if (!expectedSha.empty())
+		{
+			if (!readAlignmentSha256HexValid(expectedSha))
+			{
+				throw std::runtime_error(
+					"CUFLYE_READ_ALIGNMENT_COMPACT_BINARY_EXPECTED_SHA256 "
+					"must be a 64-character hex digest");
+			}
+			if (payload.sha256 != expectedSha)
+			{
+				throw std::runtime_error(
+					"compact binary checksum mismatch: expected " + expectedSha +
+					", got " + payload.sha256);
+			}
+			payload.checksumStatus = "matched";
+		}
+
+		std::vector<unsigned char> data = readAlignmentBinaryFile(path);
+		static const size_t HEADER_BYTES = 64;
+		static const size_t RECORD_BYTES = 92;
+		if (data.size() < HEADER_BYTES)
+		{
+			throw std::runtime_error(path + ": compact binary is shorter than header");
+		}
+		const char magic[] = {'C', 'U', 'F', 'R', 'A', 'L', 'B', '0'};
+		for (size_t index = 0; index < sizeof(magic); ++index)
+		{
+			if (data[index] != static_cast<unsigned char>(magic[index]))
+			{
+				throw std::runtime_error(path + ": invalid compact binary magic");
+			}
+		}
+		uint32_t headerBytes = readAlignmentBinaryU32(data, 8, path);
+		uint32_t recordBytes = readAlignmentBinaryU32(data, 12, path);
+		uint32_t versionMajor = readAlignmentBinaryU32(data, 16, path);
+		uint32_t versionMinor = readAlignmentBinaryU32(data, 20, path);
+		payload.fixtureCount = readAlignmentBinaryU64(data, 24, path);
+		payload.outputRecords = readAlignmentBinaryU64(data, 32, path);
+		payload.totalInputRecords = readAlignmentBinaryU64(data, 40, path);
+		payload.minInputRecords = readAlignmentBinaryU32(data, 48, path);
+		payload.maxInputRecords = readAlignmentBinaryU32(data, 52, path);
+		uint32_t outputMode = readAlignmentBinaryU32(data, 56, path);
+		uint32_t reserved = readAlignmentBinaryU32(data, 60, path);
+		if (headerBytes != HEADER_BYTES || recordBytes != RECORD_BYTES)
+		{
+			throw std::runtime_error(path +
+									 ": unsupported compact binary byte layout");
+		}
+		if (versionMajor != 0 || versionMinor != 0)
+		{
+			throw std::runtime_error(path +
+									 ": unsupported compact binary version");
+		}
+		if (payload.fixtureCount != expectedFixtureCount)
+		{
+			throw std::runtime_error(path + ": compact binary fixture count mismatch");
+		}
+		if (payload.minInputRecords > payload.maxInputRecords)
+		{
+			throw std::runtime_error(path +
+									 ": compact binary min/max input count mismatch");
+		}
+		if (outputMode != 1 || reserved != 0)
+		{
+			throw std::runtime_error(path +
+									 ": invalid compact binary output mode header");
+		}
+		if (payload.outputRecords >
+			(std::numeric_limits<uint64_t>::max() - HEADER_BYTES) / RECORD_BYTES)
+		{
+			throw std::runtime_error(path +
+									 ": compact binary payload size overflows");
+		}
+		uint64_t expectedSize =
+			payload.outputRecords * RECORD_BYTES + HEADER_BYTES;
+		if (expectedSize != static_cast<uint64_t>(data.size()))
+		{
+			throw std::runtime_error(path + ": compact binary payload size mismatch");
+		}
+
+		std::unordered_set<int64_t> expectedQueries(queryIds.begin(), queryIds.end());
+		for (uint64_t recordIndex = 0; recordIndex < payload.outputRecords;
+			 ++recordIndex)
+		{
+			size_t offset = HEADER_BYTES +
+				static_cast<size_t>(recordIndex) * RECORD_BYTES;
+			int64_t queryId = 0;
+			ReadAlignmentDumpRecord record =
+				readAlignmentCompactBinaryRecord(data, offset, queryId, path);
+			if (expectedQueries.count(queryId) == 0)
+			{
+				throw std::runtime_error(path +
+										 ": compact binary record has unexpected query_id " +
+										 std::to_string(queryId));
+			}
+			payload.recordsByQuery[queryId].push_back(record);
+		}
+		for (auto& item : payload.recordsByQuery)
+		{
+			std::sort(item.second.begin(), item.second.end());
+		}
+		return payload;
+	}
